# ── Required ─────────────────────────────────────────────────────────
RELAY_API_KEY=                      # 32+ random chars, see README §3
SMTP_USER=                          # support@yourdomain.com
SMTP_PASSWORD=                      # Gmail App Password, 16 chars no spaces
SMTP_FROM=Nexus Support <support@yourdomain.com>

# ── Defaults (override only if needed) ──────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
DAILY_LIMIT_PER_USER=10

# ── Policy (highly recommended) ─────────────────────────────────────
# Comma-separated. Either list, both, or neither. Neither = relay
# will accept ANY recipient — DON'T do this in production.
ALLOWED_RECIPIENTS=
ALLOWED_DOMAINS=

# ── Storage ─────────────────────────────────────────────────────────
AUDIT_DB_PATH=/data/audit.db        # /data is the Fly volume mount

# ── Dev ─────────────────────────────────────────────────────────────
DEBUG_MODE=0
