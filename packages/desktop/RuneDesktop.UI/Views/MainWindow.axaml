<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:views="clr-namespace:RuneDesktop.UI.Views"
        xmlns:vm="clr-namespace:RuneDesktop.UI.ViewModels"
        x:Class="RuneDesktop.UI.Views.MainWindow"
        Title="Nexus"
        Icon="avares://Nexus/Assets/nexus-icon.png"
        WindowStartupLocation="CenterScreen"
        Width="1280" Height="800"
        MinWidth="1024" MinHeight="640"
        Background="{StaticResource SurfaceBaseBrush}"
        x:Name="RootWindow">

  <Grid RowDefinitions="44,*">

    <!-- Top toolbar. macOS apps use a 44 pt toolbar height with a
         single hairline divider, near-flat background that's barely
         distinguishable from the window chrome. We keep it 1 px darker
         than SurfaceBase so the eye can find the boundary, but we
         drop the heavy yellow N tile from the old design — the app
         icon in the Dock already carries that identity, the toolbar
         should be calm. -->
    <Border Grid.Row="0"
            Background="{StaticResource SurfaceBase}"
            BorderThickness="0,0,0,1"
            BorderBrush="{StaticResource DividerBrush}"
            Padding="14,0">
      <DockPanel>
        <StackPanel DockPanel.Dock="Left" Orientation="Horizontal" Spacing="8"
                    VerticalAlignment="Center">
          <!-- Sidebar toggle (Cmd+\\). Hides/shows the entire session
               rail — cleanest pattern for "I just want the chat
               surface, no chrome". When the rail is hidden, this
               button is the only way back. -->
          <Button Classes="toolbar"
                  IsVisible="{Binding IsLoggedIn}"
                  Command="{Binding SessionsVm.ToggleHiddenCommand}"
                  ToolTip.Tip="Toggle session rail (Ctrl+\)"
                  FontSize="14">
            <TextBlock Text="☰"
                       Foreground="{StaticResource TextPrimaryBrush}"/>
          </Button>
          <!-- Wordmark only — drop the brand-colour tile. The app
               icon does identity work; the toolbar shouldn't repeat
               it. SemiBold 13 pt is the macOS toolbar title weight. -->
          <TextBlock Text="Nexus"
                     FontSize="13" FontWeight="SemiBold"
                     Foreground="{StaticResource TextPrimaryBrush}"
                     VerticalAlignment="Center"
                     Margin="6,0,0,0"/>
        </StackPanel>

        <StackPanel DockPanel.Dock="Right" Orientation="Horizontal"
                    Spacing="12" VerticalAlignment="Center">
          <!-- "Return to chat" affordance — shown only when the user
               has navigated AWAY from chat (into Account or Plan).
               macOS apps put the "back to main" return in the toolbar
               of the secondary view; we do the same so the user
               always has a one-click path back to chat regardless of
               where they are.
               When IsChatActive is true this button collapses (no
               clutter on the default surface). -->
          <Button Classes="toolbar"
                  Command="{Binding ShowChatCommand}"
                  IsVisible="{Binding !IsChatActive}"
                  FontSize="13"
                  Content="← Back to chat"/>

          <!-- Cognition toggle moved into the chat surface's own
               toolbar — keeping it in the top bar made the toolbar
               busy AND the action only applies to Chat view anyway.
               See ChatView's Inspector button. -->

          <!-- On-chain indicator. Tiny green dot + tooltip is enough
               status — the previous pill ("ERC-8004 #1085") repeated
               info the user can see in the Account view, and at
               toolbar density a 130-px pill is visual noise. macOS
               apps use status dots (Mail's "sending", Messages'
               "delivered") not labelled pills. -->
          <Border IsVisible="{Binding ChatVm.IsOnChain}"
                  Width="10" Height="10" CornerRadius="5"
                  Background="{StaticResource SuccessBrush}"
                  VerticalAlignment="Center"
                  ToolTip.Tip="Registered on BNB Chain (ERC-8004)"/>

          <!-- Only render StatusText when there's something noteworthy
               to show (mid-bootstrap, errors, etc.). Happy-path silence
               keeps the top bar from duplicating the ERC-8004 pill +
               user pill. -->
          <TextBlock Text="{Binding StatusText}" FontSize="12"
                     Foreground="{StaticResource TextSecondaryBrush}"
                     VerticalAlignment="Center"
                     TextTrimming="CharacterEllipsis" MaxWidth="380"
                     IsVisible="{Binding StatusText, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>

          <!-- User pill — the whole avatar + name block is the click
               target. Pops a MenuFlyout with Account / Plan & Billing
               / Sign out (Slack / Linear / Figma pattern). macOS HIG:
               account-level navigation belongs under the user menu,
               not in the top-bar tab strip.
               Padding kept tight (4,3) and Background transparent so
               the pill reads as a chrome control, not a card. -->
          <Button IsVisible="{Binding IsLoggedIn}"
                  ToolTip.Tip="{Binding UserId}"
                  Background="Transparent"
                  BorderThickness="0"
                  CornerRadius="6"
                  Padding="4,3">
            <Button.Styles>
              <Style Selector="Button:pointerover /template/ ContentPresenter">
                <Setter Property="Background" Value="#14FFFFFF"/>
              </Style>
            </Button.Styles>
            <StackPanel Orientation="Horizontal" Spacing="8"
                        VerticalAlignment="Center">
              <Border Width="26" Height="26" CornerRadius="13"
                      Background="{StaticResource SurfaceRaisedBrush}"
                      BorderBrush="{StaticResource DividerBrush}"
                      BorderThickness="1">
                <TextBlock Text="{Binding UserInitial, FallbackValue=?}"
                           Foreground="{StaticResource TextPrimaryBrush}"
                           FontSize="11" FontWeight="SemiBold"
                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
              </Border>
              <StackPanel Orientation="Vertical" Spacing="0"
                          VerticalAlignment="Center">
                <TextBlock Text="{Binding UserName, FallbackValue=Unknown}"
                           FontSize="12" FontWeight="SemiBold"
                           Foreground="{StaticResource TextPrimaryBrush}"
                           TextTrimming="CharacterEllipsis" MaxWidth="180"/>
                <TextBlock Text="{Binding UserShortId}"
                           FontSize="10"
                           FontFamily="Menlo, Consolas, monospace"
                           Foreground="{StaticResource TextTertiaryBrush}"
                           TextTrimming="CharacterEllipsis" MaxWidth="180"/>
              </StackPanel>
              <!-- Down-chevron — a visual cue that this is a menu
                   trigger, not a static label. macOS convention. -->
              <TextBlock Text="▾"
                         FontSize="10"
                         Foreground="{StaticResource TextTertiaryBrush}"
                         VerticalAlignment="Center"
                         Margin="2,0,2,0"/>
            </StackPanel>
            <Button.Flyout>
              <MenuFlyout Placement="BottomEdgeAlignedRight">
                <MenuItem Header="Workflows"
                          Command="{Binding ShowWorkflowsCommand}"/>
                <MenuItem Header="Files"
                          Command="{Binding ShowFilesCommand}"/>
                <MenuItem Header="Account"
                          Command="{Binding ShowAccountCommand}"/>
                <MenuItem Header="Plan &amp; Billing"
                          Command="{Binding ShowPlanCommand}"/>
                <Separator/>
                <MenuItem Header="Sign out"
                          Command="{Binding LogoutCommand}"/>
              </MenuFlyout>
            </Button.Flyout>
          </Button>
        </StackPanel>
        <Panel/>
      </DockPanel>
    </Border>

    <!-- Content -->
    <Panel Grid.Row="1">
      <!-- First-run wizard: occludes everything else when ShowWelcome
           is true. Set on startup if the user hasn't configured a
           server URL yet, or when they click the gear icon on Login.
           IMPORTANT: We wrap WelcomeView in a Panel so IsVisible can
           bind against MainViewModel (the inherited DataContext)
           while the inner WelcomeView's DataContext is explicitly
           overridden to WelcomeVm. Without the wrapper, the
           IsVisible binding tries to resolve `ShowWelcome` on
           WelcomeVm — which doesn't have that property — and
           silently evaluates to false (gear-button-does-nothing bug). -->
      <Panel IsVisible="{Binding ShowWelcome}">
        <views:WelcomeView DataContext="{Binding WelcomeVm}"/>
      </Panel>

      <!-- Login: visible when configured but not logged in. Same
           wrapper trick as above — Panel evaluates ShowWelcome /
           IsLoggedIn against MainViewModel. -->
      <Panel>
        <Panel.IsVisible>
          <MultiBinding Converter="{x:Static BoolConverters.And}">
            <Binding Path="ShowWelcome"
                     Converter="{x:Static BoolConverters.Not}"/>
            <Binding Path="IsLoggedIn"
                     Converter="{x:Static BoolConverters.Not}"/>
          </MultiBinding>
        </Panel.IsVisible>
        <views:LoginView DataContext="{Binding LoginVm}"/>
      </Panel>

      <!-- #174 — REDESIGNED LAYOUT
           LEFT (260) : PatientNavigator (was SessionRail). Patient-
                        first list with collapsible study timelines.
           CENTER     : Active view (Chat / Plan / Account / Workflows /
                        Files) — same router as before.
           RIGHT (320): ActivityPanel with Now/Tasks/History tabs.
                        Replaces the chat-embedded Cognition panel
                        AND the floating bottom-left tasks overlay.
           BOTTOM (28): StatusBar with build / token / OCR / SMTP /
                        chain pills. Replaces the floating top-right
                        chain toast + buried token meter.
           Old SessionRailView stays in the codebase as a fallback;
           switch flag in PatientNavigatorVm controls whether the
           new rail or the old one renders — for #174 we default to
           the new patient-centric one. -->
      <Grid IsVisible="{Binding #RootWindow.DataContext.IsLoggedIn}"
            RowDefinitions="*,Auto"
            ColumnDefinitions="Auto,Auto,*,Auto">
        <!-- LEFT rail — patient navigator -->
        <views:PatientNavigatorView Grid.Column="0" Grid.Row="0"
                                     DataContext="{Binding PatientNavigatorVm}"
                                     IsVisible="{Binding PatientNavigatorVm.IsCollapsed,
                                                 Converter={x:Static BoolConverters.Not}}"/>
        <!-- Splitter between rail and chat REMOVED.
             The rail has three fixed widths (0 hidden, 60 collapsed,
             240 expanded) driven by SessionsVm.IsHidden/IsCollapsed.
             A drag splitter doesn't add value — and worse, Avalonia
             11.3's GridSplitter writes a pixel Width directly onto the
             ColumnDefinition, OVERRIDING the rail Border's own
             Width=RailWidth binding. A single stray drag could leave
             col 0 stuck at 700+ px and ignore subsequent RailWidth
             updates entirely. The rail-toggle button in the top bar
             + the «/» buttons in the rail footer cover all use cases. -->
        <Border Grid.Column="1" Width="0"/>
        <!-- Content area: shows ChatView / PlanView / AccountView
             depending on MainViewModel.ActiveView. Only one is visible
             at a time so they share Grid.Column=2. Each keeps its own
             state when hidden — no re-init when switching back, no
             scroll-to-top, attachments persist.

             CRITICAL: We override DataContext on each view (so it gets
             its own VM), but the IsVisible flags live on MainViewModel.
             A naive `{Binding IsChatActive}` would resolve against the
             OVERRIDDEN DataContext (ChatVm) and silently fail because
             ChatVm has no IsChatActive property — leaving IsVisible at
             its default `true` and stacking every view on top of every
             other view. Use #RootWindow.DataContext.X to bind directly
             to the MainViewModel regardless of the local DataContext
             override. Same pattern used by the wrapping Grid above. -->
        <!-- #175 — center canvas with top tab strip + active page.
             #177 adds an onboarding checklist row above the tab
             strip when visible. -->
        <Grid Grid.Column="2" Grid.Row="0" RowDefinitions="Auto,Auto,*">
          <!-- #177 — onboarding checklist (collapses when complete) -->
          <Border Grid.Row="0"
                  IsVisible="{Binding OnboardingVm.IsVisibleForUser}"
                  Margin="20,16,20,0"
                  Padding="16,12"
                  CornerRadius="10"
                  Background="{StaticResource SurfaceCardBrush}"
                  BorderBrush="{StaticResource AccentBrush}"
                  BorderThickness="1">
            <DockPanel DataContext="{Binding OnboardingVm}">
              <Button DockPanel.Dock="Right"
                      Command="{Binding DismissCommand}"
                      Content="✕"
                      Classes="ghost"
                      FontSize="12" Padding="6,2"
                      Foreground="{StaticResource TextSecondaryBrush}"
                      ToolTip.Tip="Hide this checklist"/>
              <StackPanel Spacing="8">
                <StackPanel Orientation="Horizontal" Spacing="8">
                  <TextBlock Text="🚀"
                             FontSize="16"
                             VerticalAlignment="Center"/>
                  <TextBlock Text="Setup checklist"
                             FontSize="13" FontWeight="SemiBold"
                             Foreground="{StaticResource TextPrimaryBrush}"
                             VerticalAlignment="Center"/>
                  <TextBlock Text="{Binding ProgressLabel}"
                             FontSize="11"
                             Foreground="{StaticResource TextSecondaryBrush}"
                             VerticalAlignment="Center"/>
                </StackPanel>
                <!-- Item 1: skill pack -->
                <Grid ColumnDefinitions="Auto,*,Auto" Margin="0,2,0,0">
                  <TextBlock Grid.Column="0"
                             Text="{Binding HasSkillInstalled,
                                    Converter={x:Static vm:BoolToCheckMarkConverter.Instance}}"
                             FontSize="13" Margin="0,0,8,0"
                             VerticalAlignment="Center"/>
                  <TextBlock Grid.Column="1"
                             Text="Install a skill pack (Medical Imaging recommended)"
                             FontSize="11"
                             Foreground="{StaticResource TextPrimaryBrush}"
                             VerticalAlignment="Center"/>
                  <Button Grid.Column="2"
                          Command="{Binding FixSkillCommand}"
                          Content="Open Workflows →"
                          IsVisible="{Binding !HasSkillInstalled}"
                          Classes="ghost"
                          Foreground="{StaticResource AccentBrush}"
                          FontSize="11" Padding="8,2"/>
                </Grid>
                <!-- Item 2: email relay -->
                <Grid ColumnDefinitions="Auto,*,Auto">
                  <TextBlock Grid.Column="0"
                             Text="{Binding HasEmailRelay,
                                    Converter={x:Static vm:BoolToCheckMarkConverter.Instance}}"
                             FontSize="13" Margin="0,0,8,0"
                             VerticalAlignment="Center"/>
                  <TextBlock Grid.Column="1"
                             Text="Configure email relay (so async tasks can email you)"
                             FontSize="11"
                             Foreground="{StaticResource TextPrimaryBrush}"
                             VerticalAlignment="Center"/>
                  <Button Grid.Column="2"
                          Command="{Binding FixEmailCommand}"
                          Content="Open Account →"
                          IsVisible="{Binding !HasEmailRelay}"
                          Classes="ghost"
                          Foreground="{StaticResource AccentBrush}"
                          FontSize="11" Padding="8,2"/>
                </Grid>
                <!-- Item 3: first upload -->
                <Grid ColumnDefinitions="Auto,*,Auto">
                  <TextBlock Grid.Column="0"
                             Text="{Binding HasFirstUpload,
                                    Converter={x:Static vm:BoolToCheckMarkConverter.Instance}}"
                             FontSize="13" Margin="0,0,8,0"
                             VerticalAlignment="Center"/>
                  <TextBlock Grid.Column="1"
                             Text="Upload your first DICOM study or image"
                             FontSize="11"
                             Foreground="{StaticResource TextPrimaryBrush}"
                             VerticalAlignment="Center"/>
                  <Button Grid.Column="2"
                          Command="{Binding FixUploadCommand}"
                          Content="Open Chat →"
                          IsVisible="{Binding !HasFirstUpload}"
                          Classes="ghost"
                          Foreground="{StaticResource AccentBrush}"
                          FontSize="11" Padding="8,2"/>
                </Grid>
              </StackPanel>
            </DockPanel>
          </Border>
          <!-- Tab strip — Chat / Viewer / Library -->
          <Border Grid.Row="1"
                  BorderThickness="0,0,0,1"
                  BorderBrush="{StaticResource DividerBrush}"
                  Background="{StaticResource SurfaceBaseBrush}"
                  Padding="0,4">
            <StackPanel Orientation="Horizontal" Spacing="2"
                        HorizontalAlignment="Center">
              <Button Command="{Binding ShowChatCommand}"
                      Classes="ghost" Padding="14,6" FontSize="12">
                <TextBlock Text="💬  Chat"
                           FontWeight="{Binding IsCanvasChat,
                                      Converter={x:Static vm:BoolToFontWeightConverter.Instance}}"
                           Foreground="{Binding IsCanvasChat,
                                      Converter={x:Static vm:BoolToAccentForegroundConverter.Instance}}"/>
              </Button>
              <Button Command="{Binding ShowViewerCommand}"
                      Classes="ghost" Padding="14,6" FontSize="12">
                <TextBlock Text="🩻  Viewer"
                           FontWeight="{Binding IsCanvasViewer,
                                      Converter={x:Static vm:BoolToFontWeightConverter.Instance}}"
                           Foreground="{Binding IsCanvasViewer,
                                      Converter={x:Static vm:BoolToAccentForegroundConverter.Instance}}"/>
              </Button>
              <Button Command="{Binding ShowLibraryCommand}"
                      Classes="ghost" Padding="14,6" FontSize="12">
                <TextBlock Text="📚  Library"
                           FontWeight="{Binding IsCanvasLibrary,
                                      Converter={x:Static vm:BoolToFontWeightConverter.Instance}}"
                           Foreground="{Binding IsCanvasLibrary,
                                      Converter={x:Static vm:BoolToAccentForegroundConverter.Instance}}"/>
              </Button>
            </StackPanel>
          </Border>
          <!-- Active page — only one IsVisible at a time. Library
               sub-pages (workflows/files/account/plan) all render
               in the Library slot since IsCanvasLibrary stays true
               for them. -->
          <Grid Grid.Row="2">
            <views:ChatView DataContext="{Binding ChatVm}"
                            IsVisible="{Binding #RootWindow.DataContext.IsChatActive}"/>
            <Border IsVisible="{Binding #RootWindow.DataContext.IsViewerActive}"
                    Background="{StaticResource SurfaceMutedBrush}">
              <TextBlock Text="Viewer — select a study from the patient navigator on the left to load it here. (Inline DICOM viewer integration coming in Phase 3 follow-up.)"
                         FontSize="13" TextWrapping="Wrap"
                         Foreground="{StaticResource TextSecondaryBrush}"
                         Margin="40" MaxWidth="600"
                         HorizontalAlignment="Center"
                         VerticalAlignment="Center"/>
            </Border>
            <views:LibraryView DataContext="{Binding}"
                               IsVisible="{Binding #RootWindow.DataContext.IsLibraryActive}"/>
            <views:PlanView DataContext="{Binding PlanVm}"
                            IsVisible="{Binding #RootWindow.DataContext.IsPlanActive}"/>
            <views:AccountView DataContext="{Binding AccountVm}"
                               IsVisible="{Binding #RootWindow.DataContext.IsAccountActive}"/>
            <views:WorkflowsView DataContext="{Binding WorkflowsVm}"
                                 IsVisible="{Binding #RootWindow.DataContext.IsWorkflowsActive}"/>
            <views:FilesView DataContext="{Binding FilesVm}"
                             IsVisible="{Binding #RootWindow.DataContext.IsFilesActive}"/>
            <!-- #181 — full-roster patients view -->
            <views:PatientsView DataContext="{Binding PatientsVm}"
                                IsVisible="{Binding #RootWindow.DataContext.IsPatientsActive}"/>
          </Grid>
        </Grid>

        <!-- #174 — RIGHT rail: Activity panel (Now/Tasks/History tabs).
             Only visible in chat mode — other views (Plan/Account/etc)
             have their own dedicated surfaces. -->
        <views:ActivityPanelView Grid.Column="3" Grid.Row="0"
                                  DataContext="{Binding ActivityPanelVm}"
                                  IsVisible="{Binding #RootWindow.DataContext.IsChatActive}"/>

        <!-- #174 — BOTTOM status bar spans full width. -->
        <views:StatusBarView Grid.Column="0" Grid.Row="1"
                              Grid.ColumnSpan="4"
                              DataContext="{Binding StatusBarVm}"/>
      </Grid>
    </Panel>

    <!-- Chain-degradation toast. Floats top-right above the content
         row when ToastVisible flips true. Self-clears after 8s via the
         DispatcherTimer in MainViewModel.OnChainDegradation. The
         visible→hidden transition is binding-driven so we don't need
         a behavior or animation. -->
    <Border Grid.Row="1"
            IsVisible="{Binding ToastVisible}"
            HorizontalAlignment="Right" VerticalAlignment="Top"
            Margin="0,16,16,0"
            Padding="14,10" CornerRadius="8"
            Background="{StaticResource SurfaceCardBrush}"
            BorderBrush="{StaticResource WarningBrush}"
            BorderThickness="1"
            MaxWidth="380"
            BoxShadow="0 4 14 0 #66000000">
      <StackPanel Orientation="Horizontal" Spacing="10">
        <TextBlock Text="⚠"
                   FontSize="16"
                   Foreground="{StaticResource WarningBrush}"
                   VerticalAlignment="Top"/>
        <StackPanel Spacing="2" MaxWidth="320">
          <TextBlock Text="Chain sync degraded"
                     FontSize="12" FontWeight="SemiBold"
                     Foreground="{StaticResource TextPrimaryBrush}"/>
          <TextBlock Text="{Binding ToastMessage}"
                     FontSize="11"
                     Foreground="{StaticResource TextSecondaryBrush}"
                     TextWrapping="Wrap"/>
        </StackPanel>
      </StackPanel>
    </Border>

    <!-- #172 — background tasks overlay (bottom-left).
         Floats above the chat content so it's always visible without
         scrolling the chat. Hidden when there's nothing to show.
         Margin 16,_,_,16 clears the rail's left edge (rail width
         varies 0/60/240 by collapse state — overlay sits FLUSH-LEFT
         on top of the rail when it's expanded, which is fine since
         the overlay is narrow + the rail bottom area is just the
         "« collapse" button it's safe to cover).
         Width capped at 320 so a many-task overlay doesn't dominate
         the screen — overflow scrolls inside the Border. -->
    <Border Grid.Row="1"
            IsVisible="{Binding ChatVm.AsyncTasks.HasAnyTask}"
            HorizontalAlignment="Left" VerticalAlignment="Bottom"
            Margin="16,0,0,16"
            Width="320" MaxHeight="320"
            CornerRadius="10"
            Background="{StaticResource SurfaceCardBrush}"
            BorderBrush="{StaticResource DividerBrush}"
            BorderThickness="1"
            BoxShadow="0 6 18 0 #88000000">
      <Grid RowDefinitions="Auto,*"
            DataContext="{Binding ChatVm.AsyncTasks}">
        <!-- Header: title + active counter. Per-card ✕ buttons +
             auto-hide when HasAnyTask=false handle collapse needs,
             so we don't need a separate toggle. -->
        <Border Grid.Row="0"
                BorderThickness="0,0,0,1"
                BorderBrush="{StaticResource DividerBrush}"
                Padding="12,8">
          <StackPanel Orientation="Horizontal" Spacing="8"
                      VerticalAlignment="Center">
            <TextBlock Text="⚙"
                       FontSize="13"
                       Foreground="{StaticResource AccentBrush}"/>
            <TextBlock Text="Background tasks"
                       FontSize="11" FontWeight="SemiBold"
                       Foreground="{StaticResource TextPrimaryBrush}"/>
            <TextBlock FontSize="11"
                       Foreground="{StaticResource TextTertiaryBrush}">
              <Run Text="·  "/><Run Text="{Binding ActiveCount}"/><Run Text=" active"/>
            </TextBlock>
          </StackPanel>
        </Border>
        <!-- Body: list of task cards, scrolls when overflow -->
        <ScrollViewer Grid.Row="1"
                      VerticalScrollBarVisibility="Auto"
                      Padding="8,6">
          <ItemsControl ItemsSource="{Binding Tasks}">
            <ItemsControl.ItemTemplate>
              <DataTemplate>
                <Border Padding="8,6"
                        Margin="0,2,0,0"
                        CornerRadius="6"
                        Background="{StaticResource SurfaceMutedBrush}">
                  <Grid ColumnDefinitions="Auto,*,Auto"
                        RowDefinitions="Auto,Auto,Auto">
                    <!-- Status icon -->
                    <TextBlock Grid.Column="0" Grid.Row="0" Grid.RowSpan="2"
                               Text="{Binding StatusIcon}"
                               FontSize="16"
                               VerticalAlignment="Center"
                               Margin="0,0,8,0"/>
                    <!-- Description -->
                    <TextBlock Grid.Column="1" Grid.Row="0"
                               Text="{Binding Description}"
                               FontSize="11" FontWeight="SemiBold"
                               TextTrimming="CharacterEllipsis"
                               Foreground="{StaticResource TextPrimaryBrush}"/>
                    <!-- Status + elapsed -->
                    <StackPanel Grid.Column="1" Grid.Row="1"
                                Orientation="Horizontal" Spacing="6">
                      <TextBlock Text="{Binding StatusLabel}"
                                 FontSize="10"
                                 Foreground="{StaticResource AccentBrush}"/>
                      <TextBlock Text="·"
                                 FontSize="10"
                                 Foreground="{StaticResource TextTertiaryBrush}"/>
                      <TextBlock Text="{Binding ElapsedDisplay}"
                                 FontSize="10"
                                 Foreground="{StaticResource TextTertiaryBrush}"/>
                      <TextBlock Text="{Binding EtaDisplay}"
                                 FontSize="10"
                                 IsVisible="{Binding EtaDisplay,
                                            Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                                 Foreground="{StaticResource TextTertiaryBrush}"/>
                    </StackPanel>
                    <!-- Error (if failed) -->
                    <TextBlock Grid.Column="1" Grid.Row="2"
                               Grid.ColumnSpan="2"
                               Text="{Binding Error}"
                               IsVisible="{Binding Error,
                                          Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                               FontSize="10"
                               Foreground="{StaticResource ErrorBrush}"
                               TextWrapping="Wrap"
                               Margin="0,2,0,0"/>
                    <!-- Dismiss × -->
                    <Button Grid.Column="2" Grid.Row="0" Grid.RowSpan="2"
                            Content="✕"
                            FontSize="11" Padding="4,0"
                            Background="Transparent" BorderThickness="0"
                            Foreground="{StaticResource TextSecondaryBrush}"
                            Command="{Binding $parent[ItemsControl].DataContext.DismissCardCommand}"
                            CommandParameter="{Binding}"
                            ToolTip.Tip="Hide (audit row kept in DB)"
                            VerticalAlignment="Center"/>
                  </Grid>
                </Border>
              </DataTemplate>
            </ItemsControl.ItemTemplate>
          </ItemsControl>
        </ScrollViewer>
      </Grid>
    </Border>
  </Grid>
</Window>
