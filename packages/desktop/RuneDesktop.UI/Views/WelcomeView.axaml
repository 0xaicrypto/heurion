<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:RuneDesktop.UI.ViewModels"
             x:Class="RuneDesktop.UI.Views.WelcomeView"
             x:DataType="vm:WelcomeViewModel"
             Background="{StaticResource SurfaceBaseBrush}">

  <!-- First-run wizard. Full-screen because there's no other state to
       compete with — IsLoggedIn is false, we haven't even connected
       to a server yet. Centered card pattern: keeps the focus on the
       single decision the user has to make. -->
  <Grid>
    <Border MaxWidth="520"
            HorizontalAlignment="Center"
            VerticalAlignment="Center"
            Padding="40,32"
            CornerRadius="14"
            Background="{StaticResource SurfaceCardBrush}"
            BorderBrush="{StaticResource DividerBrush}"
            BorderThickness="1"
            BoxShadow="0 8 32 0 #44000000">
      <StackPanel Spacing="20">

        <!-- Logo + heading. Neutral surface tile to match LoginView and
             SplashWindow — the brand colour belongs in the dock icon,
             not in every chrome surface. -->
        <StackPanel Orientation="Horizontal" Spacing="14"
                    HorizontalAlignment="Center">
          <!-- #185 — branded logo tile (matches passkey login page).
               72×72 deep-navy square + BNB-yellow N. -->
          <Border Width="72" Height="72" CornerRadius="16"
                  Background="#0F1729">
            <TextBlock Text="N" FontSize="40" FontWeight="Bold"
                       Foreground="#F0B90B"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center"/>
          </Border>
          <StackPanel VerticalAlignment="Center" Spacing="2">
            <TextBlock Text="Welcome to Nexus"
                       FontSize="20" FontWeight="SemiBold"
                       Foreground="{StaticResource TextPrimaryBrush}"/>
            <TextBlock Text="Let's connect you to your agent server"
                       FontSize="12"
                       Foreground="{StaticResource TextSecondaryBrush}"/>
          </StackPanel>
        </StackPanel>

        <Border Height="1" Background="{StaticResource DividerBrush}"/>

        <!-- Explanation -->
        <TextBlock TextWrapping="Wrap"
                   FontSize="13"
                   Foreground="{StaticResource TextSecondaryBrush}"
                   LineHeight="20">
          Your Nexus agent runs on a server you (or your team) deployed.
          Paste its URL below — the desktop will save it locally and
          use it for every chat. You can change it later from the gear
          icon on the login screen.
        </TextBlock>

        <!-- Server URL input -->
        <StackPanel Spacing="6">
          <TextBlock Text="SERVER URL"
                     FontSize="10" FontWeight="SemiBold"
                     Foreground="{StaticResource TextTertiaryBrush}"/>
          <TextBox Text="{Binding ServerUrl, Mode=TwoWay,
                                  UpdateSourceTrigger=PropertyChanged}"
                   Watermark="https://1-2-3-4.nip.io  or  http://localhost:8001"
                   Classes="chat"
                   FontFamily="Menlo, Consolas, monospace"
                   FontSize="13"/>
          <TextBlock FontSize="11"
                     Foreground="{StaticResource TextTertiaryBrush}"
                     TextWrapping="Wrap">
            Tip: if you deployed via the included Docker setup, your
            URL is the nip.io hostname printed at the end of
            <Run FontFamily="Menlo, Consolas, monospace"
                 Foreground="{StaticResource TextSecondaryBrush}"
                 Text="scripts/deploy_setup.sh"/>.
          </TextBlock>

          <!-- Self-signed cert checkbox: opt-in trust for dev
               deployments running scripts/generate_self_signed_cert.sh
               (no Caddy / Let's Encrypt). Skips the system trust
               store check on the desktop's HttpClient. -->
          <CheckBox IsChecked="{Binding AcceptSelfSignedCert, Mode=TwoWay}"
                    Margin="0,4,0,0">
            <StackPanel Spacing="2">
              <TextBlock Text="Trust self-signed certificate"
                         FontSize="12"
                         Foreground="{StaticResource TextPrimaryBrush}"/>
              <TextBlock TextWrapping="Wrap"
                         FontSize="10"
                         Foreground="{StaticResource TextTertiaryBrush}"
                         Text="Tick this if your server uses a self-signed cert (from scripts/generate_self_signed_cert.sh). Leave unchecked for real Let's Encrypt / domain certs — they validate against the system trust store automatically."/>
            </StackPanel>
          </CheckBox>
        </StackPanel>

        <!-- Test connection button + status -->
        <StackPanel Spacing="8">
          <StackPanel Orientation="Horizontal" Spacing="10">
            <!-- Test = tinted (secondary commitment). Continue is the
                 primary CTA below; using filled .accent here would
                 compete with it. -->
            <Button Content="Test connection"
                    Command="{Binding TestConnectionCommand}"
                    Classes="tinted"
                    HorizontalAlignment="Left"
                    FontSize="13"/>
            <!-- Spinner while testing -->
            <TextBlock Text="⟳"
                       FontSize="16"
                       Foreground="{StaticResource SystemBlueBrush}"
                       VerticalAlignment="Center"
                       IsVisible="{Binding TestStatus, ConverterParameter=testing,
                                   Converter={x:Static StringConverters.IsNotNullOrEmpty}}">
              <TextBlock.Styles>
                <Style Selector="TextBlock">
                  <Style.Animations>
                    <Animation Duration="0:0:1.2" IterationCount="INFINITE">
                      <KeyFrame Cue="0%">
                        <Setter Property="Opacity" Value="0.4"/>
                      </KeyFrame>
                      <KeyFrame Cue="50%">
                        <Setter Property="Opacity" Value="1.0"/>
                      </KeyFrame>
                      <KeyFrame Cue="100%">
                        <Setter Property="Opacity" Value="0.4"/>
                      </KeyFrame>
                    </Animation>
                  </Style.Animations>
                </Style>
              </TextBlock.Styles>
            </TextBlock>
          </StackPanel>

          <!-- Status pill — tinted background using the semantic brush.
               macOS info banners use ~10 % tint of the semantic colour
               on a neutral surface, no border. Removes the prior dark-
               green block (#1B3220) which was a holdover from the old
               palette. -->
          <Border CornerRadius="6" Padding="10,7"
                  Background="#2630D158"
                  IsVisible="{Binding TestStatus,
                              Converter={x:Static StringConverters.IsNotNullOrEmpty}}">
            <TextBlock Text="{Binding TestMessage}"
                       FontSize="12"
                       Foreground="{StaticResource TextPrimaryBrush}"
                       TextWrapping="Wrap"/>
          </Border>
        </StackPanel>

        <!-- Continue / use-anyway buttons. macOS sheet convention:
             secondary on the left (ghost), primary filled on the right. -->
        <Grid ColumnDefinitions="Auto,*,Auto">
          <Button Grid.Column="0"
                  Content="Use anyway"
                  Command="{Binding UseAnywayCommand}"
                  Classes="ghost"
                  FontSize="12"
                  ToolTip.Tip="Save without verifying — useful if the server is offline or behind a VPN."/>

          <Button Grid.Column="2"
                  Content="Continue"
                  Command="{Binding ContinueCommand}"
                  IsEnabled="{Binding CanContinue}"
                  Classes="accent"
                  FontSize="13"
                  HorizontalAlignment="Right"/>
        </Grid>

        <!-- Footer hint -->
        <TextBlock FontSize="10"
                   Foreground="{StaticResource TextTertiaryBrush}"
                   HorizontalAlignment="Center"
                   TextAlignment="Center"
                   TextWrapping="Wrap">
          <Run Text="Nothing is sent until you click Continue. Settings stored locally at "/>
          <Run FontFamily="Menlo, Consolas, monospace"
               Text="~/.config/RuneProtocol/settings.json"/>
        </TextBlock>
      </StackPanel>
    </Border>
  </Grid>
</UserControl>
