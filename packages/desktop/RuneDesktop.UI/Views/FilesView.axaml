<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:RuneDesktop.UI.ViewModels"
             x:Class="RuneDesktop.UI.Views.FilesView"
             x:DataType="vm:FilesViewModel"
             Background="{StaticResource SurfaceBaseBrush}">

  <!--
    Files page — cross-session uploaded file library.

    Layout:
      ┌─ Header row ──────────────────────────────────────────────┐
      │  Files                                  [↻ Refresh]       │
      │  23 files · 4.2 MB total                                   │
      ├──────────────┬─────────────────────────────────────────────┤
      │   List       │   Preview pane                               │
      │   (300px)    │                                              │
      │              │   <metadata>                                 │
      │   ┌─ file1   │                                              │
      │   │ file2  ◄ │   <extracted text — monospace, scrollable>   │
      │   │ file3    │                                              │
      │   │ ...      │                                              │
      │   └──────    │                                              │
      └──────────────┴─────────────────────────────────────────────┘

    Empty state: dropzone-style hint, no upload button (uploads happen
    in chat — this is a viewer, not a manager).
  -->

  <Grid RowDefinitions="Auto,*">

    <!-- ═════ Header ═════════════════════════════════════════════ -->
    <Border Grid.Row="0"
            Padding="32,24,32,16"
            BorderBrush="{StaticResource DividerBrush}"
            BorderThickness="0,0,0,1">
      <Grid ColumnDefinitions="*,Auto">
        <StackPanel Grid.Column="0" Spacing="4">
          <TextBlock Text="Files"
                     FontSize="26" FontWeight="SemiBold"
                     Foreground="{StaticResource TextPrimaryBrush}"/>
          <TextBlock Text="{Binding SummaryLine}"
                     FontSize="12"
                     Foreground="{StaticResource TextTertiaryBrush}"/>
          <TextBlock Text="Files you've uploaded across all chats. Your agent can read these on demand via read_uploaded_file."
                     FontSize="12"
                     Foreground="{StaticResource TextSecondaryBrush}"
                     TextWrapping="Wrap"
                     MaxWidth="640"
                     Margin="0,4,0,0"/>
        </StackPanel>
        <Button Grid.Column="1"
                Classes="ghost"
                Command="{Binding RefreshCommand}"
                IsEnabled="{Binding !IsLoading}"
                FontSize="12"
                Padding="10,6"
                Content="↻ Refresh"
                VerticalAlignment="Top"/>
      </Grid>
    </Border>

    <!-- ═════ Two-column body ═════════════════════════════════════ -->
    <Grid Grid.Row="1" ColumnDefinitions="320,1,*">

      <!-- ─── (a) File list ─────────────────────────────────────── -->
      <Border Grid.Column="0"
              Background="{StaticResource SurfaceMutedBrush}">
        <Grid RowDefinitions="*,Auto">

          <!-- Empty state -->
          <Border Grid.Row="0"
                  IsVisible="{Binding HasNoFiles}"
                  Padding="24,40,24,40">
            <StackPanel Spacing="10" HorizontalAlignment="Center"
                        VerticalAlignment="Top">
              <TextBlock Text="📂"
                         FontSize="36"
                         HorizontalAlignment="Center"
                         Opacity="0.4"/>
              <TextBlock Text="No files yet"
                         FontSize="14" FontWeight="SemiBold"
                         Foreground="{StaticResource TextSecondaryBrush}"
                         HorizontalAlignment="Center"/>
              <TextBlock TextWrapping="Wrap"
                         FontSize="12"
                         Foreground="{StaticResource TextTertiaryBrush}"
                         HorizontalAlignment="Center"
                         TextAlignment="Center"
                         MaxWidth="220"
                         Text="Drop files into chat or use the paperclip button. They'll appear here and persist across sessions."/>
            </StackPanel>
          </Border>

          <!-- Scrollable list -->
          <ScrollViewer Grid.Row="0"
                        IsVisible="{Binding !HasNoFiles}"
                        VerticalScrollBarVisibility="Auto"
                        HorizontalScrollBarVisibility="Disabled">
            <ItemsControl ItemsSource="{Binding Files}">
              <ItemsControl.ItemTemplate>
                <DataTemplate DataType="vm:FileItemViewModel">
                  <Button Command="{Binding $parent[UserControl].((vm:FilesViewModel)DataContext).SelectFileCommand}"
                          CommandParameter="{Binding}"
                          Background="Transparent" BorderThickness="0"
                          HorizontalAlignment="Stretch"
                          HorizontalContentAlignment="Stretch"
                          Padding="16,10" CornerRadius="0">
                    <Button.Styles>
                      <Style Selector="Button:pointerover /template/ ContentPresenter">
                        <Setter Property="Background" Value="#1AFFFFFF"/>
                      </Style>
                    </Button.Styles>
                    <Grid ColumnDefinitions="Auto,*">
                      <TextBlock Grid.Column="0" Text="{Binding Glyph}"
                                 FontSize="18" Margin="0,0,12,0"
                                 VerticalAlignment="Top"/>
                      <StackPanel Grid.Column="1" Spacing="3">
                        <TextBlock Text="{Binding Name}"
                                   FontSize="13" FontWeight="SemiBold"
                                   Foreground="{StaticResource TextPrimaryBrush}"
                                   TextTrimming="CharacterEllipsis"/>
                        <StackPanel Orientation="Horizontal" Spacing="8">
                          <TextBlock Text="{Binding SizeText}"
                                     FontSize="11"
                                     Foreground="{StaticResource TextTertiaryBrush}"/>
                          <TextBlock Text="·" FontSize="11"
                                     Foreground="{StaticResource TextTertiaryBrush}"/>
                          <TextBlock Text="{Binding RelativeTime}"
                                     FontSize="11"
                                     Foreground="{StaticResource TextTertiaryBrush}"/>
                        </StackPanel>
                        <TextBlock Text="{Binding Excerpt}"
                                   FontSize="11"
                                   Foreground="{StaticResource TextSecondaryBrush}"
                                   TextWrapping="Wrap"
                                   MaxLines="2"
                                   TextTrimming="CharacterEllipsis"
                                   Margin="0,2,0,0"
                                   IsVisible="{Binding HasText}"/>
                      </StackPanel>
                    </Grid>
                  </Button>
                </DataTemplate>
              </ItemsControl.ItemTemplate>
            </ItemsControl>
          </ScrollViewer>

          <!-- Footer with loading hint -->
          <ProgressBar Grid.Row="1"
                       IsIndeterminate="True"
                       IsVisible="{Binding IsLoading}"
                       Height="2"/>
        </Grid>
      </Border>

      <!-- Column divider -->
      <Rectangle Grid.Column="1"
                 Fill="{StaticResource DividerBrush}"
                 Width="1"/>

      <!-- ─── (b) Preview pane ──────────────────────────────────── -->
      <Grid Grid.Column="2" RowDefinitions="Auto,*">

        <!-- Empty state when no selection -->
        <Border Grid.Row="0" Grid.RowSpan="2"
                IsVisible="{Binding Selected,
                            Converter={x:Static ObjectConverters.IsNull}}"
                Padding="48,72,48,48">
          <StackPanel Spacing="12" HorizontalAlignment="Center"
                      VerticalAlignment="Top" MaxWidth="420">
            <TextBlock Text="Select a file to preview"
                       FontSize="14"
                       Foreground="{StaticResource TextSecondaryBrush}"
                       HorizontalAlignment="Center"/>
            <TextBlock TextWrapping="Wrap"
                       FontSize="12"
                       Foreground="{StaticResource TextTertiaryBrush}"
                       HorizontalAlignment="Center"
                       TextAlignment="Center"
                       Text="The preview shows the extracted text the agent reads from this file. Same content the agent sees via read_uploaded_file()."/>
          </StackPanel>
        </Border>

        <!-- Preview header (metadata + actions) -->
        <Border Grid.Row="0"
                IsVisible="{Binding Selected,
                            Converter={x:Static ObjectConverters.IsNotNull}}"
                Padding="32,20,32,16"
                BorderBrush="{StaticResource DividerBrush}"
                BorderThickness="0,0,0,1">
          <StackPanel Spacing="10" DataContext="{Binding Preview}">
            <Grid ColumnDefinitions="*,Auto">
              <StackPanel Grid.Column="0" Spacing="4">
                <TextBlock Text="{Binding Name}"
                           FontSize="18" FontWeight="SemiBold"
                           Foreground="{StaticResource TextPrimaryBrush}"
                           TextWrapping="Wrap"/>
                <StackPanel Orientation="Horizontal" Spacing="12">
                  <TextBlock FontSize="11"
                             Foreground="{StaticResource TextTertiaryBrush}">
                    <Run Text="{Binding Mime}"/>
                  </TextBlock>
                  <TextBlock FontSize="11"
                             Foreground="{StaticResource TextTertiaryBrush}">
                    <Run Text="{Binding SizeText}"/>
                  </TextBlock>
                  <TextBlock FontSize="11"
                             Foreground="{StaticResource TextTertiaryBrush}">
                    <Run Text="Uploaded "/>
                    <Run Text="{Binding CreatedAt}"/>
                  </TextBlock>
                  <TextBlock FontSize="11"
                             FontFamily="Menlo, Consolas, monospace"
                             Foreground="{StaticResource TextTertiaryBrush}"
                             IsVisible="{Binding Sha256Short,
                                         Converter={x:Static StringConverters.IsNotNullOrEmpty}}">
                    <Run Text="sha "/>
                    <Run Text="{Binding Sha256Short}"/>
                  </TextBlock>
                </StackPanel>
              </StackPanel>
              <Button Grid.Column="1"
                      Classes="ghost"
                      Content="🗑 Delete"
                      FontSize="12"
                      Padding="10,5"
                      Command="{Binding $parent[UserControl].((vm:FilesViewModel)DataContext).DeleteSelectedCommand}"
                      Foreground="{StaticResource ErrorBrush}"
                      VerticalAlignment="Center"/>
            </Grid>
          </StackPanel>
        </Border>

        <!-- Preview content (extracted text or status) -->
        <ScrollViewer Grid.Row="1"
                      VerticalScrollBarVisibility="Auto"
                      IsVisible="{Binding Selected,
                                  Converter={x:Static ObjectConverters.IsNotNull}}"
                      Padding="32,20,32,32">
          <StackPanel Spacing="14" DataContext="{Binding Preview}">

            <!-- No-text fallback -->
            <Border Background="{StaticResource SurfaceMutedBrush}"
                    CornerRadius="6" Padding="14,12"
                    IsVisible="{Binding !HasText}">
              <TextBlock TextWrapping="Wrap"
                         FontSize="12"
                         Foreground="{StaticResource TextSecondaryBrush}"
                         Text="No extracted text available yet. The agent will try to extract it the first time it opens this file."/>
            </Border>

            <!-- Section header -->
            <TextBlock Text="EXTRACTED TEXT"
                       FontSize="10" FontWeight="SemiBold"
                       Foreground="{StaticResource TextTertiaryBrush}"
                       IsVisible="{Binding HasText}"/>

            <!-- Truncation hint -->
            <Border Background="{StaticResource SurfaceMutedBrush}"
                    CornerRadius="6" Padding="12,8"
                    IsVisible="{Binding TextTruncated}">
              <TextBlock FontSize="11"
                         Foreground="{StaticResource TextSecondaryBrush}">
                <Run Text="⚠ Preview truncated to first ~100 KB. The agent can still read the full file via "/>
                <Run Text="read_uploaded_file" FontFamily="Menlo, Consolas, monospace"/>
                <Run Text="."/>
              </TextBlock>
            </Border>

            <!-- Extracted text body — selectable monospace block -->
            <SelectableTextBlock Text="{Binding ExtractedText}"
                                 FontSize="12.5"
                                 LineHeight="20"
                                 FontFamily="Menlo, Consolas, monospace"
                                 Foreground="{StaticResource TextPrimaryBrush}"
                                 TextWrapping="Wrap"
                                 IsVisible="{Binding HasText}"/>
          </StackPanel>
        </ScrollViewer>

      </Grid>
    </Grid>
  </Grid>
</UserControl>
