<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:RuneDesktop.UI.ViewModels"
             x:Class="RuneDesktop.UI.Views.ActivityPanelView"
             x:DataType="vm:ActivityPanelViewModel">

  <!--
    #174 — right rail Activity panel with three tabs:
      NOW — live cognition (this turn's thinking + tool calls)
      TASKS — background tasks (was bottom-left floating overlay)
      HISTORY — past turns / episodes
    Replaces the chat-embedded Cognition panel.
  -->

  <Border Background="{StaticResource SurfaceBaseBrush}"
          BorderBrush="{StaticResource DividerBrush}"
          BorderThickness="1,0,0,0"
          Width="320">
    <Grid RowDefinitions="Auto,*">
      <!-- Tab strip -->
      <Border Grid.Row="0"
              BorderThickness="0,0,0,1"
              BorderBrush="{StaticResource DividerBrush}"
              Padding="6,8">
        <StackPanel Orientation="Horizontal" Spacing="4"
                    HorizontalAlignment="Center">
          <Button Command="{Binding SelectNowCommand}"
                  Classes="ghost" Padding="12,6" FontSize="11">
            <TextBlock Text="● Now"
                       FontWeight="{Binding IsNowTab,
                                  Converter={x:Static vm:BoolToFontWeightConverter.Instance}}"
                       Foreground="{Binding IsNowTab,
                                  Converter={x:Static vm:BoolToAccentForegroundConverter.Instance}}"/>
          </Button>
          <Button Command="{Binding SelectTasksCommand}"
                  Classes="ghost" Padding="12,6" FontSize="11">
            <StackPanel Orientation="Horizontal" Spacing="4">
              <TextBlock Text="⚙ Tasks"
                         FontWeight="{Binding IsTasksTab,
                                    Converter={x:Static vm:BoolToFontWeightConverter.Instance}}"
                         Foreground="{Binding IsTasksTab,
                                    Converter={x:Static vm:BoolToAccentForegroundConverter.Instance}}"/>
              <Border IsVisible="{Binding Tasks.HasAnyTask}"
                      Background="{StaticResource AccentBrush}"
                      CornerRadius="8" Padding="5,1">
                <TextBlock Text="{Binding Tasks.ActiveCount}"
                           FontSize="9" Foreground="White"
                           FontWeight="SemiBold"/>
              </Border>
            </StackPanel>
          </Button>
          <Button Command="{Binding SelectHistoryCommand}"
                  Classes="ghost" Padding="12,6" FontSize="11">
            <TextBlock Text="🕒 History"
                       FontWeight="{Binding IsHistoryTab,
                                  Converter={x:Static vm:BoolToFontWeightConverter.Instance}}"
                       Foreground="{Binding IsHistoryTab,
                                  Converter={x:Static vm:BoolToAccentForegroundConverter.Instance}}"/>
          </Button>
        </StackPanel>
      </Border>

      <!-- Tab content. ScrollViewer accepts ONE child — wrap the
           three tab panels in a Grid so we can toggle visibility
           per-tab without nesting ScrollViewers. -->
      <ScrollViewer Grid.Row="1" Padding="10,10">
        <Grid>
        <!-- NOW: live cognition / tool calls.
             #178 — full migration of the in-chat Cognition panel into
             the right rail. The old Cognition column is force-hidden
             on ChatView so this is now the canonical surface for live
             agent thinking. Sections:
               1. Status header (polling indicator + last-updated)
               2. Brain "at a glance" — facts/skills/knowledge/persona
                  counters (compact 2×2 instead of 5-wide WrapPanel)
               3. Current-turn thinking stream — headline + steps -->
        <Grid IsVisible="{Binding IsNowTab}">
          <StackPanel Spacing="10">

            <!-- ── Status header ─────────────────────────────────── -->
            <StackPanel Orientation="Horizontal" Spacing="6">
              <Border Width="6" Height="6" CornerRadius="3"
                      Background="{StaticResource SuccessBrush}"
                      VerticalAlignment="Center"
                      IsVisible="{Binding Cognition.IsPolling}"/>
              <TextBlock Text="LIVE COGNITION"
                         FontSize="10" FontWeight="Bold"
                         LetterSpacing="0.8"
                         Foreground="{StaticResource TextTertiaryBrush}"
                         VerticalAlignment="Center"/>
              <TextBlock Text="·" FontSize="10"
                         Foreground="{StaticResource TextTertiaryBrush}"
                         VerticalAlignment="Center"/>
              <TextBlock Text="{Binding Cognition.LastUpdated}"
                         FontSize="10"
                         Foreground="{StaticResource TextTertiaryBrush}"
                         VerticalAlignment="Center"/>
            </StackPanel>

            <!-- ── Brain at a glance (2×N compact grid) ──────────── -->
            <Border IsVisible="{Binding Cognition.Brain.Glance.Count}"
                    Padding="2" CornerRadius="8"
                    Background="{StaticResource SurfaceMutedBrush}">
              <ItemsControl ItemsSource="{Binding Cognition.Brain.Glance}">
                <ItemsControl.ItemsPanel>
                  <ItemsPanelTemplate>
                    <WrapPanel Orientation="Horizontal"/>
                  </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                  <DataTemplate>
                    <Border Width="92" Margin="3"
                            Padding="8,6" CornerRadius="6"
                            Background="{StaticResource SurfaceCardBrush}">
                      <StackPanel Spacing="2">
                        <TextBlock Text="{Binding DisplayName}"
                                   FontSize="9"
                                   FontWeight="SemiBold"
                                   LetterSpacing="0.5"
                                   Foreground="{StaticResource TextTertiaryBrush}"/>
                        <TextBlock Text="{Binding DisplayValue}"
                                   FontSize="16"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource TextPrimaryBrush}"/>
                        <TextBlock Text="{Binding DeltaText}"
                                   FontSize="9"
                                   Foreground="{StaticResource AccentMedicalBrush}"/>
                      </StackPanel>
                    </Border>
                  </DataTemplate>
                </ItemsControl.ItemTemplate>
              </ItemsControl>
            </Border>

            <!-- ── Current turn thinking — empty state ────────────── -->
            <TextBlock IsVisible="{Binding Cognition.ThinkingEmpty}"
                       Text="Idle. Send a message or upload a study — the agent's reasoning will stream here."
                       FontSize="11" TextWrapping="Wrap"
                       Foreground="{StaticResource TextTertiaryBrush}"/>

            <!-- ── Turn cards ────────────────────────────────────── -->
            <ItemsControl ItemsSource="{Binding Cognition.Turns}"
                          IsVisible="{Binding !Cognition.ThinkingEmpty}">
              <ItemsControl.ItemTemplate>
                <DataTemplate>
                  <Border Padding="8,7" Margin="0,3"
                          CornerRadius="6"
                          BorderThickness="1"
                          BorderBrush="{StaticResource DividerBrush}"
                          Background="{StaticResource SurfaceCardBrush}">
                    <StackPanel Spacing="4">
                      <!-- Header: "Turn N · 6.2s · 7 steps" + live dot -->
                      <StackPanel Orientation="Horizontal" Spacing="5">
                        <Ellipse Width="6" Height="6"
                                 Fill="{StaticResource AccentAIBrush}"
                                 VerticalAlignment="Center"
                                 IsVisible="{Binding IsCurrent}"/>
                        <TextBlock Text="{Binding HeaderText}"
                                   FontSize="10"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource TextSecondaryBrush}"/>
                      </StackPanel>
                      <!-- Headline (user prompt snippet) -->
                      <TextBlock Text="{Binding Headline}"
                                 FontSize="11"
                                 TextWrapping="Wrap"
                                 TextTrimming="CharacterEllipsis"
                                 MaxLines="2"
                                 Foreground="{StaticResource TextPrimaryBrush}"/>
                      <!-- Step list (only when current/expanded). The
                           full step rendering with tool-call detail
                           lives in the dedicated cognition panel; here
                           we surface the latest step's label so the
                           medic can see what the agent is doing right
                           now without losing screen real estate. -->
                      <ItemsControl ItemsSource="{Binding Steps}"
                                    IsVisible="{Binding IsExpanded}">
                        <ItemsControl.ItemTemplate>
                          <DataTemplate>
                            <TextBlock Text="{Binding Label}"
                                       FontSize="10"
                                       Margin="0,1"
                                       TextWrapping="Wrap"
                                       Foreground="{StaticResource TextSecondaryBrush}"/>
                          </DataTemplate>
                        </ItemsControl.ItemTemplate>
                      </ItemsControl>
                    </StackPanel>
                  </Border>
                </DataTemplate>
              </ItemsControl.ItemTemplate>
            </ItemsControl>

            <!-- ── Recently learned (Summarized stream) ──────────── -->
            <TextBlock Text="RECENTLY LEARNED"
                       FontSize="10" FontWeight="Bold"
                       LetterSpacing="0.8"
                       Foreground="{StaticResource TextTertiaryBrush}"
                       Margin="0,8,0,0"
                       IsVisible="{Binding !Cognition.SummarizedEmpty}"/>
            <ItemsControl ItemsSource="{Binding Cognition.Summarized}"
                          IsVisible="{Binding !Cognition.SummarizedEmpty}">
              <ItemsControl.ItemTemplate>
                <DataTemplate>
                  <Border Padding="6,4" Margin="0,2"
                          CornerRadius="4"
                          Background="{StaticResource SurfaceMutedBrush}">
                    <StackPanel Spacing="2">
                      <TextBlock Text="{Binding Title}"
                                 FontSize="10"
                                 FontWeight="SemiBold"
                                 Foreground="{StaticResource TextPrimaryBrush}"
                                 TextTrimming="CharacterEllipsis"/>
                      <TextBlock Text="{Binding Summary}"
                                 FontSize="10"
                                 TextWrapping="Wrap"
                                 MaxLines="2"
                                 Foreground="{StaticResource TextSecondaryBrush}"/>
                    </StackPanel>
                  </Border>
                </DataTemplate>
              </ItemsControl.ItemTemplate>
            </ItemsControl>
          </StackPanel>
        </Grid>

        <!-- TASKS: background tasks list -->
        <StackPanel IsVisible="{Binding IsTasksTab}" Spacing="6">
          <TextBlock FontSize="10" FontWeight="SemiBold"
                     Foreground="{StaticResource TextTertiaryBrush}">
            <Run Text="{Binding Tasks.ActiveCount}"/><Run Text=" active · "/><Run Text="{Binding Tasks.FinishedCount}"/><Run Text=" finished"/>
          </TextBlock>
          <TextBlock IsVisible="{Binding !Tasks.HasAnyTask}"
                     Text="No background tasks. Ask the agent to run a long workflow with 'email me when done'."
                     FontSize="10" TextWrapping="Wrap"
                     Foreground="{StaticResource TextTertiaryBrush}"/>
          <ItemsControl ItemsSource="{Binding Tasks.Tasks}">
            <ItemsControl.ItemTemplate>
              <DataTemplate>
                <Border Padding="8,6" Margin="0,2,0,0"
                        CornerRadius="6"
                        Background="{StaticResource SurfaceMutedBrush}">
                  <Grid ColumnDefinitions="Auto,*,Auto"
                        RowDefinitions="Auto,Auto,Auto">
                    <TextBlock Grid.Column="0" Grid.Row="0" Grid.RowSpan="2"
                               Text="{Binding StatusIcon}"
                               FontSize="16"
                               VerticalAlignment="Center"
                               Margin="0,0,8,0"/>
                    <TextBlock Grid.Column="1" Grid.Row="0"
                               Text="{Binding Description}"
                               FontSize="11" FontWeight="SemiBold"
                               TextTrimming="CharacterEllipsis"
                               Foreground="{StaticResource TextPrimaryBrush}"/>
                    <StackPanel Grid.Column="1" Grid.Row="1"
                                Orientation="Horizontal" Spacing="6">
                      <TextBlock Text="{Binding StatusLabel}"
                                 FontSize="10"
                                 Foreground="{StaticResource AccentBrush}"/>
                      <TextBlock Text="·" FontSize="10"
                                 Foreground="{StaticResource TextTertiaryBrush}"/>
                      <TextBlock Text="{Binding ElapsedDisplay}"
                                 FontSize="10"
                                 Foreground="{StaticResource TextTertiaryBrush}"/>
                      <TextBlock Text="{Binding EtaDisplay}"
                                 FontSize="10"
                                 IsVisible="{Binding EtaDisplay,
                                            Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                                 Foreground="{StaticResource TextTertiaryBrush}"/>
                    </StackPanel>
                    <TextBlock Grid.Column="1" Grid.Row="2"
                               Grid.ColumnSpan="2"
                               Text="{Binding Error}"
                               IsVisible="{Binding Error,
                                          Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                               FontSize="10"
                               Foreground="{StaticResource ErrorBrush}"
                               TextWrapping="Wrap" Margin="0,2,0,0"/>
                    <Button Grid.Column="2" Grid.Row="0" Grid.RowSpan="2"
                            Content="✕" FontSize="11" Padding="4,0"
                            Background="Transparent" BorderThickness="0"
                            Foreground="{StaticResource TextSecondaryBrush}"
                            Command="{Binding $parent[ItemsControl].DataContext.DismissCardCommand}"
                            CommandParameter="{Binding}"
                            VerticalAlignment="Center"/>
                  </Grid>
                </Border>
              </DataTemplate>
            </ItemsControl.ItemTemplate>
          </ItemsControl>
        </StackPanel>

        <!-- HISTORY: episodes / past turns -->
        <StackPanel IsVisible="{Binding IsHistoryTab}" Spacing="6">
          <TextBlock Text="Past turns"
                     FontSize="10" FontWeight="SemiBold"
                     Foreground="{StaticResource TextTertiaryBrush}"/>
          <TextBlock Text="Earlier conversation turns + tool calls. Scroll to search across sessions."
                     FontSize="10" TextWrapping="Wrap"
                     Foreground="{StaticResource TextSecondaryBrush}"/>
          <!-- Future: rich episode rendering. For now a placeholder
               so the tab compiles and shows up. -->
        </StackPanel>
        </Grid>
      </ScrollViewer>
    </Grid>
  </Border>
</UserControl>
