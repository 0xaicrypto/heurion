<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:RuneDesktop.UI.ViewModels"
             xmlns:local="clr-namespace:RuneDesktop.UI.Views"
             x:Class="RuneDesktop.UI.Views.ChatView"
             Background="{StaticResource SurfaceBaseBrush}">

  <Panel>
    <!-- ══════════════════════════════════════════════════════════════
         Three-pane layout: SIDEBAR (320px) | CHAT (flex) | COGNITION (380px)
         The slide-over detail panel is layered ON TOP of all three
         when DetailPanel.IsOpen is true.

         The Cognition column is always visible — that's the whole
         point. It runs four live streams (Thinking / Summarized /
         On-chain / Working directory) refreshed every 2s so the user
         can see the agent thinking, learning, and committing to chain
         in real time. No clicks required.
         ══════════════════════════════════════════════════════════════ -->
    <!-- Two resizable columns:
           Col 0 = chat surface (flex, MinWidth 380)
           Col 1 = vertical splitter (4 px gutter, drag to resize cognition)
           Col 2 = cognition column (default 380, drag-resizable 320–800)

         The legacy LEFT activity sidebar (ERC-8004 pill, state counters,
         deprecated ACTIVITY stream) was removed in this rev — its data
         was already duplicated by the top bar (identity pill) and the
         right-rail Brain Dashboard (state counters, namespace cards).
         Keeping it was visual debt that pushed the chat into a tight
         ~380 px center column on most laptops.

         The cognition column track is given an explicit pixel Width
         (not Auto) because GridSplitter.ResizeBehavior=PreviousAndNext
         only works when BOTH neighbouring tracks have non-Auto widths.
         If we leave it Auto the splitter ends up locked because the
         column track keeps re-sizing itself to the inner Border's
         desired width on every layout pass. -->
    <Grid x:Name="LayoutGrid">
      <Grid.ColumnDefinitions>
        <!-- chat: fluid, takes whatever's left after cognition. -->
        <ColumnDefinition Width="*"/>
        <!-- splitter handle column. Auto-sized — when the splitter
             Border inside is IsVisible=false (cognition hidden),
             its desired width is 0 and this column collapses,
             letting chat reclaim those 6 px. When visible the
             Border's Width=6 expands the column to 6.
             We bypass Avalonia 11.3's GridSplitter and drive resize
             from code-behind because GridSplitter writes past
             MaxWidth (drag could balloon cognition to ~80 % of
             screen, squashing chat to a 200-px strip). -->
        <ColumnDefinition Width="Auto"/>
        <!-- cognition: default 400 px; resized by dragging col 1.
             Code-behind clamps the column Width to [320, 800] so
             chat keeps at least ~520 px on a typical 1280-px window
             and cognition keeps enough room for its 320-px chart.
             Not x:Named — Avalonia's ColumnDefinition doesn't inherit
             from Control so XAML's `x:Name` rejects it (AVLN2000).
             The splitter handler in code-behind reaches this track
             via LayoutGrid.ColumnDefinitions[2]. -->
        <ColumnDefinition Width="400"/>
      </Grid.ColumnDefinitions>

      <!-- ═════ LEFT (col 0): CHAT AREA ═════════════════════════════
           Drag-and-drop is enabled on this whole column so users can
           drop files anywhere in the chat surface (matching Claude /
           Cowork). Code-behind wires DragOver / Drop into
           ChatViewModel.HandleDroppedFilesAsync. The IsDraggingOver
           overlay shows a tinted "Drop to attach" hint while the
           cursor carries files over the area.

           Row 0 — chat-local toolbar (44 px). Hosts the inspector
           toggle on the right; mirrors macOS app pattern where view-
           specific controls live in a tight strip on the canvas
           itself, not the window-level toolbar.
           Row 1 — messages scrollviewer (*).
           Row 2 — typing indicator (auto).
           Row 3 — input bar (auto). -->
      <Grid Grid.Column="0" RowDefinitions="36,*,Auto,Auto"
            x:Name="ChatColumnGrid"
            DragDrop.AllowDrop="True">

        <!-- Chat-local toolbar. Translucent, no border on the bottom
             until the user scrolls (would be nice; punted for now).
             Just an inspector toggle on the right — keeps it as a
             pure "open the dashboard" affordance. -->
        <Border Grid.Row="0"
                Background="{StaticResource SurfaceBaseBrush}"
                BorderThickness="0,0,0,1"
                BorderBrush="{StaticResource DividerBrush}"
                Padding="14,0">
          <DockPanel>
            <Button DockPanel.Dock="Right"
                    Classes="toolbar"
                    Command="{Binding Cognition.ToggleHiddenCommand}"
                    ToolTip.Tip="Show inspector (Ctrl+Shift+\)"
                    FontSize="14"
                    VerticalAlignment="Center">
              <TextBlock Text="◧"
                         Foreground="{StaticResource TextSecondaryBrush}"/>
            </Button>
            <Panel/>
          </DockPanel>
        </Border>

        <!-- Messages — horizontal scroll DISABLED at this level. With
             Auto, the ScrollViewer measured its content with infinite
             available width, which let the inner StackPanel + bubble
             grid demand whatever width the natural markdown content
             wanted. That demand cascaded back through the Grid layout
             pass and bypassed the chat ColumnDefinition's MinWidth,
             leaving chat as a 200-px strip on screen with a horizontal
             scrollbar at the bottom. Disabling here forces the chat
             column to size by the OUTER constraints and any wide
             children (code blocks, tables) get their OWN local
             ScrollViewer in the markdown renderer instead. -->
        <ScrollViewer Grid.Row="1"
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled"
                      x:Name="MessageScrollViewer">
          <!-- Centred reading column. macOS chat surfaces (Messages,
               Claude, ChatGPT desktop) cap the conversation at ~760 px
               and centre it inside the available width — that's how
               collapsing the sidebar still "feels" responsive: the
               surrounding margin breathes, the readable column stays
               at a comfortable line length.

               Implementation: Border (MaxWidth=780, HorizontalAlignment=
               Center) instead of StackPanel-with-HA-Center because
               Avalonia's StackPanel collapses to content desired width
               which then floats LEFT inside the parent, producing the
               "chat jammed against one edge" bug. Border with a fixed
               MaxWidth + Center DOES reliably centre. -->
          <Border MaxWidth="780"
                  HorizontalAlignment="Center">
            <StackPanel>
              <!-- Empty state. Neutral surface tile, not brand colour —
                   matches the rest of the HIG redesign. -->
              <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center"
                          Spacing="12" Margin="32,96"
                          IsVisible="{Binding HasNoMessages}">
                <!-- #185 — branded logo tile (matches login page).
                     72×72 deep-navy + BNB-yellow N. -->
                <Border Width="72" Height="72" CornerRadius="16"
                        Background="#0F1729"
                        HorizontalAlignment="Center">
                  <TextBlock Text="N" FontSize="40" FontWeight="Bold"
                             Foreground="#F0B90B"
                             HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Border>
                <TextBlock Text="Say hi to your Digital Twin"
                           FontSize="15" FontWeight="SemiBold"
                           Foreground="{StaticResource TextPrimaryBrush}"
                           HorizontalAlignment="Center"/>
                <TextBlock Text="Conversation, memory, and on-chain provenance show up in the sidebar as you chat."
                           FontSize="12"
                           Foreground="{StaticResource TextSecondaryBrush}"
                           HorizontalAlignment="Center" TextAlignment="Center"
                           MaxWidth="360" TextWrapping="Wrap"/>
              </StackPanel>

              <ItemsControl ItemsSource="{Binding Messages}"
                            Margin="24,16,24,28">
              <ItemsControl.ItemTemplate>
                <DataTemplate>
                  <StackPanel Margin="0,8" HorizontalAlignment="{Binding HAlignment}">
                    <!-- ───────────────────────────────────────────────
                         #93: the inline workflow_run card was deleted
                         along with the run_workflow tool (#91) and the
                         server-side runtime (#92). Old historical
                         workflow_run events fall back to the text
                         bubble path via IsTextBubble — their content
                         ("Started workflow: X") renders as a regular
                         assistant message. delegate() calls are tools
                         rendered by the cognition / tool-call surface,
                         not by this template. -->
                    <StackPanel Orientation="Horizontal" Spacing="10"
                                HorizontalAlignment="{Binding HAlignment}"
                                IsVisible="{Binding IsTextBubble}">
                      <!-- Agent avatar — monochrome surface tile, not
                           accent. Identity reads from position + the
                           letter, not from the disc colour. -->
                      <Border Width="28" Height="28" CornerRadius="14"
                              Background="{StaticResource SurfaceRaisedBrush}"
                              BorderBrush="{StaticResource DividerBrush}"
                              BorderThickness="1"
                              IsVisible="{Binding !IsUser}"
                              VerticalAlignment="Top">
                        <TextBlock Text="N" FontSize="12" FontWeight="SemiBold"
                                   Foreground="{StaticResource TextPrimaryBrush}"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"/>
                      </Border>
                      <Border CornerRadius="14" Padding="14,10" MaxWidth="640"
                              Background="{Binding BubbleColor}">
                        <StackPanel Spacing="6">
                          <!-- Phase Q: structured attachment chips
                               above the text body. Bound to the
                               message's Attachments collection — set
                               from history reload OR optimistic send.
                               When empty (most messages, all assistant
                               messages), the strip collapses. -->
                          <ItemsControl ItemsSource="{Binding Attachments}"
                                        IsVisible="{Binding HasAttachments}">
                            <ItemsControl.ItemsPanel>
                              <ItemsPanelTemplate>
                                <WrapPanel Orientation="Horizontal"/>
                              </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                              <DataTemplate>
                                <!-- #125: bubble chip auto-switches to
                                     image-preview mode when we have a
                                     thumbnail (current-session sends).
                                     History reload uses the glyph
                                     branch since LocalSourcePath is
                                     null until v2 ships a server-side
                                     thumbnail endpoint. -->
                                <Border Margin="0,0,6,4"
                                        Padding="6,4"
                                        CornerRadius="8"
                                        Background="#33000000"
                                        BorderBrush="#55FFFFFF"
                                        BorderThickness="1">
                                  <StackPanel Orientation="Horizontal" Spacing="8">
                                    <!-- Image-preview branch -->
                                    <Image Source="{Binding Thumbnail}"
                                           IsVisible="{Binding HasThumbnail}"
                                           MaxWidth="320" MaxHeight="240"
                                           Stretch="Uniform"/>
                                    <!-- Glyph branch (file or no preview) -->
                                    <TextBlock Text="{Binding Glyph}"
                                               IsVisible="{Binding !HasThumbnail}"
                                               FontSize="14"
                                               VerticalAlignment="Center"/>
                                    <StackPanel Orientation="Vertical" Spacing="2"
                                                VerticalAlignment="Center">
                                      <TextBlock Text="{Binding Name}"
                                                 FontSize="12" FontWeight="SemiBold"
                                                 Foreground="{Binding $parent[ItemsControl].((vm:ChatMessageViewModel)DataContext).TextColor}"
                                                 TextTrimming="CharacterEllipsis"
                                                 MaxWidth="280"
                                                 VerticalAlignment="Center"/>
                                      <TextBlock Text="{Binding SizeText}"
                                                 FontSize="10"
                                                 Foreground="{Binding $parent[ItemsControl].((vm:ChatMessageViewModel)DataContext).TimeColor}"
                                                 VerticalAlignment="Center"
                                                 IsVisible="{Binding SizeText,
                                                             Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>
                                    </StackPanel>
                                  </StackPanel>
                                </Border>
                              </DataTemplate>
                            </ItemsControl.ItemTemplate>
                          </ItemsControl>
                          <!-- Markdown body: in-house renderer that
                               handles headers / bold / italic / inline
                               code / fenced code blocks (with copy
                               button) / lists / blockquotes / links.
                               User bubbles are short and rarely use
                               markdown so the cost is negligible
                               there too; we render uniformly so the
                               agent can format e.g. `code` mentions
                               in user messages too. -->
                          <local:MarkdownView Markdown="{Binding Content}"
                                              BodyForeground="{Binding TextColor}"
                                              IsVisible="{Binding Content,
                                                          Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>
                          <!-- Footer row: Copy button + timestamp.
                               MarkdownView renders each paragraph /
                               list-item as a separate SelectableText-
                               Block, so cross-block selection isn't
                               possible (Avalonia limitation). The
                               Copy button below sidesteps that — one
                               click puts the entire raw message on
                               the clipboard. Tag carries the VM so
                               the code-behind handler can read
                               Content without binding gymnastics. -->
                          <StackPanel Orientation="Horizontal" Spacing="8"
                                      HorizontalAlignment="Right">
                            <!-- #130: feedback row. Visible only on
                                 assistant messages, only in the
                                 "none" state (replaced with a single
                                 badge after the medic clicks one). -->
                            <Button Content="✓"
                                    FontSize="11"
                                    Padding="6,2"
                                    Background="Transparent"
                                    BorderThickness="0"
                                    CornerRadius="4"
                                    Foreground="{Binding TimeColor}"
                                    Cursor="Hand"
                                    Tag="{Binding}"
                                    Click="OnAcceptFeedbackClicked"
                                    IsVisible="{Binding ShowFeedbackButtons}"
                                    ToolTip.Tip="Mark as accurate — feeds positive sample to skill evolution">
                              <Button.Styles>
                                <Style Selector="Button:pointerover /template/ ContentPresenter">
                                  <Setter Property="Background" Value="#1AFFFFFF"/>
                                </Style>
                              </Button.Styles>
                            </Button>
                            <Button Content="✗"
                                    FontSize="11"
                                    Padding="6,2"
                                    Background="Transparent"
                                    BorderThickness="0"
                                    CornerRadius="4"
                                    Foreground="{Binding TimeColor}"
                                    Cursor="Hand"
                                    Tag="{Binding}"
                                    Click="OnCorrectFeedbackClicked"
                                    IsVisible="{Binding ShowFeedbackButtons}"
                                    ToolTip.Tip="Submit a correction — feeds into skill evolution next cycle">
                              <Button.Styles>
                                <Style Selector="Button:pointerover /template/ ContentPresenter">
                                  <Setter Property="Background" Value="#1AFFFFFF"/>
                                </Style>
                              </Button.Styles>
                            </Button>
                            <TextBlock Text="✓ Accepted"
                                       FontSize="10"
                                       Foreground="{Binding TimeColor}"
                                       VerticalAlignment="Center"
                                       IsVisible="{Binding ShowAcceptedBadge}"/>
                            <TextBlock Text="✗ Corrected"
                                       FontSize="10"
                                       Foreground="{Binding TimeColor}"
                                       VerticalAlignment="Center"
                                       IsVisible="{Binding ShowCorrectedBadge}"/>
                            <Button Content="Copy"
                                    FontSize="10"
                                    Padding="6,2"
                                    Background="Transparent"
                                    BorderThickness="0"
                                    CornerRadius="4"
                                    Foreground="{Binding TimeColor}"
                                    Cursor="Hand"
                                    Tag="{Binding}"
                                    Click="OnCopyMessageClicked"
                                    ToolTip.Tip="Copy this message">
                              <Button.Styles>
                                <Style Selector="Button:pointerover /template/ ContentPresenter">
                                  <Setter Property="Background" Value="#1AFFFFFF"/>
                                </Style>
                              </Button.Styles>
                            </Button>
                            <TextBlock Text="{Binding FormattedTime}" FontSize="10"
                                       Foreground="{Binding TimeColor}"
                                       VerticalAlignment="Center"/>
                          </StackPanel>
                        </StackPanel>
                      </Border>
                      <!-- No user avatar — macOS Messages convention.
                           A right-aligned System Blue bubble is enough
                           to communicate "this is me"; an avatar circle
                           just adds noise. -->
                      <Panel IsVisible="False"/>
                    </StackPanel>
                  </StackPanel>
                </DataTemplate>
              </ItemsControl.ItemTemplate>
            </ItemsControl>
            </StackPanel>
          </Border>        <!-- close centred MaxWidth=780 Border -->
        </ScrollViewer>

        <!-- Drag-over overlay: shows a tinted hint while files are
             being dragged into the chat column. Visibility bound to
             ChatViewModel.IsDraggingOverChat. macOS standard: System
             Blue tinted overlay (~30 % opacity surface base + 60 %
             blue border) so the user reads it as "drop target", not
             a brand swatch. Lives in Row 1 (the messages area) so it
             doesn't extend over the toolbar. -->
        <Border Grid.Row="1"
                Background="#CC1E1E1E"
                BorderThickness="2"
                BorderBrush="{StaticResource SystemBlueBrush}"
                CornerRadius="10"
                Margin="16"
                IsVisible="{Binding IsDraggingOverChat}"
                IsHitTestVisible="False">
          <StackPanel HorizontalAlignment="Center"
                      VerticalAlignment="Center"
                      Spacing="8">
            <TextBlock Text="📎"
                       FontSize="48"
                       HorizontalAlignment="Center"/>
            <TextBlock Text="Drop to attach"
                       FontSize="18" FontWeight="SemiBold"
                       Foreground="{StaticResource TextPrimaryBrush}"
                       HorizontalAlignment="Center"/>
            <TextBlock Text="Files will be uploaded and attached to your next message"
                       FontSize="12"
                       Foreground="{StaticResource TextSecondaryBrush}"
                       HorizontalAlignment="Center"/>
          </StackPanel>
        </Border>

        <!-- Typing indicator. Pulsing dot avatars are a calmer cue
             than a coloured initial — matches Apple Mail's "...typing"
             style. Row 2 in the 4-row chat layout (toolbar / messages
             / typing / input). -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" Spacing="8"
                    Margin="32,4,32,8" IsVisible="{Binding IsTyping}">
          <Border Width="20" Height="20" CornerRadius="10"
                  Background="{StaticResource SurfaceRaisedBrush}"
                  BorderBrush="{StaticResource DividerBrush}"
                  BorderThickness="1">
            <TextBlock Text="N" FontSize="10" FontWeight="SemiBold"
                       Foreground="{StaticResource TextPrimaryBrush}"
                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
          </Border>
          <TextBlock Text="Agent is thinking…" FontSize="12"
                     Foreground="{StaticResource TextSecondaryBrush}"
                     VerticalAlignment="Center"/>
        </StackPanel>

        <!-- Input bar (Row 3).
             Outer Border spans the full chat column (gives us a clean
             hairline + matching background). The INNER StackPanel is
             centred at MaxWidth=780 so it aligns with the conversation
             column above; on wide windows you get symmetric margins
             on both sides instead of an attach button hugging the
             far left edge and Send hugging the far right. -->
        <Border Grid.Row="3" BorderThickness="0,1,0,0"
                BorderBrush="{StaticResource DividerBrush}"
                Padding="20,14"
                Background="{StaticResource SurfaceBaseBrush}">
          <!-- HorizontalAlignment intentionally left at Stretch (the
               default). MaxWidth + Stretch gives us "fill up to 780 px,
               then cap and self-centre via parent". HorizontalAlignment
               Center would size to content instead, leaving the input
               looking shrunken. -->
          <StackPanel Spacing="8"
                      MaxWidth="780">
            <!-- #172 background tasks panel moved to MainWindow as a
                 floating bottom-left overlay (user feedback: 'don't
                 put it in the chat main window'). See MainWindow.axaml
                 search for "background tasks overlay". -->

            <!-- #159: inline DICOM preview. Visible after the medic
                 clicks a chip's "Preview" button. Image is fetched
                 from /api/v1/dicom/.../render — eager cache (#158)
                 makes scrolls ~5 ms after the first slice. Mouse
                 wheel on the image steps slices; slider beneath
                 jumps absolute position. "Pop out" launches the
                 full standalone HTML viewer in Brave/Vivaldi/Safari
                 for ROI + chat-sidebar interaction. -->
            <Border IsVisible="{Binding IsPreviewVisible}"
                    CornerRadius="10"
                    BorderBrush="{StaticResource DividerBrush}"
                    BorderThickness="1"
                    Background="{StaticResource SurfaceCardBrush}"
                    Padding="12">
              <Grid RowDefinitions="Auto,Auto,Auto,Auto">
                <!-- Title row: study description + close button -->
                <DockPanel Grid.Row="0" Margin="0,0,0,8">
                  <Button DockPanel.Dock="Right"
                          Content="✕"
                          Background="Transparent"
                          BorderThickness="0"
                          Padding="6,2"
                          FontSize="14"
                          Foreground="{StaticResource TextSecondaryBrush}"
                          Command="{Binding ClosePreviewCommand}"
                          ToolTip.Tip="Close preview"/>
                  <Button DockPanel.Dock="Right"
                          Content="↗ Pop out (full viewer)"
                          Padding="10,4" FontSize="11"
                          Margin="0,0,6,0"
                          Classes="ghost"
                          Foreground="{StaticResource AccentBrush}"
                          Command="{Binding PopOutDicomViewerCommand}"
                          ToolTip.Tip="Open this study in the full standalone DICOM viewer (Brave / Safari)"/>
                  <TextBlock Text="{Binding PreviewLabel}"
                             FontSize="12" FontWeight="SemiBold"
                             VerticalAlignment="Center"
                             TextTrimming="CharacterEllipsis"
                             Foreground="{StaticResource TextPrimaryBrush}"/>
                </DockPanel>
                <!-- Image — scroll-wheel handler wired in code-behind. -->
                <Border Grid.Row="1"
                        Background="#000"
                        CornerRadius="6"
                        x:Name="PreviewImageHolder">
                  <Image Source="{Binding PreviewBitmap}"
                         Stretch="Uniform"
                         MaxHeight="380"
                         HorizontalAlignment="Center"
                         VerticalAlignment="Center"/>
                </Border>
                <!-- Slice slider -->
                <Grid Grid.Row="2" ColumnDefinitions="Auto,*,Auto"
                      Margin="0,8,0,4">
                  <TextBlock Grid.Column="0"
                             Text="Slice" FontSize="11" Margin="0,0,8,0"
                             VerticalAlignment="Center"
                             Foreground="{StaticResource TextSecondaryBrush}"/>
                  <Slider Grid.Column="1"
                          Minimum="0"
                          Maximum="{Binding PreviewSliceCount}"
                          Value="{Binding PreviewSliceIdx, Mode=TwoWay}"
                          TickFrequency="1"
                          IsSnapToTickEnabled="True"/>
                  <TextBlock Grid.Column="2"
                             FontSize="11" Margin="8,0,0,0"
                             VerticalAlignment="Center"
                             Foreground="{StaticResource TextSecondaryBrush}">
                    <Run Text="{Binding PreviewSliceIdx}"/><Run Text=" / "/><Run Text="{Binding PreviewSliceCount}"/>
                  </TextBlock>
                </Grid>
                <!-- Window preset selector -->
                <DockPanel Grid.Row="3">
                  <TextBlock DockPanel.Dock="Left"
                             Text="W/L" FontSize="11" Margin="0,0,8,0"
                             VerticalAlignment="Center"
                             Foreground="{StaticResource TextSecondaryBrush}"/>
                  <ComboBox ItemsSource="{Binding PreviewWindowPresets}"
                            SelectedItem="{Binding PreviewWindowPreset, Mode=TwoWay}"
                            FontSize="11" MinWidth="160"
                            HorizontalAlignment="Left"/>
                </DockPanel>
              </Grid>
            </Border>
            <ItemsControl ItemsSource="{Binding PendingAttachments}"
                          IsVisible="{Binding HasPendingAttachments}">
              <ItemsControl.ItemsPanel>
                <ItemsPanelTemplate>
                  <WrapPanel Orientation="Horizontal"/>
                </ItemsPanelTemplate>
              </ItemsControl.ItemsPanel>
              <ItemsControl.ItemTemplate>
                <DataTemplate>
                  <!-- #125: chip auto-switches between "image chip"
                       (thumbnail + name) and "file chip" (📎 + name +
                       size). Image branch uses CornerRadius=8 because
                       a 999-radius pill wraps oddly around an 80-px
                       square; file branch keeps the pill aesthetic. -->
                  <Border CornerRadius="8"
                          Padding="6,4"
                          Margin="0,0,8,4"
                          Background="{StaticResource SurfaceCardBrush}"
                          BorderBrush="{StaticResource DividerBrush}"
                          BorderThickness="1">
                    <StackPanel Orientation="Horizontal" Spacing="8"
                                VerticalAlignment="Center">
                      <!-- Image thumbnail branch (visible only for image MIME) -->
                      <Image Source="{Binding Thumbnail}"
                             IsVisible="{Binding IsImage}"
                             Width="80" Height="80"
                             Stretch="UniformToFill"/>
                      <!-- File icon branch (visible for everything else) -->
                      <TextBlock Text="📎" FontSize="11"
                                 IsVisible="{Binding !IsImage}"
                                 VerticalAlignment="Center"/>
                      <StackPanel Orientation="Vertical" Spacing="2"
                                  VerticalAlignment="Center">
                        <TextBlock Text="{Binding Name}" FontSize="12"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource TextPrimaryBrush}"
                                   VerticalAlignment="Center"
                                   TextTrimming="CharacterEllipsis" MaxWidth="220"/>
                        <TextBlock Text="{Binding DisplaySize}" FontSize="11"
                                   Foreground="{StaticResource TextSecondaryBrush}"
                                   VerticalAlignment="Center"/>
                        <!-- #152: DICOM prerender verdict shown as a
                             second line on the chip so the medic
                             sees ingest succeeded BEFORE hitting
                             Send. Visibility driven by non-empty
                             DicomBadge so non-medical uploads aren't
                             cluttered with a generic "no badge" row.
                             #158: while DicomStatus == "prerendering"
                             the badge text shows the current stage
                             label, and a ProgressBar below tracks
                             percent completion in real time. -->
                        <TextBlock Text="{Binding DicomBadge}" FontSize="10"
                                   IsVisible="{Binding DicomBadge,
                                              Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                                   Foreground="{StaticResource AccentBrush}"
                                   VerticalAlignment="Center"
                                   ToolTip.Tip="Server prerender status — green = ready for agent, ⚠ = open in viewer"/>
                        <ProgressBar IsVisible="{Binding IsProgressVisible}"
                                     Value="{Binding ProgressPercent}"
                                     Minimum="0" Maximum="100"
                                     Height="3" Width="220"
                                     Margin="0,2,0,0"
                                     ShowProgressText="False"
                                     Foreground="{StaticResource AccentBrush}"
                                     Background="{StaticResource DividerBrush}"/>
                      </StackPanel>
                      <!-- #157: large Preview button — primary CTA on
                           the chip when a DICOM study was
                           successfully ingested. Auto-pop was removed;
                           the medic explicitly clicks to launch the
                           3D viewer in their preferred browser
                           (Brave/Safari fallback per #156). Sized
                           bigger than the ✕ remove button so it's
                           the obvious next action, with accent fill
                           so it reads as a primary call-to-action
                           rather than secondary chrome. -->
                      <Button Content="🩻  Preview"
                              FontSize="13" FontWeight="SemiBold"
                              Padding="14,8"
                              IsVisible="{Binding DicomRendered}"
                              Classes="accent"
                              Command="{Binding $parent[ItemsControl].DataContext.OpenDicomViewerCommand}"
                              CommandParameter="{Binding}"
                              ToolTip.Tip="Open this study in the 3D DICOM viewer"
                              VerticalAlignment="Center"/>
                      <Button Content="✕" FontSize="11" Padding="4,0"
                              Background="Transparent" BorderThickness="0"
                              Foreground="{StaticResource TextSecondaryBrush}"
                              Command="{Binding $parent[ItemsControl].DataContext.RemoveAttachmentCommand}"
                              CommandParameter="{Binding}"
                              ToolTip.Tip="Remove"
                              VerticalAlignment="Center"/>
                    </StackPanel>
                  </Border>
                </DataTemplate>
              </ItemsControl.ItemTemplate>
            </ItemsControl>

            <TextBlock Text="{Binding AttachmentError}"
                       IsVisible="{Binding AttachmentError,
                                  Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                       Foreground="{StaticResource ErrorBrush}" FontSize="11"
                       TextWrapping="Wrap"/>

            <!-- Sync-status strip above the chat input.
                 Hidden when healthy — a permanent "healthy · 0
                 queued" pill is noise. Only surfaces when something
                 needs attention (daemon down / degraded / busy). Bound
                 to IsDegraded so the strip self-clears the moment the
                 system recovers, without needing a converter. -->
            <Border IsVisible="{Binding Cognition.Brain.Health.IsDegraded}"
                    Padding="8,4" CornerRadius="4"
                    Background="{StaticResource SurfaceMutedBrush}"
                    Margin="0,0,0,4">
              <StackPanel Orientation="Horizontal" Spacing="6">
                <Ellipse Width="6" Height="6"
                         VerticalAlignment="Center"
                         Fill="{Binding Cognition.Brain.Health.GreenfieldReady,
                                Converter={x:Static local:DriftFillConverter.Instance},
                                ConverterParameter=invert}"/>
                <TextBlock Text="{Binding Cognition.Brain.Health.OverallStatus}"
                           FontSize="10" FontWeight="SemiBold"
                           Foreground="{StaticResource TextSecondaryBrush}"
                           VerticalAlignment="Center"/>
                <TextBlock Text="·"
                           FontSize="10"
                           Foreground="{StaticResource TextTertiaryBrush}"
                           VerticalAlignment="Center"/>
                <TextBlock Text="{Binding Cognition.Brain.Health.QueueLabel}"
                           FontSize="10"
                           Foreground="{StaticResource TextTertiaryBrush}"
                           VerticalAlignment="Center"/>
              </StackPanel>
            </Border>

            <DockPanel>
              <!-- Attach button — ghost. Tighter padding than before so
                   the input row reads as a single composer, not three
                   competing widgets. -->
              <Button DockPanel.Dock="Left" Content="📎"
                      Command="{Binding AttachFilesCommand}"
                      Classes="ghost"
                      FontSize="15" Padding="6,4"
                      Margin="0,0,6,0" VerticalAlignment="Bottom"
                      ToolTip.Tip="Attach files"/>
              <!-- Send — rectangular filled accent (HIG primary CTA);
                   pill was visually heavier than the surrounding chat
                   chrome. -->
              <Button DockPanel.Dock="Right" Content="Send"
                      Command="{Binding SendMessageCommand}"
                      Classes="accent"
                      FontSize="13"
                      Margin="6,0,0,0" VerticalAlignment="Bottom"/>
              <TextBox Text="{Binding InputText, Mode=TwoWay}"
                       Watermark="Type a message…  (Shift+Enter for newline)"
                       Classes="chat" FontSize="14"
                       AcceptsReturn="False" TextWrapping="Wrap"
                       MinHeight="40" MaxHeight="120"
                       x:Name="InputBox"/>
              <!-- KeyDown handler wired in code-behind via
                   WireUpInputBoxKeyHandler() so we can use
                   RoutingStrategies.Tunnel. The XAML attribute syntax
                   gives us a Bubble handler, which fires AFTER
                   TextBox's internal Cmd-V/Cmd-C key bindings have
                   already eaten the event. Tunnel handler catches it
                   in the routing-down phase, before TextBox sees it. -->
            </DockPanel>
          </StackPanel>
        </Border>
      </Grid>

      <!-- GridSplitter removed — see ColumnDefinitions comment. The
           cognition column is now a fixed 400 px; resize will come
           back as a discrete toggle later, not a freeform drag. -->

      <!-- ═════ RIGHT (col 1): ALWAYS-ON COGNITION COLUMN ═══════════
           Live mirror of the agent's "head + hand": what it's
           thinking right now, what it has learned (compactions /
           extractions / skills / persona evolutions), what it has
           anchored on BSC, and the live Greenfield bucket tree.
           Refreshes every 2s — no clicks needed.

           Width is set on the COLUMN TRACK (CognitionColumn,
           clamped 320–800 by code-behind drag handler). No Width on
           the Border itself — that lets the track drive the visual
           width without competing.

           Visibility bound to Cognition.IsHidden — toggle from the
           top bar's Cmd+Shift+\\ button.
           ════════════════════════════════════════════════════════ -->

      <!-- Splitter handle (col 1). 6 px-wide drag gutter. Manual
           pointer handling in code-behind (OnSplitterPointer*) updates
           CognitionColumn.Width with strict clamping — bypasses
           Avalonia 11.3 GridSplitter's broken MaxWidth respect.
           Hidden when cognition panel is hidden so it doesn't dangle. -->
      <Border Grid.Column="1"
              x:Name="ChatCognitionSplitter"
              Width="6"
              Background="{StaticResource DividerBrush}"
              Cursor="SizeWestEast"
              IsHitTestVisible="True"
              IsVisible="{Binding Cognition.IsHidden,
                          Converter={x:Static BoolConverters.Not}}"/>

      <Border Grid.Column="2"
              Background="{StaticResource SurfaceMutedBrush}"
              BorderThickness="0"
              IsVisible="{Binding Cognition.IsHidden,
                          Converter={x:Static BoolConverters.Not}}">
        <Grid RowDefinitions="Auto,*">
          <!-- Header -->
          <Border Grid.Row="0" Padding="14,12,14,8"
                  BorderThickness="0,0,0,1"
                  BorderBrush="{StaticResource DividerBrush}">
            <StackPanel Spacing="4">
              <StackPanel Orientation="Horizontal" Spacing="8">
                <TextBlock Text="🧠" FontSize="16"
                           VerticalAlignment="Center"/>
                <TextBlock Text="Live Cognition"
                           FontSize="13" FontWeight="SemiBold"
                           Foreground="{StaticResource TextPrimaryBrush}"
                           VerticalAlignment="Center"/>
                <Border Width="6" Height="6" CornerRadius="3"
                        Background="#7DBC68" VerticalAlignment="Center"
                        IsVisible="{Binding Cognition.IsPolling}"/>
              </StackPanel>
              <TextBlock FontSize="10"
                         Foreground="{StaticResource TextTertiaryBrush}">
                <Run Text="A self-evolving agent — refreshing every 2s · last "/>
                <Run Text="{Binding Cognition.LastUpdated}"/>
              </TextBlock>
            </StackPanel>
          </Border>

          <!-- Body: stacked sections, vertical-scroll only. Horizontal
               scroll deliberately Disabled — the cognition column is
               a fixed 400 px and every section is sized to fit:
                 * Section 1 brain cards: WrapPanel of 66-px cards,
                   wraps to 2 rows on the 400-px column.
                 * Section 2 timeline: 320-px Canvas centered, fits.
                 * Section 3 DAG: centered, MinWidth=240 fits.
               If we leave Auto on this ScrollViewer, ANY child that
               sets HorizontalAlignment=Stretch (e.g. an earlier rev
               of Section 3 DAG) measures with infinite width, demands
               way more than 400 px, and the user sees an empty column
               with the actual content scrolled offscreen to the right.
               That's exactly the bug just reported ("需要向右滚动很
               多才能看到 section 2 和 3 的图表"). -->
          <ScrollViewer Grid.Row="1"
                        VerticalScrollBarVisibility="Auto"
                        HorizontalScrollBarVisibility="Disabled">
            <StackPanel Margin="12,10,12,12" Spacing="14">

              <!-- ═════════════════════════════════════════════════
                   SECTION 1 — BRAIN AT A GLANCE (#159 v3)
                   5 horizontal cards in a UniformGrid, matching the
                   agreed design. Each card shows namespace name +
                   per-namespace display value (Persona = version
                   "v0042"; others = count) + smart-cadence delta
                   (today / this week / active) + 3-dot chain status.
                   ═════════════════════════════════════════════════ -->
              <StackPanel Spacing="6">
                <TextBlock Text="SECTION 1 — BRAIN AT A GLANCE"
                           FontSize="10" FontWeight="Bold"
                           Foreground="{StaticResource TextTertiaryBrush}"
                           ToolTip.Tip="One card per typed namespace. Dots: ● local · ● mirrored to Greenfield · ● anchored on BSC."/>
                <!-- WrapPanel — cards reflow to a second row when the
                     cognition column is too narrow to fit all 5 in
                     one row. Each card has a fixed minimum width so
                     content stays readable regardless of column size. -->
                <ItemsControl ItemsSource="{Binding Cognition.Brain.Glance}">
                  <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                      <WrapPanel Orientation="Horizontal"/>
                    </ItemsPanelTemplate>
                  </ItemsControl.ItemsPanel>
                  <ItemsControl.ItemTemplate>
                    <DataTemplate>
                      <Border Width="66" Margin="2,0,2,4"
                              Padding="6,8" CornerRadius="6"
                              Background="{StaticResource SurfaceCardBrush}">
                        <StackPanel Spacing="2">
                          <TextBlock Text="{Binding DisplayName}"
                                     FontSize="9"
                                     Foreground="{StaticResource TextSecondaryBrush}"
                                     TextTrimming="CharacterEllipsis"/>
                          <TextBlock Text="{Binding DisplayValue}"
                                     FontSize="15" FontWeight="Bold"
                                     Foreground="{StaticResource TextPrimaryBrush}"
                                     TextTrimming="CharacterEllipsis"/>
                          <TextBlock Text="{Binding DeltaText}"
                                     FontSize="8"
                                     Foreground="{StaticResource SuccessBrush}"
                                     TextWrapping="Wrap"
                                     IsVisible="{Binding DeltaText,
                                                 Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>
                          <StackPanel Orientation="Horizontal"
                                      Spacing="2" Margin="0,2,0,0">
                            <Ellipse Width="5" Height="5"
                                     Fill="{StaticResource SuccessBrush}"
                                     IsVisible="{Binding DotLocal}"/>
                            <Ellipse Width="5" Height="5"
                                     Fill="{StaticResource SuccessBrush}"
                                     IsVisible="{Binding DotMirrored}"/>
                            <Ellipse Width="5" Height="5"
                                     Stroke="{StaticResource DividerBrush}"
                                     StrokeThickness="1"
                                     IsVisible="{Binding !DotMirrored}"/>
                            <!-- Anchored dot: green when fully synced,
                                 amber when this namespace has drifted
                                 past its last on-chain anchor (>1h
                                 since last_anchor_at AND there's been
                                 a more recent local commit). The fill
                                 binding picks the brush via
                                 DriftFillConverter. -->
                            <Ellipse Width="5" Height="5"
                                     Fill="{Binding IsDrifted,
                                            Converter={x:Static local:DriftFillConverter.Instance}}"
                                     IsVisible="{Binding DotAnchored}"
                                     ToolTip.Tip="Anchored — yellow means commits have outpaced the last on-chain anchor"/>
                            <Ellipse Width="5" Height="5"
                                     Stroke="{StaticResource DividerBrush}"
                                     StrokeThickness="1"
                                     IsVisible="{Binding !DotAnchored}"/>
                          </StackPanel>
                        </StackPanel>
                      </Border>
                    </DataTemplate>
                  </ItemsControl.ItemTemplate>
                </ItemsControl>
              </StackPanel>

              <!-- ═════════════════════════════════════════════════
                   SECTION 2 — LEARNING TIMELINE (last 7 days)
                   Multi-line cumulative chart. Polyline.Points
                   strings come from BrainPanelVM precomputed against
                   TimelineChartWidth (320) × Height (110).
                   ═════════════════════════════════════════════════ -->
              <StackPanel Spacing="6">
                <TextBlock Text="SECTION 2 — LEARNING TIMELINE (last 7 days)"
                           FontSize="10" FontWeight="Bold"
                           Foreground="{StaticResource TextTertiaryBrush}"
                           ToolTip.Tip="Cumulative items learned per namespace, day-by-day."/>
                <Border Padding="8,10" CornerRadius="8"
                        Background="{StaticResource SurfaceCardBrush}">
                  <StackPanel Spacing="6">
                    <TextBlock IsVisible="{Binding !Cognition.Brain.TimelineHasData}"
                               Text="(no learning yet — chat with the agent and lines will start tracing)"
                               FontSize="11"
                               Foreground="{StaticResource TextTertiaryBrush}"
                               TextWrapping="Wrap"
                               HorizontalAlignment="Center"
                               Margin="0,30"/>
                    <Canvas Width="320" Height="110"
                            HorizontalAlignment="Center"
                            IsVisible="{Binding Cognition.Brain.TimelineHasData}">
                      <Line StartPoint="0,110" EndPoint="320,110"
                            Stroke="{StaticResource DividerBrush}"
                            StrokeThickness="1"/>
                      <!-- All 5 polylines use the StringToPointsConverter
                           because Avalonia's binding pipeline does NOT
                           auto-invoke the Polyline.Points type converter
                           — without this converter the strings are
                           silently dropped and the chart stays blank. -->
                      <Polyline Points="{Binding Cognition.Brain.FactsLinePoints,
                                          Converter={x:Static local:StringToPointsConverter.Instance}}"
                                Stroke="#5AAEFF" StrokeThickness="2"
                                StrokeJoin="Round"/>
                      <Polyline Points="{Binding Cognition.Brain.SkillsLinePoints,
                                          Converter={x:Static local:StringToPointsConverter.Instance}}"
                                Stroke="#7DBC68" StrokeThickness="2"
                                StrokeJoin="Round"/>
                      <Polyline Points="{Binding Cognition.Brain.KnowledgeLinePoints,
                                          Converter={x:Static local:StringToPointsConverter.Instance}}"
                                Stroke="#E07A4D" StrokeThickness="2"
                                StrokeJoin="Round"/>
                      <Polyline Points="{Binding Cognition.Brain.PersonaLinePoints,
                                          Converter={x:Static local:StringToPointsConverter.Instance}}"
                                Stroke="#F0B90B" StrokeThickness="1.5"
                                StrokeDashArray="3,3"
                                StrokeJoin="Round"/>
                      <Polyline Points="{Binding Cognition.Brain.EpisodesLinePoints,
                                          Converter={x:Static local:StringToPointsConverter.Instance}}"
                                Stroke="#9CA3AF" StrokeThickness="1.5"
                                StrokeDashArray="3,3"
                                StrokeJoin="Round"/>
                    </Canvas>
                    <ItemsControl ItemsSource="{Binding Cognition.Brain.TimelineDayLabels}"
                                  IsVisible="{Binding Cognition.Brain.TimelineHasData}"
                                  Width="320" HorizontalAlignment="Center">
                      <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                          <UniformGrid Rows="1"/>
                        </ItemsPanelTemplate>
                      </ItemsControl.ItemsPanel>
                      <ItemsControl.ItemTemplate>
                        <DataTemplate>
                          <TextBlock Text="{Binding}"
                                     FontSize="9"
                                     Foreground="{StaticResource TextTertiaryBrush}"
                                     HorizontalAlignment="Center"/>
                        </DataTemplate>
                      </ItemsControl.ItemTemplate>
                    </ItemsControl>
                    <!-- Legend -->
                    <ItemsControl IsVisible="{Binding Cognition.Brain.TimelineHasData}"
                                  HorizontalAlignment="Center" Margin="0,2,0,0">
                      <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                          <WrapPanel Orientation="Horizontal"/>
                        </ItemsPanelTemplate>
                      </ItemsControl.ItemsPanel>
                      <StackPanel Orientation="Horizontal" Spacing="3" Margin="4,0">
                        <Border Width="10" Height="2" Background="#5AAEFF"
                                VerticalAlignment="Center"/>
                        <TextBlock Text="Facts" FontSize="9"
                                   Foreground="{StaticResource TextSecondaryBrush}"/>
                      </StackPanel>
                      <StackPanel Orientation="Horizontal" Spacing="3" Margin="4,0">
                        <Border Width="10" Height="2" Background="#7DBC68"
                                VerticalAlignment="Center"/>
                        <TextBlock Text="Skills" FontSize="9"
                                   Foreground="{StaticResource TextSecondaryBrush}"/>
                      </StackPanel>
                      <StackPanel Orientation="Horizontal" Spacing="3" Margin="4,0">
                        <Border Width="10" Height="2" Background="#E07A4D"
                                VerticalAlignment="Center"/>
                        <TextBlock Text="Knowledge" FontSize="9"
                                   Foreground="{StaticResource TextSecondaryBrush}"/>
                      </StackPanel>
                      <StackPanel Orientation="Horizontal" Spacing="3" Margin="4,0">
                        <Border Width="10" Height="2" Background="#F0B90B"
                                VerticalAlignment="Center"/>
                        <TextBlock Text="Persona" FontSize="9"
                                   Foreground="{StaticResource TextSecondaryBrush}"/>
                      </StackPanel>
                      <StackPanel Orientation="Horizontal" Spacing="3" Margin="4,0">
                        <Border Width="10" Height="2" Background="#9CA3AF"
                                VerticalAlignment="Center"/>
                        <TextBlock Text="Episodes" FontSize="9"
                                   Foreground="{StaticResource TextSecondaryBrush}"/>
                      </StackPanel>
                    </ItemsControl>
                  </StackPanel>
                </Border>
              </StackPanel>

              <!-- ═════════════════════════════════════════════════
                   SECTION 3 — DATA FLOW
                   Compact DAG: Chat turn → Facts +N | Skills +N
                                         → Knowledge ⏸ N/M to fire
                                         → Persona ⏸ Nd to next
                   Skills branches off Chat turn but is a leaf.
                   The +N numbers MUST match Section 1's cards because
                   they bind to the SAME DeltaThisWeek/DeltaToday
                   fields. Earlier rev titled this "(this turn)" which
                   misled users into thinking the deltas were per-turn;
                   per-stage time-window labels (today / this week)
                   inline now keep the two sections honest.
                   ═════════════════════════════════════════════════ -->
              <StackPanel Spacing="6">
                <TextBlock Text="SECTION 3 — DATA FLOW"
                           FontSize="10" FontWeight="Bold"
                           Foreground="{StaticResource TextTertiaryBrush}"
                           ToolTip.Tip="The pipeline turning chat into long-term knowledge. ⏸ means the evolver is accumulating but hasn't fired yet. Numbers are recent activity — same time windows as the Brain at a Glance cards above."/>
                <!-- Compact vertical DAG that fits a 320 px column.
                     Layout (top → bottom):
                       Chat turn (N turns)
                          │
                          ├──► Skills +N (learned strategy)
                          │       (leaf — no forward arrow)
                          ▼
                       Facts +N (preference, fact)
                          │
                          ▼
                       Knowledge ⏸ N/M to compile
                          │
                          ▼ (dashed = slow path)
                       Persona ⏸ Nd to next                              -->
                <Border Padding="10,10" CornerRadius="8"
                        Background="{StaticResource SurfaceCardBrush}">
                  <StackPanel Spacing="0" HorizontalAlignment="Center">
                    <!-- Chat turn -->
                    <Border Padding="8,5" CornerRadius="5"
                            Background="#1A1F2A"
                            BorderBrush="{StaticResource DividerBrush}"
                            BorderThickness="1">
                      <StackPanel Spacing="1" HorizontalAlignment="Center">
                        <TextBlock Text="Chat turn" FontSize="10"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource TextPrimaryBrush}"/>
                        <TextBlock FontSize="8"
                                   Foreground="{StaticResource TextTertiaryBrush}">
                          <Run Text="{Binding Cognition.Turns.Count}"/>
                          <Run Text=" turns"/>
                        </TextBlock>
                      </StackPanel>
                    </Border>

                    <!-- Branch arrows: Chat turn fans out to TWO leaf
                         products and one downstream chain. The leaves
                         (Episodes + Skills) keep this section in sync
                         with Section 1's 5 namespace cards — earlier
                         rev had only Skills here, which made operators
                         (rightly) think the views disagreed. Episodes
                         is the raw turn record; Skills is the
                         in-the-loop strategy delta. -->
                    <!-- Centered, fixed-ish layout. HorizontalAlignment
                         is Center (NOT Stretch) so the inner Grid
                         doesn't push its parent ScrollViewer to claim
                         infinite width — that was the cause of the
                         "scroll right to see content" bug. The inner
                         `*` filler column still keeps Chat-turn
                         centred between Episodes and Heuristics. -->
                    <Grid ColumnDefinitions="Auto,Auto,Auto,*,Auto,Auto,Auto"
                          HorizontalAlignment="Center"
                          Width="320">
                      <!-- Episodes leaf (left) -->
                      <Border Grid.Column="0"
                              Padding="6,3" CornerRadius="5"
                              Background="#2A2630"
                              BorderBrush="#9F7BFF"
                              BorderThickness="1"
                              VerticalAlignment="Center">
                        <StackPanel Spacing="0">
                          <TextBlock FontSize="10" FontWeight="SemiBold"
                                     Foreground="#C9B5FF">
                            <Run Text="Episodes +"/>
                            <Run Text="{Binding Cognition.Brain.Glance[4].DeltaToday}"/>
                            <Run Text=" today" FontWeight="Normal"
                                 Foreground="#9F7BFF"/>
                          </TextBlock>
                          <TextBlock Text="raw turn record"
                                     FontSize="8"
                                     Foreground="#9F7BFF"/>
                        </StackPanel>
                      </Border>
                      <Path Grid.Column="1" Stretch="None"
                            Stroke="{StaticResource TextTertiaryBrush}"
                            StrokeThickness="1"
                            Data="M 0,8 L 30,8 M 4,5 L 0,8 L 4,11"/>
                      <!-- Vertical stem from Chat turn down through this row -->
                      <Path Grid.Column="2" Stretch="None"
                            Stroke="{StaticResource TextTertiaryBrush}"
                            StrokeThickness="1"
                            Data="M 8,0 L 8,16"/>
                      <!-- Filler column so left + right balance under
                           the 280px width — keeps Chat turn centred. -->
                      <Path Grid.Column="3"/>
                      <!-- Skills leaf (right) -->
                      <Path Grid.Column="4" Stretch="None"
                            Stroke="{StaticResource TextTertiaryBrush}"
                            StrokeThickness="1"
                            Data="M 0,8 L 30,8 M 26,5 L 30,8 L 26,11"/>
                      <Border Grid.Column="5"
                              Padding="6,3" CornerRadius="5"
                              Background="#1F2E25"
                              BorderBrush="#7DBC68"
                              BorderThickness="1"
                              VerticalAlignment="Center">
                        <StackPanel Spacing="0">
                          <!-- "Heuristics" = strategies the SkillEvolver
                               learned from chat history (NOT externally
                               installed SKILL.md files — those are
                               listed in the INSTALLED SKILLS panel
                               below as 'Skills'). The wire-name is
                               still "skills" for back-compat with
                               historical Greenfield snapshots; only
                               the label is rewritten. -->
                          <TextBlock FontSize="10" FontWeight="SemiBold"
                                     Foreground="#A8D596">
                            <Run Text="Heuristics +"/>
                            <Run Text="{Binding Cognition.Brain.Glance[2].DeltaThisWeek}"/>
                            <Run Text=" / wk" FontWeight="Normal"
                                 Foreground="#7DBC68"/>
                          </TextBlock>
                          <TextBlock Text="learned strategy"
                                     FontSize="8"
                                     Foreground="#7DBC68"/>
                        </StackPanel>
                      </Border>
                    </Grid>

                    <!-- Down arrow (Chat → Facts) -->
                    <Path Stretch="None"
                          Stroke="{StaticResource TextTertiaryBrush}"
                          StrokeThickness="1"
                          Data="M 50,0 L 50,12 M 47,8 L 50,12 L 53,8"
                          Width="100" Height="14"/>

                    <!-- Facts -->
                    <Border Padding="8,5" CornerRadius="5"
                            Background="#1E2C3F"
                            BorderBrush="#5AAEFF"
                            BorderThickness="1">
                      <StackPanel Spacing="1" HorizontalAlignment="Center">
                        <TextBlock FontSize="10" FontWeight="SemiBold"
                                   Foreground="#9CC6FF">
                          <Run Text="Facts +"/>
                          <Run Text="{Binding Cognition.Brain.Glance[3].DeltaToday}"/>
                          <Run Text=" today" FontWeight="Normal"
                               Foreground="#5AAEFF"/>
                        </TextBlock>
                        <TextBlock Text="preference, fact"
                                   FontSize="8"
                                   Foreground="#5AAEFF"/>
                      </StackPanel>
                    </Border>

                    <!-- Down arrow (Facts → Knowledge) -->
                    <Path Stretch="None"
                          Stroke="{StaticResource TextTertiaryBrush}"
                          StrokeThickness="1"
                          Data="M 50,0 L 50,12 M 47,8 L 50,12 L 53,8"
                          Width="100" Height="14"/>

                    <!-- Knowledge -->
                    <Border Padding="8,5" CornerRadius="5"
                            Background="#2F2218"
                            BorderBrush="#E07A4D"
                            BorderThickness="1">
                      <StackPanel Spacing="1" HorizontalAlignment="Center">
                        <StackPanel Orientation="Horizontal" Spacing="3"
                                    HorizontalAlignment="Center">
                          <TextBlock Text="Knowledge"
                                     FontSize="10" FontWeight="SemiBold"
                                     Foreground="#F0B89A"/>
                          <TextBlock Text="⏸"
                                     FontSize="9"
                                     Foreground="#E07A4D"
                                     VerticalAlignment="Center"/>
                        </StackPanel>
                        <TextBlock FontSize="8"
                                   Foreground="#E07A4D"
                                   Text="{Binding Cognition.Brain.KnowledgePressureLabel}"
                                   HorizontalAlignment="Center"/>
                      </StackPanel>
                    </Border>

                    <!-- Down arrow (Knowledge → Persona, dashed) -->
                    <Path Stretch="None"
                          Stroke="{StaticResource TextTertiaryBrush}"
                          StrokeThickness="1"
                          StrokeDashArray="3,2"
                          Data="M 50,0 L 50,12 M 47,8 L 50,12 L 53,8"
                          Width="100" Height="14"/>

                    <!-- Persona -->
                    <Border Padding="8,5" CornerRadius="5"
                            Background="#2A2335"
                            BorderBrush="#B589F5"
                            BorderThickness="1">
                      <StackPanel Spacing="1" HorizontalAlignment="Center">
                        <StackPanel Orientation="Horizontal" Spacing="3"
                                    HorizontalAlignment="Center">
                          <TextBlock Text="Persona"
                                     FontSize="10" FontWeight="SemiBold"
                                     Foreground="#D5BDFA"/>
                          <TextBlock Text="⏸"
                                     FontSize="9"
                                     Foreground="#B589F5"
                                     VerticalAlignment="Center"/>
                        </StackPanel>
                        <TextBlock FontSize="8"
                                   Foreground="#B589F5"
                                   Text="{Binding Cognition.Brain.PersonaPressureLabel}"
                                   HorizontalAlignment="Center"/>
                      </StackPanel>
                    </Border>
                  </StackPanel>
                </Border>
              </StackPanel>

              <!-- Section 1: Thinking — live SSE, grouped by turn.
                   Each turn renders as a card with a header and a
                   list of typed steps. Current turn pulses on its
                   latest step; previous turns collapse to a single
                   header line and re-expand on click. -->
              <StackPanel Spacing="6">
                <Grid ColumnDefinitions="*,Auto">
                  <TextBlock Grid.Column="0" Text="THINKING"
                             FontSize="10" FontWeight="Bold"
                             Foreground="{StaticResource TextTertiaryBrush}"/>
                  <Border Grid.Column="1"
                          CornerRadius="999"
                          Padding="6,1"
                          Background="#1B3220"
                          IsVisible="{Binding Cognition.StreamStatus,
                                      Converter={x:Static StringConverters.IsNotNullOrEmpty}}">
                    <TextBlock Text="{Binding Cognition.StreamStatus}"
                               FontSize="9" FontWeight="SemiBold"
                               Foreground="{StaticResource SuccessBrush}"
                               VerticalAlignment="Center"/>
                  </Border>
                </Grid>
                <TextBlock IsVisible="{Binding Cognition.ThinkingEmpty}"
                           Text="(no thinking yet — send a message and watch the agent reason)"
                           FontSize="11"
                           Foreground="{StaticResource TextTertiaryBrush}"
                           TextWrapping="Wrap"/>

                <ItemsControl ItemsSource="{Binding Cognition.Turns}">
                  <ItemsControl.ItemTemplate>
                    <DataTemplate>
                      <Border Margin="0,0,0,8" Padding="0" CornerRadius="8"
                              Background="{StaticResource SurfaceCardBrush}"
                              BorderBrush="{StaticResource DividerBrush}"
                              BorderThickness="1">
                        <StackPanel>
                          <!-- Turn header: click to expand/collapse -->
                          <Button Background="Transparent"
                                  BorderThickness="0"
                                  Padding="10,7"
                                  HorizontalAlignment="Stretch"
                                  HorizontalContentAlignment="Stretch"
                                  Command="{Binding ToggleExpandedCommand}">
                            <Grid ColumnDefinitions="Auto,*,Auto">
                              <TextBlock Grid.Column="0"
                                         Text="▾"
                                         FontSize="10"
                                         IsVisible="{Binding IsExpanded}"
                                         Foreground="{StaticResource TextSecondaryBrush}"
                                         VerticalAlignment="Center"
                                         Margin="0,0,8,0"/>
                              <TextBlock Grid.Column="0"
                                         Text="▸"
                                         FontSize="10"
                                         IsVisible="{Binding !IsExpanded}"
                                         Foreground="{StaticResource TextSecondaryBrush}"
                                         VerticalAlignment="Center"
                                         Margin="0,0,8,0"/>
                              <StackPanel Grid.Column="1" Spacing="1">
                                <TextBlock Text="{Binding HeaderText}"
                                           FontSize="11" FontWeight="SemiBold"
                                           Foreground="{StaticResource TextPrimaryBrush}"/>
                                <TextBlock Text="{Binding Headline}"
                                           FontSize="10"
                                           Foreground="{StaticResource TextSecondaryBrush}"
                                           TextTrimming="CharacterEllipsis"
                                           IsVisible="{Binding Headline,
                                                     Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>
                              </StackPanel>
                              <Border Grid.Column="2"
                                      CornerRadius="999"
                                      Padding="5,1"
                                      Background="#1B3220"
                                      IsVisible="{Binding IsCurrent}"
                                      VerticalAlignment="Center">
                                <TextBlock Text="live"
                                           FontSize="9" FontWeight="SemiBold"
                                           Foreground="{StaticResource SuccessBrush}"/>
                              </Border>
                            </Grid>
                          </Button>

                          <!-- Steps list (visible only when expanded) -->
                          <ItemsControl ItemsSource="{Binding Steps}"
                                        IsVisible="{Binding IsExpanded}"
                                        Margin="10,0,10,8">
                            <ItemsControl.ItemTemplate>
                              <DataTemplate>
                                <Grid ColumnDefinitions="22,*"
                                      Margin="0,3,0,3">
                                  <!-- Typed dot icon -->
                                  <Border Grid.Column="0"
                                          Width="18" Height="18"
                                          CornerRadius="9"
                                          Background="{Binding AccentColor}"
                                          VerticalAlignment="Top"
                                          Margin="0,2,4,0">
                                    <TextBlock Text="{Binding Glyph}"
                                               FontSize="10" FontWeight="SemiBold"
                                               Foreground="White"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center"/>
                                  </Border>

                                  <StackPanel Grid.Column="1" Spacing="1">
                                    <Grid ColumnDefinitions="*,Auto,Auto">
                                      <TextBlock Grid.Column="0"
                                                 Text="{Binding Label}"
                                                 FontSize="11" FontWeight="SemiBold"
                                                 Foreground="{StaticResource TextPrimaryBrush}"
                                                 TextTrimming="CharacterEllipsis"/>
                                      <!-- Phase A4: 4-dot persistence chain.
                                           queued (in-process queue) →
                                           EventLog → Greenfield → BSC anchor.
                                           Each dot lights as the step
                                           reaches that durable phase.
                                           Hover shows the audit summary
                                           (event_id / hash / blob_path /
                                           tx hash). -->
                                      <StackPanel Grid.Column="1"
                                                  Orientation="Horizontal"
                                                  Spacing="2"
                                                  VerticalAlignment="Center"
                                                  Margin="6,0,4,0"
                                                  ToolTip.Tip="{Binding Persistence.StatusSummary}">
                                        <Ellipse Width="6" Height="6"
                                                 Fill="{Binding Persistence.Queued,
                                                        Converter={x:Static local:DotFillConverter.Queued}}"
                                                 ToolTip.Tip="In-process queue (just emitted)"/>
                                        <Ellipse Width="6" Height="6"
                                                 Fill="{Binding Persistence.EventLogPersisted,
                                                        Converter={x:Static local:DotFillConverter.EventLog}}"
                                                 ToolTip.Tip="Server EventLog committed"/>
                                        <Ellipse Width="6" Height="6"
                                                 Fill="{Binding Persistence.GreenfieldMirrored,
                                                        Converter={x:Static local:DotFillConverter.Greenfield}}"
                                                 ToolTip.Tip="Mirrored to Greenfield (gnfd://)"/>
                                        <Ellipse Width="6" Height="6"
                                                 Fill="{Binding Persistence.BscAnchored,
                                                        Converter={x:Static local:DotFillConverter.BscAnchor}}"
                                                 ToolTip.Tip="Covered by a BSC state-root anchor (immutable)"/>
                                      </StackPanel>
                                      <TextBlock Grid.Column="2"
                                                 Text="{Binding DurationText}"
                                                 FontSize="10"
                                                 Foreground="{StaticResource TextTertiaryBrush}"/>
                                    </Grid>
                                    <!-- Reasoning (Gemini chain-of-thought) — italic, indented box -->
                                    <Border IsVisible="{Binding IsReasoning}"
                                            BorderThickness="2,0,0,0"
                                            BorderBrush="#7B5CFF"
                                            Padding="8,4,8,4"
                                            CornerRadius="0,4,4,0"
                                            Background="#1B1B26"
                                            Margin="0,3,0,0">
                                      <TextBlock Text="{Binding Content}"
                                                 FontSize="11"
                                                 FontStyle="Italic"
                                                 Foreground="{StaticResource TextPrimaryBrush}"
                                                 TextWrapping="Wrap"/>
                                    </Border>
                                    <!-- Default content row (anything not reasoning) -->
                                    <TextBlock Text="{Binding Content}"
                                               FontSize="10"
                                               Foreground="{StaticResource TextSecondaryBrush}"
                                               TextWrapping="Wrap" MaxLines="3"
                                               TextTrimming="CharacterEllipsis"
                                               IsVisible="{Binding !IsReasoning}"/>
                                  </StackPanel>
                                </Grid>
                              </DataTemplate>
                            </ItemsControl.ItemTemplate>
                          </ItemsControl>
                        </StackPanel>
                      </Border>
                    </DataTemplate>
                  </ItemsControl.ItemTemplate>
                </ItemsControl>
              </StackPanel>

              <!-- ═════════════════════════════════════════════════
                   Section 1.5: PRESSURE GAUGES (Phase C3).
                   Renders one progress bar per evolver, layer-coloured
                   (L0 gold / L1 green / L2 blue / L4 grey). Driven by
                   GET /agent/evolution/pressure (refreshed every 5s).
                   Lets the user see "what's about to evolve" — when
                   knowledge is 9/10 facts away from compiling, the
                   gauge fills to 90% and ⏳ pulses.
                   ═════════════════════════════════════════════════ -->
              <StackPanel Spacing="6">
                <Grid ColumnDefinitions="*,Auto">
                  <TextBlock Grid.Column="0" Text="EVOLUTION PRESSURE"
                             FontSize="10" FontWeight="Bold"
                             Foreground="{StaticResource TextTertiaryBrush}"
                             ToolTip.Tip="Each evolver's accumulator vs threshold. Layer colours follow the AHE pyramid: gold=persona (slowest), green=memory, blue=skills, grey=audit (fastest)."/>
                  <TextBlock Grid.Column="1"
                             Text="{Binding Cognition.Pressure.LastUpdated}"
                             FontSize="9"
                             Foreground="{StaticResource TextTertiaryBrush}"/>
                </Grid>
                <!-- Empty-state placeholder so a fresh agent (no
                     pressure data yet) doesn't see a blank section. -->
                <TextBlock IsVisible="{Binding Cognition.Pressure.IsEmpty}"
                           Text="(warming up — chat a few turns and evolvers will appear)"
                           FontSize="11"
                           Foreground="{StaticResource TextTertiaryBrush}"
                           TextWrapping="Wrap"/>
                <ItemsControl ItemsSource="{Binding Cognition.Pressure.Gauges}">
                  <ItemsControl.ItemTemplate>
                    <DataTemplate>
                      <Border Margin="0,0,0,6" Padding="8,6" CornerRadius="6"
                              Background="{StaticResource SurfaceCardBrush}"
                              ToolTip.Tip="{Binding GaugeDetail}">
                        <StackPanel Spacing="4">
                          <Grid ColumnDefinitions="*,Auto">
                            <TextBlock Grid.Column="0"
                                       Text="{Binding DisplayName}"
                                       FontSize="11" FontWeight="SemiBold"
                                       Foreground="{StaticResource TextPrimaryBrush}"
                                       TextTrimming="CharacterEllipsis"/>
                            <TextBlock Grid.Column="1"
                                       Text="{Binding FillLabel}"
                                       FontSize="10"
                                       Foreground="{StaticResource TextSecondaryBrush}"/>
                          </Grid>
                          <!-- The gauge itself: a thin bar background
                               + a progress fill clipped to FillRatio.
                               Layer colour drives both bar fill and
                               bottom-line summary. -->
                          <Border Height="6" CornerRadius="3"
                                  Background="#22FFFFFF">
                            <Grid HorizontalAlignment="Stretch">
                              <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="{Binding FillRatio, StringFormat=\{0:0.000\}*}"/>
                                <ColumnDefinition Width="*"/>
                              </Grid.ColumnDefinitions>
                              <Border Grid.Column="0"
                                      CornerRadius="3"
                                      Background="{Binding LayerColor}"/>
                            </Grid>
                          </Border>
                          <TextBlock Text="{Binding FedByLabel}"
                                     FontSize="9"
                                     Foreground="{StaticResource TextTertiaryBrush}"
                                     IsVisible="{Binding FedByLabel,
                                                 Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>
                        </StackPanel>
                      </Border>
                    </DataTemplate>
                  </ItemsControl.ItemTemplate>
                </ItemsControl>

                <!-- ── 24h frequency histogram (mini-pyramid) ──
                     One row per evolver, 24 hourly bars. Visualises
                     the BEP-Nexus AHE pyramid: L0 sparse at top,
                     L1/L2 busier toward the bottom. -->
                <TextBlock Text="LAST 24H FREQUENCY"
                           FontSize="9" FontWeight="Bold"
                           Foreground="{StaticResource TextTertiaryBrush}"
                           Margin="0,8,0,0"
                           IsVisible="{Binding Cognition.Pressure.Histogram.Count}"/>
                <ItemsControl ItemsSource="{Binding Cognition.Pressure.Histogram}">
                  <ItemsControl.ItemTemplate>
                    <DataTemplate>
                      <Grid ColumnDefinitions="120,*,Auto" Margin="0,0,0,3">
                        <TextBlock Grid.Column="0"
                                   Text="{Binding Evolver}"
                                   FontSize="10"
                                   Foreground="{StaticResource TextSecondaryBrush}"
                                   TextTrimming="CharacterEllipsis"
                                   VerticalAlignment="Center"/>
                        <ItemsControl Grid.Column="1"
                                      ItemsSource="{Binding Bars}"
                                      Height="20">
                          <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                              <UniformGrid Columns="24" Rows="1"/>
                            </ItemsPanelTemplate>
                          </ItemsControl.ItemsPanel>
                          <ItemsControl.ItemTemplate>
                            <DataTemplate>
                              <Border Margin="0,0,1,0"
                                      VerticalAlignment="Bottom"
                                      Background="{Binding $parent[ItemsControl].DataContext.LayerColor}"
                                      Height="{Binding Height,
                                              Converter={x:Static local:HistogramHeightConverter.Instance}}"
                                      ToolTip.Tip="{Binding Tooltip}"/>
                            </DataTemplate>
                          </ItemsControl.ItemTemplate>
                        </ItemsControl>
                        <TextBlock Grid.Column="2"
                                   Text="{Binding TotalIn24h, StringFormat=\{0\}/24h}"
                                   FontSize="9"
                                   Foreground="{StaticResource TextTertiaryBrush}"
                                   VerticalAlignment="Center"
                                   Margin="6,0,0,0"/>
                      </Grid>
                    </DataTemplate>
                  </ItemsControl.ItemTemplate>
                </ItemsControl>

                <!-- ── Recent verdict feed (Phase D 续 / #159) ──
                     Newest-first list of kept / reverted decisions
                     so the user sees what the agent's evolution
                     pipeline has actually concluded. -->
                <TextBlock Text="RECENT VERDICTS"
                           FontSize="9" FontWeight="Bold"
                           Foreground="{StaticResource TextTertiaryBrush}"
                           Margin="0,8,0,0"
                           IsVisible="{Binding Cognition.Pressure.Verdicts.Count}"/>
                <ItemsControl ItemsSource="{Binding Cognition.Pressure.Verdicts}">
                  <ItemsControl.ItemTemplate>
                    <DataTemplate>
                      <Border Margin="0,0,0,4" Padding="8,6" CornerRadius="6"
                              Background="{StaticResource SurfaceCardBrush}">
                        <StackPanel Spacing="3">
                          <Grid ColumnDefinitions="Auto,*,Auto">
                            <Border Grid.Column="0" Padding="5,2" CornerRadius="3"
                                    Background="{Binding DecisionColor}"
                                    Margin="0,0,6,0"
                                    VerticalAlignment="Center">
                              <TextBlock Text="{Binding DecisionBadge}"
                                         FontSize="9" FontWeight="Bold"
                                         Foreground="White"/>
                            </Border>
                            <TextBlock Grid.Column="1"
                                       Text="{Binding Evolver}"
                                       FontSize="11" FontWeight="SemiBold"
                                       Foreground="{StaticResource TextPrimaryBrush}"
                                       VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="2"
                                       Text="{Binding RelativeTime}"
                                       FontSize="9"
                                       Foreground="{StaticResource TextTertiaryBrush}"
                                       VerticalAlignment="Center"/>
                          </Grid>
                          <TextBlock Text="{Binding ChangeSummary}"
                                     FontSize="10"
                                     Foreground="{StaticResource TextSecondaryBrush}"
                                     TextWrapping="Wrap"
                                     MaxLines="2"
                                     TextTrimming="CharacterEllipsis"
                                     IsVisible="{Binding ChangeSummary,
                                                 Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>
                          <TextBlock Text="{Binding ReasoningLabel}"
                                     FontSize="9"
                                     Foreground="{StaticResource TextTertiaryBrush}"
                                     IsVisible="{Binding ReasoningLabel,
                                                 Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>
                        </StackPanel>
                      </Border>
                    </DataTemplate>
                  </ItemsControl.ItemTemplate>
                </ItemsControl>
              </StackPanel>

              <!-- ═════════════════════════════════════════════════
                   Section 2: JUST LEARNED (Phase D 续 / #159 v2)
                   Replaces "JUST HAPPENED" — sourced from
                   /api/v1/agent/learning_summary (typed namespaces).
                   Each row: kind chip + content + 3-dot chain status
                   + relative time.
                   ═════════════════════════════════════════════════ -->
              <StackPanel Spacing="6">
                <TextBlock Text="JUST LEARNED"
                           FontSize="10" FontWeight="Bold"
                           Foreground="{StaticResource TextTertiaryBrush}"
                           ToolTip.Tip="Newest items learned across the 5 typed namespaces (persona / knowledge / skills / facts / episodes). Each one shows ● local · ● mirrored · ● anchored chain status."/>
                <TextBlock IsVisible="{Binding Cognition.Brain.IsJustLearnedEmpty}"
                           Text="(nothing learned yet — chat with the agent and items will start appearing here)"
                           FontSize="11"
                           Foreground="{StaticResource TextTertiaryBrush}"
                           TextWrapping="Wrap"/>
                <ItemsControl ItemsSource="{Binding Cognition.Brain.JustLearned}">
                  <ItemsControl.ItemTemplate>
                    <DataTemplate>
                      <Border Margin="0,0,0,5" Padding="8,6" CornerRadius="6"
                              Background="{StaticResource SurfaceCardBrush}">
                        <StackPanel Spacing="4">
                          <Grid ColumnDefinitions="Auto,*,Auto">
                            <Border Grid.Column="0" Padding="5,2" CornerRadius="3"
                                    Background="{StaticResource SurfaceMutedBrush}"
                                    Margin="0,0,6,0"
                                    VerticalAlignment="Center">
                              <TextBlock Text="{Binding KindBadge}"
                                         FontSize="9" FontWeight="Bold"
                                         Foreground="{StaticResource TextSecondaryBrush}"/>
                            </Border>
                            <TextBlock Grid.Column="1"
                                       Text="{Binding Content}"
                                       FontSize="11"
                                       Foreground="{StaticResource TextPrimaryBrush}"
                                       TextWrapping="Wrap" MaxLines="2"
                                       TextTrimming="CharacterEllipsis"/>
                            <StackPanel Grid.Column="2" Orientation="Horizontal"
                                        Spacing="3" Margin="6,0,0,0"
                                        VerticalAlignment="Center">
                              <Ellipse Width="6" Height="6"
                                       Fill="{StaticResource SuccessBrush}"
                                       IsVisible="{Binding DotLocal}"/>
                              <Ellipse Width="6" Height="6"
                                       Fill="{StaticResource SuccessBrush}"
                                       IsVisible="{Binding DotMirrored}"/>
                              <Ellipse Width="6" Height="6"
                                       Stroke="{StaticResource DividerBrush}"
                                       StrokeThickness="1"
                                       IsVisible="{Binding !DotMirrored}"/>
                              <Ellipse Width="6" Height="6"
                                       Fill="{StaticResource SuccessBrush}"
                                       IsVisible="{Binding DotAnchored}"/>
                              <Ellipse Width="6" Height="6"
                                       Stroke="{StaticResource DividerBrush}"
                                       StrokeThickness="1"
                                       IsVisible="{Binding !DotAnchored}"/>
                            </StackPanel>
                          </Grid>
                          <TextBlock Text="{Binding RelativeTime}"
                                     FontSize="9"
                                     Foreground="{StaticResource TextTertiaryBrush}"/>
                        </StackPanel>
                      </Border>
                    </DataTemplate>
                  </ItemsControl.ItemTemplate>
                </ItemsControl>
              </StackPanel>

              <!-- ═════════════════════════════════════════════════
                   Section 3: CHAIN HEALTH (Phase D 续 / #159 v2)
                   Replaces "ANCHORED ON BSC" — surfaces the chain
                   pipeline state at a glance: WAL queue + daemon
                   alive + Greenfield/BSC ready + recent anchor list.
                   Sourced from /api/v1/agent/chain_status.
                   ═════════════════════════════════════════════════ -->
              <StackPanel Spacing="6">
                <TextBlock Text="CHAIN HEALTH"
                           FontSize="10" FontWeight="Bold"
                           Foreground="{StaticResource TextTertiaryBrush}"
                           ToolTip.Tip="Background sync to Greenfield + BSC. Healthy = empty queue + daemon alive + both backends ready."/>
                <Border Padding="10,8" CornerRadius="8"
                        Background="{StaticResource SurfaceCardBrush}">
                  <StackPanel Spacing="6"
                              DataContext="{Binding Cognition.Brain.Health}">
                    <Grid ColumnDefinitions="*,Auto">
                      <TextBlock Grid.Column="0"
                                 Text="{Binding OverallStatus}"
                                 FontSize="13" FontWeight="SemiBold"
                                 Foreground="{StaticResource TextPrimaryBrush}"/>
                      <TextBlock Grid.Column="1"
                                 Text="{Binding QueueLabel}"
                                 FontSize="10"
                                 Foreground="{StaticResource TextSecondaryBrush}"
                                 VerticalAlignment="Center"/>
                    </Grid>
                    <Grid ColumnDefinitions="*,*,*">
                      <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="4">
                        <Ellipse Width="7" Height="7"
                                 Fill="{StaticResource SuccessBrush}"
                                 IsVisible="{Binding DaemonAlive}"
                                 VerticalAlignment="Center"/>
                        <Ellipse Width="7" Height="7"
                                 Fill="{StaticResource ErrorBrush}"
                                 IsVisible="{Binding !DaemonAlive}"
                                 VerticalAlignment="Center"/>
                        <TextBlock Text="daemon" FontSize="10"
                                   Foreground="{StaticResource TextSecondaryBrush}"
                                   VerticalAlignment="Center"/>
                      </StackPanel>
                      <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="4">
                        <Ellipse Width="7" Height="7"
                                 Fill="{StaticResource SuccessBrush}"
                                 IsVisible="{Binding GreenfieldReady}"
                                 VerticalAlignment="Center"/>
                        <Ellipse Width="7" Height="7"
                                 Fill="{StaticResource WarningBrush}"
                                 IsVisible="{Binding !GreenfieldReady}"
                                 VerticalAlignment="Center"/>
                        <TextBlock Text="greenfield" FontSize="10"
                                   Foreground="{StaticResource TextSecondaryBrush}"
                                   VerticalAlignment="Center"/>
                      </StackPanel>
                      <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="4">
                        <Ellipse Width="7" Height="7"
                                 Fill="{StaticResource SuccessBrush}"
                                 IsVisible="{Binding BscReady}"
                                 VerticalAlignment="Center"/>
                        <Ellipse Width="7" Height="7"
                                 Fill="{StaticResource WarningBrush}"
                                 IsVisible="{Binding !BscReady}"
                                 VerticalAlignment="Center"/>
                        <TextBlock Text="bsc" FontSize="10"
                                   Foreground="{StaticResource TextSecondaryBrush}"
                                   VerticalAlignment="Center"/>
                      </StackPanel>
                    </Grid>
                    <!-- Degraded-reason banner. Only renders when the
                         server has reported a fallback within the last
                         5 minutes; gives the operator the actual root
                         cause (e.g. "Cannot find module …", "bucket
                         nexus-agent-985 unavailable") instead of just
                         the yellow dot. -->
                    <Border IsVisible="{Binding FallbackActive}"
                            Padding="8,6" CornerRadius="6"
                            BorderBrush="{StaticResource WarningBrush}"
                            BorderThickness="1"
                            Margin="0,4,0,0">
                      <StackPanel Spacing="2">
                        <TextBlock Text="Greenfield writes degraded — local cache only"
                                   FontSize="10" FontWeight="SemiBold"
                                   Foreground="{StaticResource WarningBrush}"
                                   TextWrapping="Wrap"/>
                        <TextBlock Text="{Binding DegradedReason}"
                                   FontSize="10"
                                   Foreground="{StaticResource TextSecondaryBrush}"
                                   TextWrapping="Wrap"
                                   IsVisible="{Binding DegradedReason, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>
                      </StackPanel>
                    </Border>

                    <!-- BSC anchor failure banner — same shape as the
                         Greenfield one. Was previously a silent fail:
                         bsc dot stayed solid green even when every
                         anchor was reverting (RPC down, gas exhausted,
                         nonce stuck). -->
                    <Border IsVisible="{Binding BscFailureActive}"
                            Padding="8,6" CornerRadius="6"
                            BorderBrush="{StaticResource ErrorBrush}"
                            BorderThickness="1"
                            Margin="0,4,0,0">
                      <StackPanel Spacing="2">
                        <TextBlock Text="BSC anchor failed — local-only state"
                                   FontSize="10" FontWeight="SemiBold"
                                   Foreground="{StaticResource ErrorBrush}"
                                   TextWrapping="Wrap"/>
                        <TextBlock Text="{Binding BscDegradedReason}"
                                   FontSize="10"
                                   Foreground="{StaticResource TextSecondaryBrush}"
                                   TextWrapping="Wrap"
                                   IsVisible="{Binding BscDegradedReason, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>
                      </StackPanel>
                    </Border>

                    <!-- WAL-stuck soft-warning banner. Renders when the
                         oldest pending write has been queued for more
                         than ~1 minute AND nothing has explicitly
                         failed yet. Catches the slow-leak scenario
                         where the daemon is alive but writes don't
                         drain — easy to miss without per-entry age. -->
                    <Border IsVisible="{Binding WalIsStuck}"
                            Padding="8,6" CornerRadius="6"
                            BorderBrush="{StaticResource WarningBrush}"
                            BorderThickness="1"
                            Margin="0,4,0,0">
                      <StackPanel Spacing="2">
                        <TextBlock Text="Writes piling up — pipeline lagging"
                                   FontSize="10" FontWeight="SemiBold"
                                   Foreground="{StaticResource WarningBrush}"
                                   TextWrapping="Wrap"/>
                        <TextBlock Text="{Binding WalStuckCaption}"
                                   FontSize="10"
                                   FontFamily="Menlo, Consolas, monospace"
                                   Foreground="{StaticResource TextSecondaryBrush}"
                                   TextWrapping="Wrap"/>
                      </StackPanel>
                    </Border>
                  </StackPanel>
                </Border>

                <!-- ─────────────────────────────────────────────────
                     CHAIN OPERATIONS LOG (Section 6) — recent
                     greenfield/BSC operations with status. Replaces
                     "SSH to server + SELECT from twin_chain_events"
                     for any operator wanting to see what happened.
                     ───────────────────────────────────────────────── -->
                <TextBlock Text="CHAIN OPERATIONS"
                           FontSize="9" FontWeight="Bold"
                           Foreground="{StaticResource TextTertiaryBrush}"
                           Margin="0,8,0,0"
                           IsVisible="{Binding Cognition.Brain.ChainEvents.Count}"/>
                <ItemsControl ItemsSource="{Binding Cognition.Brain.ChainEvents}"
                              IsVisible="{Binding Cognition.Brain.ChainEvents.Count}">
                  <ItemsControl.ItemTemplate>
                    <DataTemplate>
                      <Border Padding="8,5" CornerRadius="6"
                              Background="{StaticResource SurfaceCardBrush}"
                              Margin="0,0,0,4">
                        <Grid ColumnDefinitions="Auto,*,Auto">
                          <!-- Status dot: green / amber / red — picks
                               brush via name lookup against the row's
                               StatusColorKey ("Success" / "Warning" /
                               "Error"). The static StatusColorConverter
                               instance is queried on-the-fly so we
                               don't need an App.axaml resource entry. -->
                          <Ellipse Grid.Column="0" Width="6" Height="6"
                                   Margin="0,0,8,0"
                                   VerticalAlignment="Center"
                                   Fill="{Binding StatusColorKey,
                                          Converter={x:Static local:StatusColorConverter.Instance}}"/>
                          <StackPanel Grid.Column="1" Spacing="1">
                            <Grid ColumnDefinitions="Auto,*">
                              <TextBlock Grid.Column="0"
                                         Text="{Binding KindLabel}"
                                         FontSize="10" FontWeight="SemiBold"
                                         Foreground="{StaticResource TextPrimaryBrush}"
                                         Margin="0,0,6,0"/>
                              <TextBlock Grid.Column="1"
                                         Text="{Binding Summary}"
                                         FontSize="10"
                                         Foreground="{StaticResource TextSecondaryBrush}"
                                         TextTrimming="CharacterEllipsis"/>
                            </Grid>
                            <TextBlock Text="{Binding Error}"
                                       IsVisible="{Binding HasError}"
                                       FontSize="9"
                                       FontFamily="Menlo, Consolas, monospace"
                                       Foreground="{StaticResource TextTertiaryBrush}"
                                       TextWrapping="Wrap"/>
                          </StackPanel>
                          <TextBlock Grid.Column="2"
                                     Text="{Binding TimeAgo}"
                                     FontSize="10"
                                     Foreground="{StaticResource TextTertiaryBrush}"
                                     VerticalAlignment="Top"
                                     Margin="8,0,0,0"/>
                        </Grid>
                      </Border>
                    </DataTemplate>
                  </ItemsControl.ItemTemplate>
                </ItemsControl>

                <!-- ─────────────────────────────────────────────────
                     INSTALLED SKILLS (Section 7) — externally-installed
                     SKILL.md packages. NOT to be confused with the
                     Brain panel's Heuristics card (= learned strategies
                     from SkillEvolver). These are tools the agent has
                     pip-install'd: pdf, xlsx, mcp:slack, etc.
                     ───────────────────────────────────────────────── -->
                <TextBlock Text="INSTALLED SKILLS"
                           FontSize="9" FontWeight="Bold"
                           Foreground="{StaticResource TextTertiaryBrush}"
                           Margin="0,8,0,0"
                           ToolTip.Tip="External skill packages the agent has installed via manage_skill (pdf, xlsx, mcp:*, etc). Different from the Heuristics card above — those are strategies the agent learned from chat."/>
                <!-- Empty state placeholder — visible iff no skills are
                     installed yet. Keeps the section header from looking
                     orphaned on a fresh deployment. -->
                <TextBlock IsVisible="{Binding Cognition.Brain.IsInstalledSkillsEmpty}"
                           Text="No skills installed yet — the agent will install them as it needs new capabilities."
                           FontSize="10"
                           Foreground="{StaticResource TextTertiaryBrush}"
                           TextWrapping="Wrap"
                           Margin="0,2,0,0"/>
                <ItemsControl ItemsSource="{Binding Cognition.Brain.InstalledSkills}">
                  <ItemsControl.ItemTemplate>
                    <DataTemplate>
                      <Border Padding="8,5" CornerRadius="6"
                              Background="{StaticResource SurfaceCardBrush}"
                              Margin="0,0,0,4">
                        <StackPanel Spacing="2">
                          <Grid ColumnDefinitions="Auto,*">
                            <TextBlock Grid.Column="0"
                                       Text="📄"
                                       FontSize="11"
                                       Margin="0,0,6,0"
                                       VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="1"
                                       Text="{Binding Title}"
                                       FontSize="11" FontWeight="SemiBold"
                                       Foreground="{StaticResource TextPrimaryBrush}"
                                       TextTrimming="CharacterEllipsis"/>
                          </Grid>
                          <TextBlock Text="{Binding Description}"
                                     IsVisible="{Binding Description, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                                     FontSize="10"
                                     Foreground="{StaticResource TextSecondaryBrush}"
                                     TextWrapping="Wrap"
                                     MaxLines="2"
                                     TextTrimming="CharacterEllipsis"/>
                          <TextBlock Text="{Binding MetaLine}"
                                     IsVisible="{Binding MetaLine, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                                     FontSize="9"
                                     Foreground="{StaticResource TextTertiaryBrush}"
                                     FontFamily="Menlo, Consolas, monospace"/>
                        </StackPanel>
                      </Border>
                    </DataTemplate>
                  </ItemsControl.ItemTemplate>
                </ItemsControl>

                <!-- Recent anchors mini-list (top 3) — keeps the
                     auditable per-anchor detail (state-root hash + tx)
                     accessible without a slide-over click. -->
                <TextBlock Text="RECENT ANCHORS"
                           FontSize="9" FontWeight="Bold"
                           Foreground="{StaticResource TextTertiaryBrush}"
                           Margin="0,4,0,0"
                           IsVisible="{Binding Cognition.OnChain.Count}"/>
                <ItemsControl ItemsSource="{Binding Cognition.OnChain}">
                  <ItemsControl.ItemTemplate>
                    <DataTemplate>
                      <Border Margin="0,0,0,3" Padding="8,5" CornerRadius="6"
                              Background="{StaticResource SurfaceCardBrush}">
                        <Grid ColumnDefinitions="Auto,*,Auto">
                          <Border Grid.Column="0" Width="6" Height="6"
                                  CornerRadius="3"
                                  Background="{Binding StatusColor}"
                                  Margin="0,0,6,0"
                                  VerticalAlignment="Center"/>
                          <TextBlock Grid.Column="1" FontSize="10"
                                     Foreground="{StaticResource TextSecondaryBrush}">
                            <Run Text="{Binding ShortHash}"
                                 FontFamily="Menlo, Consolas, monospace"
                                 Foreground="{StaticResource TextPrimaryBrush}"/>
                            <Run Text=" · "/>
                            <Run Text="{Binding RelativeTime}"
                                 Foreground="{StaticResource TextTertiaryBrush}"/>
                          </TextBlock>
                          <TextBlock Grid.Column="2" FontSize="9"
                                     IsVisible="{Binding HasBscTx}"
                                     Foreground="{StaticResource AccentClaudeBrush}"
                                     FontFamily="Menlo, Consolas, monospace"
                                     Text="{Binding ShortTx}"
                                     VerticalAlignment="Center"/>
                        </Grid>
                      </Border>
                    </DataTemplate>
                  </ItemsControl.ItemTemplate>
                </ItemsControl>
              </StackPanel>

              <!-- Section 4: Working directory (Greenfield bucket tree) -->
              <!-- #134: Greenfield sync disabled by default while we
                   transition to an S3-compatible backend for durable
                   storage. The whole section is hidden until the new
                   backend lands; ViewModels stay wired so re-enabling
                   is a one-line change. -->
              <StackPanel Spacing="6" IsVisible="False">
                <TextBlock Text="WORK DIRECTORY"
                           FontSize="10" FontWeight="Bold"
                           Foreground="{StaticResource TextTertiaryBrush}"
                           ToolTip.Tip="Live mirror of the agent's Greenfield bucket — every memory file, artifact version, and session checkpoint."/>
                <TextBlock Text="{Binding Cognition.WorkdirHeading}"
                           FontSize="10"
                           FontFamily="Menlo, Consolas, monospace"
                           Foreground="{StaticResource TextSecondaryBrush}"/>
                <TextBlock IsVisible="{Binding Cognition.WorkdirEmpty}"
                           Text="(bucket pending — chain identity bootstrapping)"
                           FontSize="11"
                           Foreground="{StaticResource TextTertiaryBrush}"/>
                <!-- Sync badge legend so the user knows what the
                     ✅ / ⏳ glyphs mean without hovering. -->
                <StackPanel Orientation="Horizontal" Spacing="12"
                            Margin="0,0,0,4">
                  <StackPanel Orientation="Horizontal" Spacing="4">
                    <TextBlock Text="✅" FontSize="10"/>
                    <TextBlock Text="synced"
                               FontSize="9"
                               Foreground="{StaticResource TextTertiaryBrush}"
                               VerticalAlignment="Center"/>
                  </StackPanel>
                  <StackPanel Orientation="Horizontal" Spacing="4">
                    <TextBlock Text="⏳" FontSize="10"/>
                    <TextBlock Text="pending"
                               FontSize="9"
                               Foreground="{StaticResource TextTertiaryBrush}"
                               VerticalAlignment="Center"/>
                  </StackPanel>
                </StackPanel>

                <ItemsControl ItemsSource="{Binding Cognition.Workdir}">
                  <ItemsControl.ItemTemplate>
                    <DataTemplate>
                      <StackPanel>
                        <!-- Level 0: agent root -->
                        <StackPanel Orientation="Horizontal" Spacing="6"
                                    Margin="0,2,0,0">
                          <TextBlock Text="{Binding Glyph}" FontSize="11"/>
                          <TextBlock Text="{Binding Name}"
                                     FontSize="11" FontWeight="SemiBold"
                                     FontFamily="Menlo, Consolas, monospace"
                                     Foreground="{StaticResource TextPrimaryBrush}"/>
                          <TextBlock Text="{Binding SyncBadge}"
                                     FontSize="11"
                                     IsVisible="{Binding ShowBadge}"
                                     ToolTip.Tip="{Binding SyncTooltip}"/>
                        </StackPanel>
                        <ItemsControl ItemsSource="{Binding Children}"
                                      Margin="14,2,0,0"
                                      IsVisible="{Binding HasChildren}">
                          <ItemsControl.ItemTemplate>
                            <DataTemplate>
                              <StackPanel>
                                <!-- Level 1: top-level folders (memory/, artifacts/, sessions/) -->
                                <StackPanel Orientation="Horizontal" Spacing="6"
                                            Margin="0,2,0,0">
                                  <TextBlock Text="{Binding Glyph}" FontSize="10"/>
                                  <TextBlock Text="{Binding Name}"
                                             FontSize="10"
                                             FontFamily="Menlo, Consolas, monospace"
                                             Foreground="{StaticResource TextPrimaryBrush}"
                                             TextTrimming="CharacterEllipsis"/>
                                  <TextBlock Text="{Binding SyncBadge}"
                                             FontSize="10"
                                             IsVisible="{Binding ShowBadge}"
                                             ToolTip.Tip="{Binding SyncTooltip}"/>
                                </StackPanel>
                                <ItemsControl ItemsSource="{Binding Children}"
                                              Margin="14,1,0,0"
                                              IsVisible="{Binding HasChildren}">
                                  <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                      <!-- Level 2: leaves (the actual files) — ALWAYS show badge here -->
                                      <StackPanel Orientation="Horizontal" Spacing="6"
                                                  Margin="0,1,0,0">
                                        <TextBlock Text="{Binding Glyph}" FontSize="9"/>
                                        <TextBlock Text="{Binding Name}"
                                                   FontSize="9"
                                                   FontFamily="Menlo, Consolas, monospace"
                                                   Foreground="{StaticResource TextSecondaryBrush}"
                                                   TextTrimming="CharacterEllipsis"/>
                                        <TextBlock Text="{Binding SyncBadge}"
                                                   FontSize="9"
                                                   IsVisible="{Binding ShowBadge}"
                                                   ToolTip.Tip="{Binding SyncTooltip}"/>
                                      </StackPanel>
                                    </DataTemplate>
                                  </ItemsControl.ItemTemplate>
                                </ItemsControl>
                              </StackPanel>
                            </DataTemplate>
                          </ItemsControl.ItemTemplate>
                        </ItemsControl>
                      </StackPanel>
                    </DataTemplate>
                  </ItemsControl.ItemTemplate>
                </ItemsControl>
              </StackPanel>
            </StackPanel>
          </ScrollViewer>
        </Grid>
      </Border>
    </Grid>

    <!-- ══════════════════════════════════════════════════════════════
         SLIDE-OVER DETAIL PANEL (Memories or Anchors)
         Layered above everything when open. Click outside or X closes.
         ══════════════════════════════════════════════════════════════ -->
    <Panel IsVisible="{Binding DetailPanel.IsOpen}">
      <!-- Backdrop -->
      <Border Background="#88000000">
        <Border.Styles>
          <Style Selector="Border">
            <Setter Property="Cursor" Value="Hand"/>
          </Style>
        </Border.Styles>
        <Button Background="Transparent" BorderThickness="0"
                HorizontalAlignment="Stretch" VerticalAlignment="Stretch"
                Command="{Binding DetailPanel.CloseCommand}"/>
      </Border>

      <!-- Panel itself -->
      <Border HorizontalAlignment="Right" VerticalAlignment="Stretch"
              Width="460"
              Background="{StaticResource SurfaceCardBrush}"
              BorderBrush="{StaticResource DividerBrush}"
              BorderThickness="1,0,0,0"
              BoxShadow="-12 0 32 0 #66000000">
        <Grid RowDefinitions="Auto,*">
          <Border Grid.Row="0" Padding="20,16"
                  BorderThickness="0,0,0,1"
                  BorderBrush="{StaticResource DividerBrush}">
            <DockPanel>
              <Button DockPanel.Dock="Right" Content="✕"
                      Command="{Binding DetailPanel.CloseCommand}"
                      Classes="ghost" FontSize="14" Padding="8,4"/>
              <TextBlock Text="{Binding DetailPanel.Title}"
                         FontSize="15" FontWeight="SemiBold"
                         Foreground="{StaticResource TextPrimaryBrush}"
                         VerticalAlignment="Center"/>
            </DockPanel>
          </Border>

          <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto"
                        Padding="20,16">
            <Panel>
              <!-- Memories: Current Brain (latest) + History (older) -->
              <StackPanel IsVisible="{Binding DetailPanel.ShowMemories}"
                          Spacing="20">

                <!-- Empty state -->
                <Border IsVisible="{Binding DetailPanel.MemoriesEmpty}"
                        Padding="20,28" CornerRadius="12"
                        Background="{StaticResource SurfaceMutedBrush}"
                        BorderBrush="{StaticResource DividerBrush}"
                        BorderThickness="1">
                  <StackPanel Spacing="10" HorizontalAlignment="Center">
                    <TextBlock Text="🧠" FontSize="32"
                               HorizontalAlignment="Center"/>
                    <TextBlock Text="No memory snapshots yet"
                               FontSize="14" FontWeight="SemiBold"
                               Foreground="{StaticResource TextPrimaryBrush}"
                               HorizontalAlignment="Center"/>
                    <TextBlock TextWrapping="Wrap" TextAlignment="Center"
                               MaxWidth="320" FontSize="12"
                               Foreground="{StaticResource TextSecondaryBrush}"
                               Text="The agent compacts what it learned every 10 user turns. Each snapshot summarises new events and folds in prior summaries — the latest one is the agent's current memory; older ones stay as an immutable audit trail."/>
                  </StackPanel>
                </Border>

                <!-- Current Brain -->
                <StackPanel Spacing="8" IsVisible="{Binding DetailPanel.HasCurrentBrain}">
                  <StackPanel Orientation="Horizontal" Spacing="8">
                    <Border Width="6" Height="6" CornerRadius="3"
                            Background="{StaticResource SuccessBrush}"
                            VerticalAlignment="Center"/>
                    <TextBlock Text="CURRENT BRAIN" FontSize="10" FontWeight="Bold"
                               Foreground="{StaticResource SuccessBrush}"
                               VerticalAlignment="Center"/>
                    <TextBlock Text="{Binding DetailPanel.CurrentBrain.RelativeTime}"
                               FontSize="10"
                               Foreground="{StaticResource TextTertiaryBrush}"
                               VerticalAlignment="Center"/>
                  </StackPanel>
                  <Border Padding="16,14" CornerRadius="12"
                          Background="{StaticResource SurfaceMutedBrush}"
                          BorderBrush="{StaticResource SuccessBrush}"
                          BorderThickness="1">
                    <StackPanel Spacing="6">
                      <TextBlock Text="{Binding DetailPanel.CurrentBrain.Content}"
                                 FontSize="13" TextWrapping="Wrap"
                                 Foreground="{StaticResource TextPrimaryBrush}"
                                 FontFamily="Menlo, Consolas, monospace"/>
                      <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,4,0,0">
                        <TextBlock Text="{Binding DetailPanel.CurrentBrain.Range}"
                                   FontSize="10"
                                   Foreground="{StaticResource TextTertiaryBrush}"/>
                        <TextBlock Text="·" FontSize="10"
                                   Foreground="{StaticResource TextTertiaryBrush}"/>
                        <TextBlock Text="{Binding DetailPanel.CurrentBrain.SizeLabel}"
                                   FontSize="10"
                                   Foreground="{StaticResource TextTertiaryBrush}"/>
                      </StackPanel>
                    </StackPanel>
                  </Border>
                </StackPanel>

                <!-- History -->
                <StackPanel Spacing="8" IsVisible="{Binding DetailPanel.HasHistory}">
                  <TextBlock Text="HISTORY (SUPERSEDED)"
                             FontSize="10" FontWeight="Bold"
                             Foreground="{StaticResource TextTertiaryBrush}"/>
                  <ItemsControl ItemsSource="{Binding DetailPanel.HistoryMemories}">
                    <ItemsControl.ItemTemplate>
                      <DataTemplate>
                        <Border Margin="0,0,0,8" Padding="12,10" CornerRadius="8"
                                Background="{StaticResource SurfaceMutedBrush}"
                                BorderBrush="{StaticResource DividerBrush}"
                                BorderThickness="1"
                                Opacity="0.7">
                          <StackPanel Spacing="4">
                            <StackPanel Orientation="Horizontal" Spacing="6">
                              <TextBlock Text="{Binding Range}" FontSize="10"
                                         Foreground="{StaticResource TextSecondaryBrush}"
                                         VerticalAlignment="Center"/>
                              <TextBlock Text="·" FontSize="10"
                                         Foreground="{StaticResource TextTertiaryBrush}"/>
                              <TextBlock Text="{Binding SizeLabel}" FontSize="10"
                                         Foreground="{StaticResource TextTertiaryBrush}"/>
                              <TextBlock Text="·" FontSize="10"
                                         Foreground="{StaticResource TextTertiaryBrush}"/>
                              <TextBlock Text="{Binding RelativeTime}" FontSize="10"
                                         Foreground="{StaticResource TextTertiaryBrush}"/>
                            </StackPanel>
                            <TextBlock Text="{Binding Content}" FontSize="11"
                                       TextWrapping="Wrap" MaxLines="3"
                                       TextTrimming="CharacterEllipsis"
                                       Foreground="{StaticResource TextSecondaryBrush}"
                                       FontFamily="Menlo, Consolas, monospace"/>
                          </StackPanel>
                        </Border>
                      </DataTemplate>
                    </ItemsControl.ItemTemplate>
                  </ItemsControl>
                </StackPanel>
              </StackPanel>

              <!-- Anchors section (empty state + list) -->
              <StackPanel IsVisible="{Binding DetailPanel.ShowAnchors}" Spacing="12">
                <Border IsVisible="{Binding DetailPanel.AnchorsEmpty}"
                        Padding="20,28" CornerRadius="12"
                        Background="{StaticResource SurfaceMutedBrush}"
                        BorderBrush="{StaticResource DividerBrush}"
                        BorderThickness="1">
                  <StackPanel Spacing="10" HorizontalAlignment="Center">
                    <TextBlock Text="🔗" FontSize="32"
                               HorizontalAlignment="Center"/>
                    <TextBlock Text="No anchors yet"
                               FontSize="14" FontWeight="SemiBold"
                               Foreground="{StaticResource TextPrimaryBrush}"
                               HorizontalAlignment="Center"/>
                    <TextBlock TextWrapping="Wrap" TextAlignment="Center"
                               MaxWidth="320" FontSize="12"
                               Foreground="{StaticResource TextSecondaryBrush}"
                               Text="Every batch of synced events is hashed (SHA-256), stored on Greenfield, and the hash is anchored on BSC. Send a message to start the chain."/>
                  </StackPanel>
                </Border>

                <ItemsControl ItemsSource="{Binding DetailPanel.Anchors}">
                <ItemsControl.ItemTemplate>
                  <DataTemplate>
                    <Border Margin="0,0,0,10" Padding="14,12" CornerRadius="10"
                            Background="{StaticResource SurfaceMutedBrush}"
                            BorderBrush="{StaticResource DividerBrush}"
                            BorderThickness="1">
                      <StackPanel Spacing="6">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                          <Border Width="10" Height="10" CornerRadius="5"
                                  Background="{Binding StatusColor}"
                                  VerticalAlignment="Center"/>
                          <TextBlock Text="{Binding Status}"
                                     FontSize="12" FontWeight="SemiBold"
                                     Foreground="{StaticResource TextPrimaryBrush}"
                                     VerticalAlignment="Center"/>
                          <TextBlock Text="·" FontSize="11"
                                     Foreground="{StaticResource TextTertiaryBrush}"
                                     VerticalAlignment="Center"/>
                          <TextBlock Text="{Binding Range}"
                                     FontSize="11"
                                     Foreground="{StaticResource TextSecondaryBrush}"
                                     VerticalAlignment="Center"/>
                        </StackPanel>
                        <StackPanel Spacing="2">
                          <TextBlock FontSize="11"
                                     Foreground="{StaticResource TextSecondaryBrush}">
                            <Run Text="hash "/>
                            <Run Text="{Binding ShortHash}"
                                 FontFamily="Menlo, Consolas, monospace"
                                 Foreground="{StaticResource TextPrimaryBrush}"/>
                          </TextBlock>
                          <TextBlock FontSize="11"
                                     Foreground="{StaticResource TextSecondaryBrush}"
                                     IsVisible="{Binding HasBscTx}">
                            <Run Text="tx "/>
                            <Run Text="{Binding ShortTx}"
                                 FontFamily="Menlo, Consolas, monospace"
                                 Foreground="{StaticResource AccentClaudeBrush}"/>
                          </TextBlock>
                        </StackPanel>
                        <TextBlock Text="{Binding RelativeTime}"
                                   FontSize="10"
                                   Foreground="{StaticResource TextTertiaryBrush}"/>
                      </StackPanel>
                    </Border>
                  </DataTemplate>
                </ItemsControl.ItemTemplate>
              </ItemsControl>
              </StackPanel>

              <!-- Phase J.9: typed memory namespaces -->
              <StackPanel IsVisible="{Binding DetailPanel.ShowNamespaces}" Spacing="12">
                <Border IsVisible="{Binding DetailPanel.NamespacesEmpty}"
                        Padding="20,28" CornerRadius="12"
                        Background="{StaticResource SurfaceMutedBrush}"
                        BorderBrush="{StaticResource DividerBrush}"
                        BorderThickness="1">
                  <StackPanel Spacing="10" HorizontalAlignment="Center">
                    <TextBlock Text="🗂" FontSize="32" HorizontalAlignment="Center"/>
                    <TextBlock Text="Namespaces are empty"
                               FontSize="14" FontWeight="SemiBold"
                               Foreground="{StaticResource TextPrimaryBrush}"
                               HorizontalAlignment="Center"/>
                    <TextBlock TextWrapping="Wrap" TextAlignment="Center"
                               MaxWidth="320" FontSize="12"
                               Foreground="{StaticResource TextSecondaryBrush}"
                               Text="Episodes, Facts, Skills, Persona and Knowledge each live in their own VersionedStore. Chat with the twin to populate them."/>
                  </StackPanel>
                </Border>

                <ItemsControl ItemsSource="{Binding DetailPanel.NamespaceCards}">
                  <ItemsControl.ItemTemplate>
                    <DataTemplate>
                      <Border Margin="0,0,0,12" Padding="14,12" CornerRadius="10"
                              Background="{StaticResource SurfaceMutedBrush}"
                              BorderBrush="{StaticResource DividerBrush}"
                              BorderThickness="1">
                        <StackPanel Spacing="8">
                          <Grid ColumnDefinitions="*,Auto">
                            <TextBlock Grid.Column="0" Text="{Binding Title}"
                                       FontSize="13" FontWeight="SemiBold"
                                       Foreground="{StaticResource TextPrimaryBrush}"/>
                            <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="6">
                              <TextBlock FontSize="11"
                                         Foreground="{StaticResource TextSecondaryBrush}">
                                <Run Text="{Binding ItemCount}"/>
                                <Run Text=" items"/>
                              </TextBlock>
                              <TextBlock Text="·" FontSize="11"
                                         Foreground="{StaticResource TextTertiaryBrush}"/>
                              <TextBlock FontSize="11"
                                         Foreground="{StaticResource TextSecondaryBrush}">
                                <Run Text="{Binding VersionCount}"/>
                                <Run Text=" versions"/>
                              </TextBlock>
                            </StackPanel>
                          </Grid>
                          <TextBlock FontSize="10"
                                     Foreground="{StaticResource TextTertiaryBrush}"
                                     FontFamily="Menlo, Consolas, monospace">
                            <Run Text="@ "/>
                            <Run Text="{Binding CurrentVersionLabel}"/>
                          </TextBlock>
                          <ItemsControl ItemsSource="{Binding Items}"
                                        IsVisible="{Binding HasItems}">
                            <ItemsControl.ItemTemplate>
                              <DataTemplate>
                                <Border Margin="0,4,0,0" Padding="10,8" CornerRadius="6"
                                        Background="{StaticResource SurfaceMutedBrush}">
                                  <StackPanel Spacing="2">
                                    <TextBlock Text="{Binding Headline}"
                                               FontSize="12"
                                               TextTrimming="CharacterEllipsis"
                                               Foreground="{StaticResource TextPrimaryBrush}"/>
                                    <TextBlock Text="{Binding Subline}"
                                               FontSize="10"
                                               Foreground="{StaticResource TextTertiaryBrush}"
                                               TextTrimming="CharacterEllipsis"/>
                                  </StackPanel>
                                </Border>
                              </DataTemplate>
                            </ItemsControl.ItemTemplate>
                          </ItemsControl>
                        </StackPanel>
                      </Border>
                    </DataTemplate>
                  </ItemsControl.ItemTemplate>
                </ItemsControl>
              </StackPanel>

              <!-- Phase O.5/O.6: falsifiable evolution timeline -->
              <StackPanel IsVisible="{Binding DetailPanel.ShowEvolution}" Spacing="12">
                <Border IsVisible="{Binding DetailPanel.EvolutionEmpty}"
                        Padding="20,28" CornerRadius="12"
                        Background="{StaticResource SurfaceMutedBrush}"
                        BorderBrush="{StaticResource DividerBrush}"
                        BorderThickness="1">
                  <StackPanel Spacing="10" HorizontalAlignment="Center">
                    <TextBlock Text="🧬" FontSize="32" HorizontalAlignment="Center"/>
                    <TextBlock Text="No evolution events yet"
                               FontSize="14" FontWeight="SemiBold"
                               Foreground="{StaticResource TextPrimaryBrush}"
                               HorizontalAlignment="Center"/>
                    <TextBlock TextWrapping="Wrap" TextAlignment="Center"
                               MaxWidth="320" FontSize="12"
                               Foreground="{StaticResource TextSecondaryBrush}"
                               Text="Every persona / memory / skill / knowledge edit is logged as a Proposal, then graded as a Verdict (kept / warning / reverted) once the observation window elapses. Reverts roll the namespace store back."/>
                  </StackPanel>
                </Border>

                <UniformGrid Columns="4"
                             IsVisible="{Binding !DetailPanel.EvolutionEmpty}"
                             Margin="0,0,0,4">
                  <StackPanel HorizontalAlignment="Center">
                    <TextBlock Text="{Binding DetailPanel.EvolutionProposalCount}"
                               FontSize="18" FontWeight="Bold"
                               Foreground="{StaticResource TextPrimaryBrush}"
                               HorizontalAlignment="Center"/>
                    <TextBlock Text="proposed" FontSize="10"
                               Foreground="{StaticResource TextTertiaryBrush}"
                               HorizontalAlignment="Center"/>
                  </StackPanel>
                  <StackPanel HorizontalAlignment="Center">
                    <TextBlock Text="{Binding DetailPanel.EvolutionVerdictCount}"
                               FontSize="18" FontWeight="Bold"
                               Foreground="{StaticResource TextPrimaryBrush}"
                               HorizontalAlignment="Center"/>
                    <TextBlock Text="verdicts" FontSize="10"
                               Foreground="{StaticResource TextTertiaryBrush}"
                               HorizontalAlignment="Center"/>
                  </StackPanel>
                  <StackPanel HorizontalAlignment="Center">
                    <TextBlock Text="{Binding DetailPanel.EvolutionRevertCount}"
                               FontSize="18" FontWeight="Bold"
                               Foreground="{StaticResource TextPrimaryBrush}"
                               HorizontalAlignment="Center"/>
                    <TextBlock Text="reverted" FontSize="10"
                               Foreground="{StaticResource TextTertiaryBrush}"
                               HorizontalAlignment="Center"/>
                  </StackPanel>
                  <StackPanel HorizontalAlignment="Center">
                    <TextBlock Text="{Binding DetailPanel.EvolutionPendingCount}"
                               FontSize="18" FontWeight="Bold"
                               Foreground="{StaticResource WarningBrush}"
                               HorizontalAlignment="Center"/>
                    <TextBlock Text="pending" FontSize="10"
                               Foreground="{StaticResource TextTertiaryBrush}"
                               HorizontalAlignment="Center"/>
                  </StackPanel>
                </UniformGrid>

                <ItemsControl ItemsSource="{Binding DetailPanel.EvolutionRows}">
                  <ItemsControl.ItemTemplate>
                    <DataTemplate>
                      <Border Margin="0,0,0,8" Padding="12,10" CornerRadius="8"
                              Background="{StaticResource SurfaceMutedBrush}"
                              BorderBrush="{StaticResource DividerBrush}"
                              BorderThickness="1">
                        <StackPanel Spacing="6">
                          <StackPanel Orientation="Horizontal" Spacing="8">
                            <Border Width="10" Height="10" CornerRadius="5"
                                    Background="{Binding AccentColor}"
                                    VerticalAlignment="Center"/>
                            <TextBlock Text="{Binding DisplayKind}"
                                       FontSize="12" FontWeight="SemiBold"
                                       Foreground="{StaticResource TextPrimaryBrush}"
                                       VerticalAlignment="Center"/>
                            <TextBlock Text="·" FontSize="11"
                                       Foreground="{StaticResource TextTertiaryBrush}"
                                       VerticalAlignment="Center"/>
                            <TextBlock Text="{Binding Evolver}"
                                       FontSize="11"
                                       Foreground="{StaticResource TextSecondaryBrush}"
                                       VerticalAlignment="Center"/>
                            <TextBlock Text="→" FontSize="11"
                                       Foreground="{StaticResource TextTertiaryBrush}"
                                       VerticalAlignment="Center"/>
                            <TextBlock Text="{Binding Target}"
                                       FontSize="11"
                                       Foreground="{StaticResource TextSecondaryBrush}"
                                       VerticalAlignment="Center"/>
                          </StackPanel>
                          <TextBlock Text="{Binding Summary}"
                                     FontSize="12"
                                     TextWrapping="Wrap"
                                     Foreground="{StaticResource TextPrimaryBrush}"/>
                          <Grid ColumnDefinitions="*,Auto">
                            <TextBlock Grid.Column="0"
                                       Text="{Binding RelativeTime}"
                                       FontSize="10"
                                       Foreground="{StaticResource TextTertiaryBrush}"
                                       VerticalAlignment="Center"/>
                            <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="6"
                                        IsVisible="{Binding CanModerate}">
                              <Button Content="Approve"
                                      Classes="ghost" FontSize="11"
                                      Command="{Binding $parent[ItemsControl].DataContext.ApproveEditCommand}"
                                      CommandParameter="{Binding EditId}"/>
                              <Button Content="Revert"
                                      Classes="ghost" FontSize="11"
                                      Foreground="{StaticResource ErrorBrush}"
                                      Command="{Binding $parent[ItemsControl].DataContext.RevertEditCommand}"
                                      CommandParameter="{Binding EditId}"/>
                            </StackPanel>
                          </Grid>
                        </StackPanel>
                      </Border>
                    </DataTemplate>
                  </ItemsControl.ItemTemplate>
                </ItemsControl>
              </StackPanel>

              <!-- Progress (planning + activity) -->
              <StackPanel IsVisible="{Binding DetailPanel.ShowProgress}" Spacing="10">
                <Border IsVisible="{Binding DetailPanel.ProgressEmpty}"
                        Padding="20,28" CornerRadius="12"
                        Background="{StaticResource SurfaceMutedBrush}"
                        BorderBrush="{StaticResource DividerBrush}"
                        BorderThickness="1">
                  <StackPanel Spacing="10" HorizontalAlignment="Center">
                    <TextBlock Text="📋" FontSize="32" HorizontalAlignment="Center"/>
                    <TextBlock Text="Nothing scheduled yet"
                               FontSize="14" FontWeight="SemiBold"
                               Foreground="{StaticResource TextPrimaryBrush}"
                               HorizontalAlignment="Center"/>
                    <TextBlock TextWrapping="Wrap" TextAlignment="Center"
                               MaxWidth="320" FontSize="12"
                               Foreground="{StaticResource TextSecondaryBrush}"
                               Text="Pending evolution proposals appear here while the verdict window is open. Completed turns and chain anchors stack below."/>
                  </StackPanel>
                </Border>
                <ItemsControl ItemsSource="{Binding DetailPanel.ProgressItems}">
                  <ItemsControl.ItemTemplate>
                    <DataTemplate>
                      <Border Margin="0,0,0,6" Padding="12,10" CornerRadius="8"
                              Background="{StaticResource SurfaceMutedBrush}"
                              BorderBrush="{StaticResource DividerBrush}"
                              BorderThickness="1">
                        <Grid ColumnDefinitions="Auto,*">
                          <Border Grid.Column="0" Width="22" Height="22"
                                  CornerRadius="11" Margin="0,0,10,0"
                                  Background="{Binding AccentColor}"
                                  VerticalAlignment="Top">
                            <TextBlock Text="{Binding StatusGlyph}"
                                       FontSize="13" FontWeight="Bold"
                                       Foreground="White"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"/>
                          </Border>
                          <StackPanel Grid.Column="1" Spacing="2">
                            <TextBlock Text="{Binding Title}"
                                       FontSize="13" FontWeight="SemiBold"
                                       Foreground="{StaticResource TextPrimaryBrush}"
                                       TextTrimming="CharacterEllipsis"/>
                            <TextBlock Text="{Binding Subtitle}"
                                       FontSize="11"
                                       Foreground="{StaticResource TextSecondaryBrush}"
                                       TextWrapping="Wrap"
                                       MaxLines="2"
                                       TextTrimming="CharacterEllipsis"/>
                            <TextBlock Text="{Binding RelativeTime}"
                                       FontSize="10"
                                       Foreground="{StaticResource TextTertiaryBrush}"/>
                          </StackPanel>
                        </Grid>
                      </Border>
                    </DataTemplate>
                  </ItemsControl.ItemTemplate>
                </ItemsControl>
              </StackPanel>

              <!-- Work directory (Greenfield bucket tree) -->
              <StackPanel IsVisible="{Binding DetailPanel.ShowWorkdir}" Spacing="10">
                <TextBlock Text="{Binding DetailPanel.WorkdirHeading}"
                           FontSize="11"
                           FontFamily="Menlo, Consolas, monospace"
                           Foreground="{StaticResource TextSecondaryBrush}"
                           IsVisible="{Binding !DetailPanel.WorkdirEmpty}"/>
                <Border IsVisible="{Binding DetailPanel.WorkdirEmpty}"
                        Padding="20,28" CornerRadius="12"
                        Background="{StaticResource SurfaceMutedBrush}"
                        BorderBrush="{StaticResource DividerBrush}"
                        BorderThickness="1">
                  <StackPanel Spacing="10" HorizontalAlignment="Center">
                    <TextBlock Text="🗂" FontSize="32" HorizontalAlignment="Center"/>
                    <TextBlock Text="Bucket is empty"
                               FontSize="14" FontWeight="SemiBold"
                               Foreground="{StaticResource TextPrimaryBrush}"
                               HorizontalAlignment="Center"/>
                    <TextBlock TextWrapping="Wrap" TextAlignment="Center"
                               MaxWidth="320" FontSize="12"
                               Foreground="{StaticResource TextSecondaryBrush}"
                               Text="When the twin runs in chain mode, every memory entry, persona / skill / knowledge artifact and session checkpoint shows up here."/>
                  </StackPanel>
                </Border>
                <ItemsControl ItemsSource="{Binding DetailPanel.WorkdirRoots}">
                  <ItemsControl.ItemTemplate>
                    <DataTemplate>
                      <Border Margin="0,0,0,8" Padding="10,8" CornerRadius="8"
                              Background="{StaticResource SurfaceMutedBrush}"
                              BorderBrush="{StaticResource DividerBrush}"
                              BorderThickness="1">
                        <StackPanel>
                          <StackPanel Orientation="Horizontal" Spacing="8">
                            <TextBlock Text="{Binding Glyph}" FontSize="13"
                                       VerticalAlignment="Center"/>
                            <TextBlock Text="{Binding Name}"
                                       FontSize="12" FontWeight="SemiBold"
                                       FontFamily="Menlo, Consolas, monospace"
                                       Foreground="{StaticResource TextPrimaryBrush}"
                                       VerticalAlignment="Center"/>
                          </StackPanel>
                          <TextBlock Text="{Binding Subtitle}"
                                     FontSize="10" Margin="22,2,0,0"
                                     Foreground="{StaticResource TextTertiaryBrush}"
                                     TextTrimming="CharacterEllipsis"/>
                          <ItemsControl ItemsSource="{Binding Children}"
                                        Margin="14,4,0,0"
                                        IsVisible="{Binding HasChildren}">
                            <ItemsControl.ItemTemplate>
                              <DataTemplate>
                                <StackPanel>
                                  <StackPanel Orientation="Horizontal" Spacing="6"
                                              Margin="0,3,0,0">
                                    <TextBlock Text="{Binding Glyph}" FontSize="11"
                                               VerticalAlignment="Center"/>
                                    <TextBlock Text="{Binding Name}"
                                               FontSize="11"
                                               FontFamily="Menlo, Consolas, monospace"
                                               Foreground="{StaticResource TextPrimaryBrush}"
                                               VerticalAlignment="Center"
                                               TextTrimming="CharacterEllipsis"/>
                                  </StackPanel>
                                  <TextBlock Text="{Binding Subtitle}"
                                             FontSize="9" Margin="18,1,0,0"
                                             Foreground="{StaticResource TextTertiaryBrush}"
                                             TextTrimming="CharacterEllipsis"
                                             MaxLines="1"/>
                                  <!-- 1-level deep nested children (e.g. session_/) -->
                                  <ItemsControl ItemsSource="{Binding Children}"
                                                Margin="14,2,0,0"
                                                IsVisible="{Binding HasChildren}">
                                    <ItemsControl.ItemTemplate>
                                      <DataTemplate>
                                        <StackPanel Orientation="Horizontal" Spacing="6"
                                                    Margin="0,2,0,0">
                                          <TextBlock Text="{Binding Glyph}" FontSize="10"/>
                                          <TextBlock Text="{Binding Name}" FontSize="10"
                                                     FontFamily="Menlo, Consolas, monospace"
                                                     Foreground="{StaticResource TextSecondaryBrush}"
                                                     TextTrimming="CharacterEllipsis"/>
                                        </StackPanel>
                                      </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                  </ItemsControl>
                                </StackPanel>
                              </DataTemplate>
                            </ItemsControl.ItemTemplate>
                          </ItemsControl>
                        </StackPanel>
                      </Border>
                    </DataTemplate>
                  </ItemsControl.ItemTemplate>
                </ItemsControl>
              </StackPanel>

              <!-- Thinking (inner monologue) -->
              <StackPanel IsVisible="{Binding DetailPanel.ShowThinking}" Spacing="8">
                <StackPanel Orientation="Horizontal" Spacing="6">
                  <Border Width="6" Height="6" CornerRadius="3"
                          Background="#7DBC68" VerticalAlignment="Center"
                          IsVisible="{Binding DetailPanel.ThinkingPolling}"/>
                  <TextBlock FontSize="10"
                             Foreground="{StaticResource TextTertiaryBrush}"
                             VerticalAlignment="Center"
                             IsVisible="{Binding DetailPanel.ThinkingPolling}"
                             Text="auto-refreshing every 2s"/>
                </StackPanel>
                <Border IsVisible="{Binding DetailPanel.ThinkingEmpty}"
                        Padding="20,28" CornerRadius="12"
                        Background="{StaticResource SurfaceMutedBrush}"
                        BorderBrush="{StaticResource DividerBrush}"
                        BorderThickness="1">
                  <StackPanel Spacing="10" HorizontalAlignment="Center">
                    <TextBlock Text="🧠" FontSize="32" HorizontalAlignment="Center"/>
                    <TextBlock Text="Quiet mind"
                               FontSize="14" FontWeight="SemiBold"
                               Foreground="{StaticResource TextPrimaryBrush}"
                               HorizontalAlignment="Center"/>
                    <TextBlock TextWrapping="Wrap" TextAlignment="Center"
                               MaxWidth="320" FontSize="12"
                               Foreground="{StaticResource TextSecondaryBrush}"
                               Text="No thinking steps recorded yet. Send a message — the agent's contract checks, memory recall, evolution proposals and final reply all show up here as they happen."/>
                  </StackPanel>
                </Border>
                <ItemsControl ItemsSource="{Binding DetailPanel.ThinkingSteps}">
                  <ItemsControl.ItemTemplate>
                    <DataTemplate>
                      <Border Margin="0,0,0,6" Padding="12,10" CornerRadius="8"
                              Background="{StaticResource SurfaceMutedBrush}"
                              BorderBrush="{StaticResource DividerBrush}"
                              BorderThickness="1">
                        <Grid ColumnDefinitions="Auto,*">
                          <Border Grid.Column="0" Width="26" Height="26"
                                  CornerRadius="13" Margin="0,0,10,0"
                                  Background="{Binding AccentColor}"
                                  VerticalAlignment="Top">
                            <TextBlock Text="{Binding Glyph}"
                                       FontSize="13"
                                       Foreground="White"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"/>
                          </Border>
                          <StackPanel Grid.Column="1" Spacing="3">
                            <TextBlock Text="{Binding Label}"
                                       FontSize="12" FontWeight="SemiBold"
                                       Foreground="{StaticResource TextPrimaryBrush}"
                                       TextTrimming="CharacterEllipsis"/>
                            <TextBlock Text="{Binding Content}"
                                       FontSize="11"
                                       Foreground="{StaticResource TextSecondaryBrush}"
                                       TextWrapping="Wrap"
                                       MaxLines="3"
                                       TextTrimming="CharacterEllipsis"/>
                            <TextBlock Text="{Binding RelativeTime}"
                                       FontSize="10"
                                       Foreground="{StaticResource TextTertiaryBrush}"/>
                          </StackPanel>
                        </Grid>
                      </Border>
                    </DataTemplate>
                  </ItemsControl.ItemTemplate>
                </ItemsControl>
              </StackPanel>

              <!-- Phase D 续 / #159 v3 — Brain detail slide-over
                   retired. All sections (Brain at a Glance,
                   Learning Timeline, Data Flow, Just Learned,
                   Chain Health) are now in the always-visible
                   Cognition right column. ShowBrain mode kept
                   on the enum so any stragglers fall through to
                   the parent Loading state instead of erroring. -->

              <!-- Loading -->
              <TextBlock Text="Loading…" FontSize="12"
                         Foreground="{StaticResource TextTertiaryBrush}"
                         IsVisible="{Binding DetailPanel.IsLoading}"
                         HorizontalAlignment="Center" Margin="0,40"/>
            </Panel>
          </ScrollViewer>
        </Grid>
      </Border>
    </Panel>
  </Panel>
</UserControl>
