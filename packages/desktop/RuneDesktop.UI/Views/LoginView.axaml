<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="RuneDesktop.UI.Views.LoginView"
             Background="{StaticResource SurfaceBaseBrush}">

  <Panel>
    <!-- Flat dark canvas. The old purple gradient was a hand-off cue
         to the passkey browser page, but post-HIG we want the desktop
         to feel like a native macOS welcome sheet — calm, dark, no
         theatrical colour. The browser page can keep its own
         branding; the seam is fine. -->
    <Border Background="{StaticResource SurfaceBaseBrush}"/>

    <!-- Gear icon: re-opens the Welcome wizard so the user can switch
         which Nexus server they connect to without reinstalling. -->
    <Button HorizontalAlignment="Right" VerticalAlignment="Top"
            Margin="0,12,12,0"
            Classes="toolbar"
            FontSize="16"
            Command="{Binding OpenSettingsCommand}"
            ToolTip.Tip="Change server URL">
      <TextBlock Text="⚙"
                 Foreground="{StaticResource TextSecondaryBrush}"/>
    </Button>

    <!-- Welcome sheet. macOS HIG: centred card with 14 px corner
         radius (matches NSWindow sheet style), soft shadow, hairline
         border. No coloured glow. -->
    <Border HorizontalAlignment="Center" VerticalAlignment="Center"
            Width="380" Padding="40,42" CornerRadius="14"
            Background="{StaticResource SurfaceCardBrush}"
            BorderBrush="{StaticResource DividerBrush}" BorderThickness="1"
            BoxShadow="0 12 36 0 #66000000">
      <StackPanel Spacing="28">
        <StackPanel Spacing="14" HorizontalAlignment="Center">
          <!-- #185 — branded logo tile. Matches the passkey login
               page exactly: 72px deep-navy square + BNB-yellow N. -->
          <Border Width="72" Height="72" CornerRadius="16"
                  HorizontalAlignment="Center"
                  Background="#0F1729">
            <TextBlock Text="N" FontSize="40" FontWeight="Bold"
                       Foreground="#F0B90B"
                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
          </Border>
          <TextBlock Text="Nexus"
                     FontSize="22" FontWeight="SemiBold"
                     Foreground="{StaticResource TextPrimaryBrush}"
                     HorizontalAlignment="Center"/>
          <TextBlock Text="Your AI agent, your data."
                     FontSize="13"
                     Foreground="{StaticResource TextSecondaryBrush}"
                     HorizontalAlignment="Center"/>
        </StackPanel>

        <StackPanel Spacing="12">
          <!-- Primary CTA. macOS sheet primary buttons are full-width
               filled .accent at 6 px radius (we keep `pill` off this
               one — the rounded-rect is the standard sheet style). -->
          <Button Content="Get Started"
                  Command="{Binding LoginWithPasskeyCommand}"
                  Classes="accent"
                  HorizontalAlignment="Stretch" HorizontalContentAlignment="Center"
                  Padding="0,12" FontSize="14"
                  IsEnabled="{Binding !IsLoading}"/>

          <StackPanel Spacing="8" IsVisible="{Binding IsLoading}">
            <TextBlock Text="Continue in your browser to verify with Passkey…"
                       Foreground="{StaticResource TextSecondaryBrush}"
                       FontSize="13" TextWrapping="Wrap"
                       HorizontalAlignment="Center" TextAlignment="Center"/>
            <Button Content="Cancel" Command="{Binding CancelPasskeyCommand}"
                    Classes="ghost" HorizontalAlignment="Center"
                    FontSize="13"/>
          </StackPanel>

          <Border Background="#26FF453A" CornerRadius="6" Padding="12,8"
                  IsVisible="{Binding ErrorMessage,
                            Converter={x:Static StringConverters.IsNotNullOrEmpty}}">
            <TextBlock Text="{Binding ErrorMessage}"
                       Foreground="{StaticResource ErrorBrush}"
                       FontSize="12" TextWrapping="Wrap"/>
          </Border>
        </StackPanel>

        <TextBlock Text="Powered by BNB Chain"
                   Foreground="{StaticResource TextTertiaryBrush}"
                   FontSize="11" HorizontalAlignment="Center"/>
      </StackPanel>
    </Border>
  </Panel>
</UserControl>
