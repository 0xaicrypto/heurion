<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:RuneDesktop.UI.ViewModels"
             xmlns:svc="using:RuneDesktop.Core.Services"
             x:Class="RuneDesktop.UI.Views.PatientsView"
             x:DataType="vm:PatientsViewModel">

  <!--
    #182 Phase 1 — full-roster Patients view, Editorial × Apple HIG.
    Spec: DESIGN_SYSTEM_v2.md §10.

    Layout: Editorial Two-Pane
      - Left  340 px : filterable patient list
      - Mid     1 px : Hairline divider
      - Right  flex  : full detail with eyebrow-sectioned content
    Header spans both, generous Space6 padding.

    Signature elements applied:
      * LargeTitle hero with SF Pro Display + tightened tracking
      * Eyebrow tag (microscopic uppercase) before every major section
      * Double-Bezel demographics card (outer paper shell + inner white core)
      * Selected row gets AccentTint bg + left 2px Accent bar
      * macro-whitespace — Space12 (48) for section padding, Space5 (20) inside cards
      * Mono font for PHI hash / MRN; SF Pro Display for hero
  -->

  <Grid Background="{StaticResource SurfaceBaseBrush}"
        ColumnDefinitions="340,1,*"
        RowDefinitions="Auto,*">

    <!-- ── HEADER (full-width) ─────────────────────────────────── -->
    <Border Grid.Row="0" Grid.ColumnSpan="3"
            Padding="32,24,32,20"
            BorderThickness="0,0,0,1"
            BorderBrush="{StaticResource DividerBrush}">
      <DockPanel>
        <StackPanel DockPanel.Dock="Left" Spacing="4">
          <TextBlock Text="PATIENT ROSTER"
                     Classes="eyebrow"/>
          <DockPanel>
            <TextBlock DockPanel.Dock="Left"
                       Text="Patients"
                       Classes="display"
                       FontSize="{StaticResource FontSizeTitle1}"
                       FontWeight="Bold"
                       Foreground="{StaticResource TextPrimaryBrush}"/>
            <TextBlock DockPanel.Dock="Left"
                       VerticalAlignment="Bottom"
                       Margin="14,0,0,8"
                       FontSize="{StaticResource FontSizeBody}"
                       Foreground="{StaticResource TextTertiaryBrush}">
              <Run Text="{Binding Patients.Count}"/><Run Text=" on file"/>
            </TextBlock>
            <Panel/>
          </DockPanel>
        </StackPanel>

        <!-- Right-aligned actions: search + new + refresh -->
        <StackPanel DockPanel.Dock="Right"
                    Orientation="Horizontal"
                    Spacing="10"
                    VerticalAlignment="Center">
          <TextBox Text="{Binding SearchQuery, Mode=TwoWay}"
                   Watermark="Search hash / initials / MRN / complaint"
                   Width="320"
                   FontSize="{StaticResource FontSizeBody}"
                   Background="{StaticResource SurfaceCardBrush}"
                   BorderBrush="{StaticResource DividerBrush}"
                   CornerRadius="10"
                   Padding="14,9"/>
          <Button Command="{Binding RefreshAsyncCommand}"
                  Classes="ghost"
                  Padding="10,8"
                  ToolTip.Tip="Refresh roster">
            <TextBlock Text="↻" FontSize="14"/>
          </Button>
        </StackPanel>
        <Panel/>
      </DockPanel>
    </Border>

    <!-- ── LEFT: roster list ───────────────────────────────────── -->
    <ScrollViewer Grid.Row="1" Grid.Column="0"
                  Padding="16,16,12,24"
                  VerticalScrollBarVisibility="Auto">
      <Grid>

        <!-- Empty state -->
        <StackPanel IsVisible="{Binding !Patients.Count}"
                    Spacing="14"
                    HorizontalAlignment="Center"
                    Margin="20,80,20,0">
          <TextBlock Text="—"
                     FontSize="32"
                     FontWeight="Light"
                     HorizontalAlignment="Center"
                     Foreground="{StaticResource TextTertiaryBrush}"/>
          <TextBlock Text="No patients yet"
                     FontSize="{StaticResource FontSizeHeadline}"
                     FontWeight="SemiBold"
                     HorizontalAlignment="Center"
                     Foreground="{StaticResource TextPrimaryBrush}"/>
          <TextBlock TextAlignment="Center"
                     FontSize="{StaticResource FontSizeSmall}"
                     TextWrapping="Wrap"
                     MaxWidth="240"
                     Foreground="{StaticResource TextSecondaryBrush}"
                     Text="Click + New patient in the left rail to register a case, or upload a DICOM study — both populate this roster."/>
        </StackPanel>

        <!-- Roster items -->
        <ItemsControl ItemsSource="{Binding FilteredPatients}"
                      IsVisible="{Binding Patients.Count}">
          <ItemsControl.ItemTemplate>
            <DataTemplate DataType="svc:PatientDetail">
              <Button Classes="ghost"
                      Padding="0"
                      Margin="0,0,0,4"
                      HorizontalAlignment="Stretch"
                      HorizontalContentAlignment="Stretch"
                      Command="{Binding $parent[ItemsControl].DataContext.SelectPatientCommand}"
                      CommandParameter="{Binding}">
                <Grid ColumnDefinitions="3,*">
                  <!-- Selected accent bar (left edge). 0 width by
                       default; non-zero when this row is the selected
                       patient. Implementation note: pure StaticResource
                       binding for now; selected-state styling lands when
                       we wire row IsSelected via attached behavior
                       (deferred to Phase 1.1). -->
                  <Border Grid.Column="0"
                          Background="Transparent"/>
                  <Border Grid.Column="1"
                          Padding="14,11,14,12"
                          CornerRadius="10"
                          BorderThickness="1"
                          BorderBrush="{StaticResource DividerBrush}"
                          Background="{StaticResource SurfaceCardBrush}">
                    <Grid ColumnDefinitions="*,Auto" RowDefinitions="Auto,Auto,Auto">

                      <!-- Initials -->
                      <TextBlock Grid.Column="0" Grid.Row="0"
                                 Text="{Binding Initials}"
                                 FontSize="{StaticResource FontSizeCallout}"
                                 FontWeight="SemiBold"
                                 Foreground="{StaticResource TextPrimaryBrush}"/>

                      <!-- Source pill (manual / dicom / both) -->
                      <Border Grid.Column="1" Grid.Row="0"
                              VerticalAlignment="Center"
                              Padding="6,2"
                              CornerRadius="999"
                              Background="{StaticResource AccentTintBrush}">
                        <TextBlock Text="{Binding Source}"
                                   FontSize="9"
                                   FontWeight="SemiBold"
                                   LetterSpacing="0.8"
                                   Foreground="{StaticResource AccentBrush}"/>
                      </Border>

                      <!-- Hash mono -->
                      <TextBlock Grid.Column="0" Grid.Row="1"
                                 Grid.ColumnSpan="2"
                                 Classes="mono"
                                 Text="{Binding PatientHash}"
                                 FontSize="10"
                                 Margin="0,3,0,0"
                                 TextTrimming="CharacterEllipsis"/>

                      <!-- Demographics line -->
                      <TextBlock Grid.Column="0" Grid.Row="2"
                                 Grid.ColumnSpan="2"
                                 FontSize="{StaticResource FontSizeSmall}"
                                 Margin="0,8,0,0"
                                 Foreground="{StaticResource TextSecondaryBrush}">
                        <Run Text="{Binding Sex}"/><Run Text=" · "/><Run Text="{Binding AgeGroup}"/><Run Text=" · "/><Run Text="{Binding StudyCount}"/><Run Text=" studies"/>
                      </TextBlock>
                    </Grid>
                  </Border>
                </Grid>
              </Button>
            </DataTemplate>
          </ItemsControl.ItemTemplate>
        </ItemsControl>
      </Grid>
    </ScrollViewer>

    <!-- ── DIVIDER (hairline) ──────────────────────────────────── -->
    <Border Grid.Row="1" Grid.Column="1"
            Background="{StaticResource DividerBrush}"/>

    <!-- ── RIGHT: detail pane ──────────────────────────────────── -->
    <ScrollViewer Grid.Row="1" Grid.Column="2"
                  Padding="48,40,48,40"
                  VerticalScrollBarVisibility="Auto">
      <Grid MaxWidth="720" HorizontalAlignment="Left">

        <!-- No selection -->
        <StackPanel IsVisible="{Binding SelectedPatient,
                                Converter={x:Static ObjectConverters.IsNull}}"
                    Spacing="12"
                    HorizontalAlignment="Center"
                    Margin="0,80,0,0">
          <TextBlock Text="Select a patient from the list."
                     FontSize="{StaticResource FontSizeCallout}"
                     Foreground="{StaticResource TextTertiaryBrush}"
                     HorizontalAlignment="Center"/>
        </StackPanel>

        <!-- Detail -->
        <StackPanel Spacing="32"
                    IsVisible="{Binding SelectedPatient,
                                Converter={x:Static ObjectConverters.IsNotNull}}">

          <!-- HERO -->
          <StackPanel Spacing="6">
            <TextBlock Text="PATIENT"
                       Classes="eyebrow"/>
            <StackPanel Orientation="Horizontal" Spacing="16">
              <TextBlock Text="{Binding SelectedPatient.Initials}"
                         Classes="display"
                         FontSize="{StaticResource FontSizeLargeTitle}"
                         FontWeight="Bold"
                         Foreground="{StaticResource TextPrimaryBrush}"/>
              <TextBlock Classes="mono"
                         Text="{Binding SelectedPatient.PatientHash}"
                         VerticalAlignment="Bottom"
                         Margin="0,0,0,10"
                         FontSize="{StaticResource FontSizeBody}"/>
            </StackPanel>
            <TextBlock FontSize="{StaticResource FontSizeCallout}"
                       Foreground="{StaticResource TextSecondaryBrush}"
                       Margin="0,2,0,0">
              <Run Text="{Binding SelectedPatient.Sex}"/><Run Text=" · "/><Run Text="{Binding SelectedPatient.AgeGroup}"/><Run Text=" · "/><Run Text="{Binding SelectedPatient.StudyCount}"/><Run Text=" studies on file"/>
            </TextBlock>
          </StackPanel>

          <!-- CHIEF COMPLAINT -->
          <StackPanel Spacing="10"
                      IsVisible="{Binding SelectedPatient.ChiefComplaint,
                                  Converter={x:Static StringConverters.IsNotNullOrEmpty}}">
            <TextBlock Text="CHIEF COMPLAINT"
                       Classes="eyebrow"/>
            <!-- Double-Bezel: outer paper shell + inner white core -->
            <Border Padding="1.5"
                    CornerRadius="14"
                    Background="{StaticResource SurfaceBaseBrush}"
                    BorderBrush="{StaticResource DividerBrush}"
                    BorderThickness="1">
              <Border Padding="20,16"
                      CornerRadius="12"
                      Background="{StaticResource SurfaceCardBrush}">
                <TextBlock Text="{Binding SelectedPatient.ChiefComplaint}"
                           FontSize="{StaticResource FontSizeCallout}"
                           LineHeight="22"
                           TextWrapping="Wrap"
                           Foreground="{StaticResource TextPrimaryBrush}"/>
              </Border>
            </Border>
          </StackPanel>

          <!-- DEMOGRAPHICS — Double-Bezel -->
          <StackPanel Spacing="10">
            <TextBlock Text="DEMOGRAPHICS"
                       Classes="eyebrow"/>
            <Border Padding="1.5"
                    CornerRadius="14"
                    Background="{StaticResource SurfaceBaseBrush}"
                    BorderBrush="{StaticResource DividerBrush}"
                    BorderThickness="1">
              <Border Padding="20,16"
                      CornerRadius="12"
                      Background="{StaticResource SurfaceCardBrush}">
                <Grid ColumnDefinitions="140,*"
                      RowDefinitions="Auto,Auto,Auto,Auto,Auto">

                  <TextBlock Grid.Column="0" Grid.Row="0"
                             Text="Initials"
                             FontSize="{StaticResource FontSizeSmall}"
                             Foreground="{StaticResource TextSecondaryBrush}"/>
                  <TextBlock Grid.Column="1" Grid.Row="0"
                             Text="{Binding SelectedPatient.Initials}"
                             FontSize="{StaticResource FontSizeCallout}"
                             FontWeight="Medium"
                             Foreground="{StaticResource TextPrimaryBrush}"/>

                  <TextBlock Grid.Column="0" Grid.Row="1"
                             Text="MRN"
                             FontSize="{StaticResource FontSizeSmall}"
                             Margin="0,10,0,0"
                             Foreground="{StaticResource TextSecondaryBrush}"/>
                  <TextBlock Grid.Column="1" Grid.Row="1"
                             Classes="mono"
                             Text="{Binding SelectedPatient.Mrn}"
                             FontSize="{StaticResource FontSizeCallout}"
                             Margin="0,10,0,0"
                             Foreground="{StaticResource TextPrimaryBrush}"/>

                  <TextBlock Grid.Column="0" Grid.Row="2"
                             Text="Age"
                             FontSize="{StaticResource FontSizeSmall}"
                             Margin="0,10,0,0"
                             Foreground="{StaticResource TextSecondaryBrush}"/>
                  <TextBlock Grid.Column="1" Grid.Row="2"
                             FontSize="{StaticResource FontSizeCallout}"
                             Margin="0,10,0,0"
                             Foreground="{StaticResource TextPrimaryBrush}">
                    <Run Text="{Binding SelectedPatient.AgeValue}"/><Run Text="  "/><Run Text="("/><Run Text="{Binding SelectedPatient.AgeGroup}"/><Run Text=")"/>
                  </TextBlock>

                  <TextBlock Grid.Column="0" Grid.Row="3"
                             Text="Sex"
                             FontSize="{StaticResource FontSizeSmall}"
                             Margin="0,10,0,0"
                             Foreground="{StaticResource TextSecondaryBrush}"/>
                  <TextBlock Grid.Column="1" Grid.Row="3"
                             Text="{Binding SelectedPatient.Sex}"
                             FontSize="{StaticResource FontSizeCallout}"
                             Margin="0,10,0,0"
                             Foreground="{StaticResource TextPrimaryBrush}"/>

                  <TextBlock Grid.Column="0" Grid.Row="4"
                             Text="Source"
                             FontSize="{StaticResource FontSizeSmall}"
                             Margin="0,10,0,0"
                             Foreground="{StaticResource TextSecondaryBrush}"/>
                  <StackPanel Grid.Column="1" Grid.Row="4"
                              Orientation="Horizontal" Spacing="6"
                              Margin="0,10,0,0">
                    <Ellipse Width="6" Height="6"
                             Fill="{StaticResource AccentBrush}"
                             VerticalAlignment="Center"/>
                    <TextBlock Text="{Binding SelectedPatient.Source}"
                               FontSize="{StaticResource FontSizeCallout}"
                               Foreground="{StaticResource TextPrimaryBrush}"/>
                  </StackPanel>

                </Grid>
              </Border>
            </Border>
          </StackPanel>

          <!-- NOTES -->
          <StackPanel Spacing="10"
                      IsVisible="{Binding SelectedPatient.Notes,
                                  Converter={x:Static StringConverters.IsNotNullOrEmpty}}">
            <TextBlock Text="NOTES"
                       Classes="eyebrow"/>
            <Border Padding="1.5"
                    CornerRadius="14"
                    Background="{StaticResource SurfaceBaseBrush}"
                    BorderBrush="{StaticResource DividerBrush}"
                    BorderThickness="1">
              <Border Padding="20,16"
                      CornerRadius="12"
                      Background="{StaticResource SurfaceCardBrush}">
                <TextBlock Text="{Binding SelectedPatient.Notes}"
                           FontSize="{StaticResource FontSizeBody}"
                           LineHeight="20"
                           TextWrapping="Wrap"
                           Foreground="{StaticResource TextSecondaryBrush}"/>
              </Border>
            </Border>
          </StackPanel>

          <!-- STUDIES — list-row pattern (no nested cards) -->
          <StackPanel Spacing="10"
                      IsVisible="{Binding SelectedPatient.StudyCount}">
            <DockPanel>
              <TextBlock DockPanel.Dock="Left"
                         Text="STUDIES"
                         Classes="eyebrow"/>
              <TextBlock DockPanel.Dock="Right"
                         Classes="mono"
                         FontSize="10"
                         Text="{Binding SelectedPatient.StudyCount}"/>
              <Panel/>
            </DockPanel>
            <!-- Single Bezel for the studies list block. Studies
                 themselves are rows inside, no further nesting. -->
            <Border Padding="1.5"
                    CornerRadius="14"
                    Background="{StaticResource SurfaceBaseBrush}"
                    BorderBrush="{StaticResource DividerBrush}"
                    BorderThickness="1">
              <Border Padding="10,8"
                      CornerRadius="12"
                      Background="{StaticResource SurfaceCardBrush}">
                <StackPanel>

                  <!-- Latest study row -->
                  <Button Classes="ghost"
                          Padding="14,12"
                          HorizontalAlignment="Stretch"
                          HorizontalContentAlignment="Stretch">
                    <Grid ColumnDefinitions="Auto,*,Auto"
                          VerticalAlignment="Center">
                      <Border Grid.Column="0"
                              Width="32" Height="32"
                              CornerRadius="6"
                              Background="{StaticResource AccentTintBrush}"
                              Margin="0,0,12,0">
                        <TextBlock Text="{Binding SelectedPatient.LatestModality}"
                                   FontSize="10"
                                   FontWeight="SemiBold"
                                   LetterSpacing="0.6"
                                   Foreground="{StaticResource AccentBrush}"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"/>
                      </Border>
                      <StackPanel Grid.Column="1" Spacing="2">
                        <TextBlock Text="Latest study"
                                   FontSize="{StaticResource FontSizeSmall}"
                                   Foreground="{StaticResource TextSecondaryBrush}"/>
                        <TextBlock Text="{Binding SelectedPatient.LatestStudyDate}"
                                   FontSize="{StaticResource FontSizeCallout}"
                                   FontWeight="Medium"
                                   Foreground="{StaticResource TextPrimaryBrush}"/>
                      </StackPanel>
                      <!-- Button-in-Button trailing arrow per spec §7.2 -->
                      <Border Grid.Column="2"
                              Width="24" Height="24"
                              CornerRadius="999"
                              Background="{StaticResource SurfaceRaisedBrush}"
                              VerticalAlignment="Center">
                        <TextBlock Text="›"
                                   FontSize="14"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource TextSecondaryBrush}"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"/>
                      </Border>
                    </Grid>
                  </Button>
                  <!-- #191 — Quick scan CTA. Kicks Gemini Flash triage
                       on the latest study's primary series; report
                       lands in chat as an assistant_response card. -->
                  <Border Height="1"
                          Background="{StaticResource DividerBrush}"
                          Margin="14,0"/>
                  <Button Classes="ghost"
                          Padding="14,12" Margin="0,2,0,0"
                          HorizontalAlignment="Stretch"
                          HorizontalContentAlignment="Stretch"
                          Command="{Binding TriggerQuickScanCommand}"
                          IsEnabled="{Binding !IsQuickScanRunning}"
                          ToolTip.Tip="Run a preliminary AI screen on the latest study (Gemini Flash). Report appears in chat. Not a diagnosis.">
                    <Grid ColumnDefinitions="Auto,*,Auto"
                          VerticalAlignment="Center">
                      <TextBlock Grid.Column="0"
                                 Text="🔍" FontSize="18"
                                 Margin="6,0,14,0"
                                 VerticalAlignment="Center"/>
                      <StackPanel Grid.Column="1" Spacing="2">
                        <!-- #191 — title + optional "(running…)" badge.
                             Run can't carry IsVisible, so we split into
                             two TextBlocks side-by-side. -->
                        <StackPanel Orientation="Horizontal" Spacing="6">
                          <TextBlock Text="Quick scan"
                                     FontSize="{StaticResource FontSizeCallout}"
                                     FontWeight="SemiBold"
                                     Foreground="{StaticResource TextPrimaryBrush}"/>
                          <TextBlock Text="(running…)"
                                     IsVisible="{Binding IsQuickScanRunning}"
                                     FontSize="{StaticResource FontSizeCallout}"
                                     FontWeight="SemiBold"
                                     Foreground="{StaticResource AccentBrush}"/>
                        </StackPanel>
                        <TextBlock Text="Preliminary AI screen via Gemini Flash · report in chat"
                                   FontSize="{StaticResource FontSizeCaption}"
                                   Foreground="{StaticResource TextTertiaryBrush}"/>
                      </StackPanel>
                      <Border Grid.Column="2"
                              Width="24" Height="24"
                              CornerRadius="999"
                              Background="{StaticResource AccentBrush}"
                              VerticalAlignment="Center">
                        <TextBlock Text="→"
                                   FontSize="14"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource TextOnAccentBrush}"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"/>
                      </Border>
                    </Grid>
                  </Button>
                </StackPanel>
              </Border>
            </Border>
          </StackPanel>

          <!-- Footer: registered / updated timestamps -->
          <TextBlock FontSize="{StaticResource FontSizeCaption}"
                     Foreground="{StaticResource TextTertiaryBrush}"
                     Margin="0,8,0,0">
            <Run Text="Registered timestamp "/><Run Text="{Binding SelectedPatient.CreatedAt}"/><Run Text="  ·  "/><Run Text="Updated "/><Run Text="{Binding SelectedPatient.UpdatedAt}"/>
          </TextBlock>

        </StackPanel>
      </Grid>
    </ScrollViewer>

  </Grid>
</UserControl>
