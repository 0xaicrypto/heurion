<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="RuneDesktop.UI.App"
             RequestedThemeVariant="Dark">

  <Application.Resources>
    <!-- ═════════════════════════════════════════════════════════════════
         #182 Design System v2 — Editorial × Apple HIG.

         Replaces the v1 "cool-dark clinical" palette with a light-first
         bone-paper surface stack + apothecary-green accent. Tonality
         shifted from "scanner readout" to "consultant's case-book on
         a polished oak desk" — quieter, more readable, less dashboard.

         Token KEYS preserved for binding stability — every existing
         StaticResource lookup in the codebase still resolves. Only
         hex values change. New tokens (UiFontDisplay / UiFontSerif /
         shadow brushes / spacing constants) added below.

         Read DESIGN_SYSTEM_v2.md before changing any value here —
         the doc has the rationale for every choice + the pre-flight
         checklist for new surfaces.
         ═══════════════════════════════════════════════════════════════ -->

    <!-- ── #185 Surface stack — midnight navy (login-page tonality) ───
         Pulled directly from the passkey login page: header is
         #0F1729 deep midnight navy. We climb the same hue family for
         lifted surfaces. The login page also features the indigo →
         violet gradient (#667eea → #764ba2) which we sample for the
         accent. -->
    <Color x:Key="SurfaceBase">#0F1729</Color>           <!-- midnight navy (window)  -->
    <Color x:Key="SurfaceCard">#182338</Color>           <!-- lifted card surface     -->
    <Color x:Key="SurfaceRaised">#1F2C42</Color>         <!-- inputs / hover          -->
    <Color x:Key="SurfaceMuted">#131C2D</Color>          <!-- sidebar / source-list   -->
    <Color x:Key="SurfaceSunken">#0A101E</Color>         <!-- chat input wells        -->
    <Color x:Key="SurfaceInk">#F0F2F5</Color>            <!-- inverse (light CTA bg)  -->

    <!-- ── Text scale ─────────────────────────────────────────────────
         Cool-tinted ink-on-paper inverted to light-on-navy. Primary
         95% white (slight cool tint to match surfaces). -->
    <Color x:Key="TextPrimary">#F0F2F5</Color>           <!-- 95% white, slight cool  -->
    <Color x:Key="TextSecondary">#9CA8BD</Color>         <!-- muted blue-grey         -->
    <Color x:Key="TextTertiary">#5F6C82</Color>          <!-- timestamps, meta        -->
    <Color x:Key="TextOnAccent">#FFFFFF</Color>          <!-- text on indigo CTA      -->
    <Color x:Key="TextOnInk">#0F1729</Color>             <!-- dark text on light CTA  -->

    <!-- ── Hairline borders ──────────────────────────────────────────
         Same blue family lifted from base by ~8% L*. -->
    <Color x:Key="Divider">#1F2C42</Color>
    <Color x:Key="DividerStrong">#2A3855</Color>

    <!-- ── #189 Accent — Google Blue (matches login-page button) ──────
         Previous version used #6B7EE6 sampled from the page gradient.
         User showed the actual login screenshot — the "Sign in with
         Passkey" button is solid #1A73E8 (Google blue). Switching the
         desktop accent to match so the same color drives every CTA
         from login through the in-app surfaces.

         Legacy keys (SystemBlue / AccentClaude / BrandAccent) all
         alias to the same blue so existing XAML bindings resolve. -->
    <Color x:Key="Accent">#1A73E8</Color>                <!-- google blue             -->
    <Color x:Key="AccentHover">#1765CC</Color>           <!-- login page hover state  -->
    <Color x:Key="AccentPress">#0F4FA0</Color>           <!-- deeper press            -->
    <Color x:Key="AccentTint">#1F2B4A</Color>            <!-- selected-row on navy    -->

    <!-- Legacy aliases — all point at Google blue. -->
    <Color x:Key="SystemBlue">#1A73E8</Color>
    <Color x:Key="SystemBlueHover">#1765CC</Color>
    <Color x:Key="SystemBluePressed">#0F4FA0</Color>
    <Color x:Key="SystemBlueTint">#401A73E8</Color>      <!-- ~25% blue ARGB          -->
    <Color x:Key="AccentClaude">#1A73E8</Color>
    <Color x:Key="AccentClaudeHover">#1765CC</Color>
    <Color x:Key="BrandAccent">#1A73E8</Color>

    <!-- ── BNB Highlight ──────────────────────────────────────────────
         The login-page logo uses BNB yellow #F0B90B as the "N" mark.
         Reserved for: brand identity in logo tiles, very-important
         status (e.g. "anchored on chain"), and never as a general
         CTA color. -->
    <Color x:Key="AccentHighlight">#F0B90B</Color>       <!-- BNB yellow              -->

    <!-- Secondary typed accents — used very sparingly for data-class
         badges. Each picked to harmonize with the indigo accent. -->
    <Color x:Key="AccentPatient">#7DD3FC</Color>         <!-- sky blue — patients     -->
    <Color x:Key="AccentTask">#F0B90B</Color>            <!-- BNB yellow — tasks      -->
    <Color x:Key="AccentAI">#A78BFA</Color>              <!-- violet — agent thinking -->
    <Color x:Key="AccentMedical">#1A73E8</Color>         <!-- = primary               -->

    <!-- Login / welcome gradient — matches the login page exactly. -->
    <Color x:Key="BrandPurpleStart">#667EEA</Color>      <!-- indigo                  -->
    <Color x:Key="BrandPurpleEnd">#764BA2</Color>        <!-- violet                  -->

    <!-- ── Semantic colors ────────────────────────────────────────────
         Login-page Google palette tuned for dark navy backgrounds.
         Slightly lifted L* so they don't muddy on the deep base. -->
    <Color x:Key="Success">#34A853</Color>               <!-- google green            -->
    <Color x:Key="Warning">#FBBC04</Color>               <!-- google amber            -->
    <Color x:Key="Error">#EA4335</Color>                 <!-- google red              -->
    <Color x:Key="Info">#1A73E8</Color>                  <!-- google blue             -->

    <SolidColorBrush x:Key="SurfaceBaseBrush" Color="{StaticResource SurfaceBase}"/>
    <SolidColorBrush x:Key="SurfaceCardBrush" Color="{StaticResource SurfaceCard}"/>
    <SolidColorBrush x:Key="SurfaceRaisedBrush" Color="{StaticResource SurfaceRaised}"/>
    <SolidColorBrush x:Key="SurfaceMutedBrush" Color="{StaticResource SurfaceMuted}"/>
    <SolidColorBrush x:Key="SurfaceSunkenBrush" Color="{StaticResource SurfaceSunken}"/>
    <SolidColorBrush x:Key="SurfaceInkBrush" Color="{StaticResource SurfaceInk}"/>
    <SolidColorBrush x:Key="TextPrimaryBrush" Color="{StaticResource TextPrimary}"/>
    <SolidColorBrush x:Key="TextSecondaryBrush" Color="{StaticResource TextSecondary}"/>
    <SolidColorBrush x:Key="TextTertiaryBrush" Color="{StaticResource TextTertiary}"/>
    <SolidColorBrush x:Key="TextOnAccentBrush" Color="{StaticResource TextOnAccent}"/>
    <SolidColorBrush x:Key="TextOnInkBrush" Color="{StaticResource TextOnInk}"/>
    <SolidColorBrush x:Key="DividerBrush" Color="{StaticResource Divider}"/>
    <SolidColorBrush x:Key="DividerStrongBrush" Color="{StaticResource DividerStrong}"/>
    <!-- #182 — primary accent brushes. AccentBrush is canonical;
         SystemBlue* / AccentClaude* / BrandAccent are preserved
         aliases pointing at the same Apothecary Green so existing
         StaticResource lookups continue to resolve. -->
    <SolidColorBrush x:Key="AccentBrush" Color="{StaticResource Accent}"/>
    <SolidColorBrush x:Key="AccentHoverBrush" Color="{StaticResource AccentHover}"/>
    <SolidColorBrush x:Key="AccentPressBrush" Color="{StaticResource AccentPress}"/>
    <SolidColorBrush x:Key="AccentTintBrush" Color="{StaticResource AccentTint}"/>
    <SolidColorBrush x:Key="SystemBlueBrush" Color="{StaticResource SystemBlue}"/>
    <SolidColorBrush x:Key="SystemBlueHoverBrush" Color="{StaticResource SystemBlueHover}"/>
    <SolidColorBrush x:Key="SystemBlueTintBrush" Color="{StaticResource SystemBlueTint}"/>
    <SolidColorBrush x:Key="AccentClaudeBrush" Color="{StaticResource AccentClaude}"/>
    <SolidColorBrush x:Key="BrandAccentBrush" Color="{StaticResource BrandAccent}"/>
    <SolidColorBrush x:Key="SuccessBrush" Color="{StaticResource Success}"/>
    <SolidColorBrush x:Key="WarningBrush" Color="{StaticResource Warning}"/>
    <SolidColorBrush x:Key="ErrorBrush" Color="{StaticResource Error}"/>
    <SolidColorBrush x:Key="InfoBrush" Color="{StaticResource Info}"/>
    <!-- Typed accent brushes (sage/amber/plum/green) — used sparingly
         for data-class badges; never compete with primary Accent. -->
    <SolidColorBrush x:Key="AccentPatientBrush" Color="{StaticResource AccentPatient}"/>
    <SolidColorBrush x:Key="AccentTaskBrush"    Color="{StaticResource AccentTask}"/>
    <SolidColorBrush x:Key="AccentAIBrush"      Color="{StaticResource AccentAI}"/>
    <SolidColorBrush x:Key="AccentMedicalBrush" Color="{StaticResource AccentMedical}"/>
    <!-- #185 — BNB yellow highlight brush. Login-page logo uses this
         for the "N" mark. Reserved for brand identity + rare
         high-importance states. Never use as general CTA. -->
    <SolidColorBrush x:Key="AccentHighlightBrush" Color="{StaticResource AccentHighlight}"/>

    <!-- ── #182 Typography (Editorial × HIG) ──────────────────────────
         SF Pro family on macOS is system-bundled (no asset needed).
         UiFontFamily is body text (SF Pro Text); UiFontDisplay is
         tightened display variant for titles. UiFontSerif (New York)
         is reserved for editorial accents only — patient name in
         hero, chart titles, etc. Mono for identifiers (PHI hash,
         MRN, file_id). Inter dropped — it was the v1 generic-LLM
         tell flagged by design-taste-frontend §4.1. -->
    <FontFamily x:Key="UiFontFamily">SF Pro Text, -apple-system, BlinkMacSystemFont, Helvetica Neue, sans-serif</FontFamily>
    <FontFamily x:Key="UiFontDisplay">SF Pro Display, -apple-system, BlinkMacSystemFont, Helvetica Neue, sans-serif</FontFamily>
    <FontFamily x:Key="UiFontMono">SF Mono, Menlo, Monaco, monospace</FontFamily>
    <FontFamily x:Key="UiFontSerif">New York, Georgia, Times New Roman, serif</FontFamily>

    <!-- Type scale — HIG-rooted with Editorial display sizes added on
         top. Specific keys map to the spec §3 scale. -->
    <x:Double x:Key="FontSizeCaption">11</x:Double>
    <x:Double x:Key="FontSizeSmall">12</x:Double>
    <x:Double x:Key="FontSizeBody">13</x:Double>
    <x:Double x:Key="FontSizeCallout">14</x:Double>
    <x:Double x:Key="FontSizeSubhead">15</x:Double>
    <x:Double x:Key="FontSizeHeadline">17</x:Double>
    <x:Double x:Key="FontSizeTitle3">20</x:Double>
    <x:Double x:Key="FontSizeTitle2">24</x:Double>
    <x:Double x:Key="FontSizeTitle1">32</x:Double>
    <x:Double x:Key="FontSizeLargeTitle">40</x:Double>
    <!-- Legacy alias preserved for views still using FontSizeTitle. -->
    <x:Double x:Key="FontSizeTitle">22</x:Double>

    <!-- ── #182 Spacing scale (8pt grid) ──────────────────────────────-->
    <x:Double x:Key="Space1">4</x:Double>
    <x:Double x:Key="Space2">8</x:Double>
    <x:Double x:Key="Space3">12</x:Double>
    <x:Double x:Key="Space4">16</x:Double>   <!-- default gap          -->
    <x:Double x:Key="Space5">20</x:Double>
    <x:Double x:Key="Space6">24</x:Double>
    <x:Double x:Key="Space8">32</x:Double>
    <x:Double x:Key="Space10">40</x:Double>
    <x:Double x:Key="Space12">48</x:Double>   <!-- section padding       -->
    <x:Double x:Key="Space16">64</x:Double>
    <x:Double x:Key="Space20">80</x:Double>
    <x:Double x:Key="Space24">96</x:Double>   <!-- hero macro-whitespace -->

    <!-- ── #182 Radii ─────────────────────────────────────────────────
         Avalonia 11.3's CornerRadius resource declarations don't
         reliably parse single-value text content (converter is
         wired to property setters, not standalone resource text).
         Inline the values in styles + views instead. Reference:
           Sm = 6   Md = 10   Lg = 14   Xl = 20   Pill = 999 -->
    <x:Double x:Key="RadiusSmVal">6</x:Double>
    <x:Double x:Key="RadiusMdVal">10</x:Double>
    <x:Double x:Key="RadiusLgVal">14</x:Double>
    <x:Double x:Key="RadiusXlVal">20</x:Double>
    <x:Double x:Key="RadiusPillVal">999</x:Double>

    <!-- #182 — shadow tokens deferred. Avalonia's BoxShadows type
         doesn't parse cleanly from a resource definition (its
         converter is wired to the property setter only), and the
         hairline border + Double-Bezel "outer paper shell" already
         gives enough visual depth. Re-add later via attached
         behaviours or per-view inline BoxShadow="..." once we have
         a tested pattern. -->

    <!-- Chat bubble fills — assistant on Card (lifted navy), user
         on Accent indigo so the dark-mode chat reads with clear
         iMessage-style hierarchy. -->
    <SolidColorBrush x:Key="BubbleAssistantBrush" Color="{StaticResource SurfaceCard}"/>
    <SolidColorBrush x:Key="BubbleUserBrush" Color="{StaticResource Accent}"/>

    <!-- Login + welcome gradient — light bone-paper variant. -->
    <LinearGradientBrush x:Key="BrandPurpleGradient"
                         StartPoint="0%,0%" EndPoint="100%,100%">
      <GradientStop Color="{StaticResource BrandPurpleStart}" Offset="0"/>
      <GradientStop Color="{StaticResource BrandPurpleEnd}"   Offset="1"/>
    </LinearGradientBrush>
  </Application.Resources>

  <Application.Styles>
    <FluentTheme>
      <FluentTheme.Palettes>
        <!-- #185 — Dark palette matches the login-page tonality:
             midnight navy region color, indigo accent (sampled from
             the login gradient), cool-light text on dark. Anything
             unstyled (ContentDialog, native menus, etc.) picks this
             up so the chrome reads as one coherent dark product. -->
        <ColorPaletteResources x:Key="Dark"
                               Accent="#1A73E8"
                               BaseHigh="#F0F2F5"
                               BaseMedium="#9CA8BD"
                               BaseLow="#2A3855"
                               RegionColor="#0F1729"/>
        <!-- Light kept for future toggle but not the default. -->
        <ColorPaletteResources x:Key="Light"
                               Accent="#1A73E8"
                               BaseHigh="#15130F"
                               BaseMedium="#5C564B"
                               BaseLow="#E5DDD0"
                               RegionColor="#FAF7F2"/>
      </FluentTheme.Palettes>
    </FluentTheme>

    <!-- ── #182 Global typography baseline ────────────────────────────
         SF Pro everywhere by default. Display variant for titles only —
         views that need it set FontFamily explicitly. -->
    <Style Selector="TextBlock">
      <Setter Property="FontFamily" Value="{StaticResource UiFontFamily}"/>
    </Style>
    <Style Selector="TextBox">
      <Setter Property="FontFamily" Value="{StaticResource UiFontFamily}"/>
    </Style>
    <Style Selector="Button">
      <Setter Property="FontFamily" Value="{StaticResource UiFontFamily}"/>
    </Style>

    <!-- ── #182 Eyebrow tag style ─────────────────────────────────────
         Microscopic uppercase pill that precedes major section / card
         titles. Editorial × HIG signature element. -->
    <Style Selector="TextBlock.eyebrow">
      <Setter Property="FontSize" Value="10"/>
      <Setter Property="FontWeight" Value="SemiBold"/>
      <Setter Property="LetterSpacing" Value="1.8"/>
      <Setter Property="Foreground" Value="{StaticResource TextTertiaryBrush}"/>
    </Style>

    <!-- ── #182 Display title style ───────────────────────────────────
         Hero titles. SF Pro Display + tightened tracking. -->
    <Style Selector="TextBlock.display">
      <Setter Property="FontFamily" Value="{StaticResource UiFontDisplay}"/>
      <Setter Property="LetterSpacing" Value="-0.4"/>
    </Style>

    <!-- ── #182 Mono identifier style ─────────────────────────────────
         For PHI hash / MRN / file_id. Tertiary color signals
         "not human-meaningful". -->
    <Style Selector="TextBlock.mono">
      <Setter Property="FontFamily" Value="{StaticResource UiFontMono}"/>
      <Setter Property="Foreground" Value="{StaticResource TextTertiaryBrush}"/>
    </Style>

    <!-- ── Inputs (Editorial) ─────────────────────────────────────────
         Hairline border, accent ring on focus, paper-raised bg. -->
    <Style Selector="TextBox.chat">
      <Setter Property="Background" Value="{StaticResource SurfaceCardBrush}"/>
      <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
      <Setter Property="CaretBrush" Value="{StaticResource AccentBrush}"/>
      <Setter Property="SelectionBrush" Value="{StaticResource AccentTintBrush}"/>
      <Setter Property="BorderBrush" Value="{StaticResource DividerBrush}"/>
      <Setter Property="BorderThickness" Value="1"/>
      <Setter Property="CornerRadius" Value="10"/>
      <Setter Property="Padding" Value="12,9"/>
      <Setter Property="FontSize" Value="13"/>
    </Style>
    <Style Selector="TextBox.chat:focus /template/ Border#PART_BorderElement">
      <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}"/>
      <Setter Property="BorderThickness" Value="1.5"/>
    </Style>

    <!-- ── #189 Primary CTA (Google blue) ─────────────────────────────
         Sized to match the login-page "Sign in with Passkey" button:
         15px text, SemiBold, ~14px vertical padding so the button is
         ~48px tall when content is single-line. One CTA per surface. -->
    <Style Selector="Button.accent">
      <Setter Property="Background" Value="{StaticResource AccentBrush}"/>
      <Setter Property="Foreground" Value="{StaticResource TextOnAccentBrush}"/>
      <Setter Property="BorderThickness" Value="0"/>
      <Setter Property="CornerRadius" Value="10"/>
      <Setter Property="Padding" Value="24,13"/>
      <Setter Property="FontWeight" Value="SemiBold"/>
      <Setter Property="FontSize" Value="15"/>
    </Style>
    <Style Selector="Button.accent:pointerover /template/ ContentPresenter">
      <Setter Property="Background" Value="{StaticResource AccentHoverBrush}"/>
    </Style>
    <Style Selector="Button.accent:pressed /template/ ContentPresenter">
      <Setter Property="Background" Value="{StaticResource AccentPressBrush}"/>
    </Style>
    <Style Selector="Button.accent:disabled /template/ ContentPresenter">
      <Setter Property="Background" Value="{StaticResource SurfaceRaisedBrush}"/>
      <Setter Property="TextElement.Foreground" Value="{StaticResource TextTertiaryBrush}"/>
    </Style>

    <!-- ── Tinted secondary ───────────────────────────────────────────
         Accent-tint background with accent foreground. Used for the
         second-most-important action where a ghost would feel too
         weak. Per design system §7.2. -->
    <Style Selector="Button.tinted">
      <Setter Property="Background" Value="{StaticResource AccentTintBrush}"/>
      <Setter Property="Foreground" Value="{StaticResource AccentBrush}"/>
      <Setter Property="BorderThickness" Value="0"/>
      <Setter Property="CornerRadius" Value="10"/>
      <Setter Property="Padding" Value="18,10"/>
      <Setter Property="FontWeight" Value="SemiBold"/>
      <Setter Property="FontSize" Value="14"/>
    </Style>
    <Style Selector="Button.tinted:pointerover /template/ ContentPresenter">
      <!-- ~30% indigo for a slightly punchier hover. -->
      <Setter Property="Background" Value="#4D6B7EE6"/>
    </Style>

    <!-- ── Pill variant (round-cap) ───────────────────────────────────-->
    <Style Selector="Button.pill">
      <Setter Property="CornerRadius" Value="999"/>
      <Setter Property="Padding" Value="22,10"/>
      <Setter Property="FontWeight" Value="Medium"/>
    </Style>

    <!-- ── Ghost / plain ──────────────────────────────────────────────
         Text-only on transparent. Hover tints with raised paper not
         white-alpha (which was wrong on dark v1 too). -->
    <Style Selector="Button.ghost">
      <Setter Property="Background" Value="Transparent"/>
      <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}"/>
      <Setter Property="BorderThickness" Value="0"/>
      <Setter Property="CornerRadius" Value="10"/>
      <Setter Property="Padding" Value="14,9"/>
      <Setter Property="FontSize" Value="14"/>
    </Style>
    <Style Selector="Button.ghost:pointerover /template/ ContentPresenter">
      <Setter Property="Background" Value="{StaticResource SurfaceRaisedBrush}"/>
      <Setter Property="TextElement.Foreground" Value="{StaticResource TextPrimaryBrush}"/>
    </Style>
    <Style Selector="Button.ghost:pressed /template/ ContentPresenter">
      <Setter Property="Background" Value="{StaticResource SurfaceMutedBrush}"/>
    </Style>

    <!-- ── Destructive ───────────────────────────────────────────────-->
    <Style Selector="Button.destructive">
      <Setter Property="Background" Value="{StaticResource ErrorBrush}"/>
      <Setter Property="Foreground" Value="{StaticResource TextOnInkBrush}"/>
      <Setter Property="BorderThickness" Value="0"/>
      <Setter Property="CornerRadius" Value="10"/>
      <Setter Property="Padding" Value="14,8"/>
      <Setter Property="FontWeight" Value="Medium"/>
    </Style>

    <!-- ── Sidebar source-list rows ───────────────────────────────────-->
    <Style Selector="Button.sidebar">
      <Setter Property="Background" Value="Transparent"/>
      <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}"/>
      <Setter Property="BorderThickness" Value="0"/>
      <Setter Property="HorizontalAlignment" Value="Stretch"/>
      <Setter Property="HorizontalContentAlignment" Value="Left"/>
      <Setter Property="Padding" Value="12,8"/>
      <Setter Property="CornerRadius" Value="6"/>
      <Setter Property="FontSize" Value="13"/>
    </Style>
    <Style Selector="Button.sidebar:pointerover /template/ ContentPresenter">
      <Setter Property="Background" Value="{StaticResource SurfaceRaisedBrush}"/>
      <Setter Property="TextElement.Foreground" Value="{StaticResource TextPrimaryBrush}"/>
    </Style>
    <Style Selector="Button.sidebar.selected /template/ ContentPresenter">
      <Setter Property="Background" Value="{StaticResource AccentTintBrush}"/>
      <Setter Property="TextElement.Foreground" Value="{StaticResource TextPrimaryBrush}"/>
    </Style>

    <!-- ── Toolbar buttons (top bar) ──────────────────────────────────-->
    <Style Selector="Button.toolbar">
      <Setter Property="Background" Value="Transparent"/>
      <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}"/>
      <Setter Property="BorderThickness" Value="0"/>
      <Setter Property="CornerRadius" Value="6"/>
      <Setter Property="Padding" Value="10,5"/>
      <Setter Property="FontSize" Value="13"/>
    </Style>
    <Style Selector="Button.toolbar:pointerover /template/ ContentPresenter">
      <Setter Property="Background" Value="{StaticResource SurfaceRaisedBrush}"/>
      <Setter Property="TextElement.Foreground" Value="{StaticResource TextPrimaryBrush}"/>
    </Style>
    <Style Selector="Button.toolbar.active /template/ ContentPresenter">
      <Setter Property="Background" Value="{StaticResource SurfaceCardBrush}"/>
      <Setter Property="TextElement.Foreground" Value="{StaticResource TextPrimaryBrush}"/>
      <Setter Property="BorderBrush" Value="{StaticResource DividerBrush}"/>
      <Setter Property="BorderThickness" Value="1"/>
      <Setter Property="CornerRadius" Value="6"/>
    </Style>

    <!-- ── ScrollBar ──────────────────────────────────────────────────
         Light-mode thumb is warm-gray, harmonized with paper bg. -->
    <Style Selector="ScrollBar:vertical /template/ Thumb">
      <Setter Property="Background" Value="#3A4862"/>
    </Style>
    <Style Selector="ScrollBar:horizontal /template/ Thumb">
      <Setter Property="Background" Value="#3A4862"/>
    </Style>

    <!-- ── ProgressBar ────────────────────────────────────────────────-->
    <Style Selector="ProgressBar">
      <Setter Property="Foreground" Value="{StaticResource AccentBrush}"/>
      <Setter Property="Background" Value="{StaticResource SurfaceMutedBrush}"/>
    </Style>
  </Application.Styles>
</Application>
