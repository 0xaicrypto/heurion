# ══════════════════════════════════════════════════════════════════════
# Rune Server — Environment Configuration
# ══════════════════════════════════════════════════════════════════════
# Server is a standalone API gateway. It does NOT import Nexus or run
# DigitalTwin. It only uses SDK's LLMClient for LLM proxying and has
# its own chain integration for agent registration.

# ── Server ───────────────────────────────────────────────────────────

# ── Authentication ───────────────────────────────────────────────────
WEBAUTHN_RP_ID=localhost
WEBAUTHN_RP_NAME=Rune Protocol
WEBAUTHN_ORIGIN=http://localhost:3000
JWT_ALGORITHM=HS256
JWT_EXPIRATION_HOURS=24

# ── CORS ─────────────────────────────────────────────────────────────

# ── LLM Gateway ─────────────────────────────────────────────────────
DEFAULT_LLM_PROVIDER=gemini
DEFAULT_LLM_MODEL=gemini-2.5-flash
GEMINI_API_KEY=AIzaSyBDndNg6l5NJp5V8dBLZz2PLccl4IxHU-s
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=

# ── Tool Execution (server runs tools on behalf of clients) ──────────
TAVILY_API_KEY=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
# JINA_API_KEY=

# ── Chain Proxy ──────────────────────────────────────────────────────
# Server signs on-chain transactions on behalf of users.
CHAIN_RPC_URL=https://data-seed-prebsc-1-s1.bnbchain.org:8545
CHAIN_AGENT_CONTRACT_ADDRESS=0x8004A818BFB912233c491871b3d84c89A494BD9e

# ── Rate Limiting ────────────────────────────────────────────────────
RATE_LIMIT_LLM_REQUESTS_PER_MINUTE=60
RATE_LIMIT_OTHER_REQUESTS_PER_MINUTE=120

# ── Database ─────────────────────────────────────────────────────────

# ── Hosted email relay — production path (#116/#117) ────────────────
# Client (Nexus desktop) calls this relay; relay holds the real SMTP
# password in Fly.io secrets. SAFE TO BUNDLE — the API key is gated
# by per-user rate limit + recipient allow-list on the relay side;
# even if extracted from the .dmg, blast radius is bounded.
#
# Rotate cred: `flyctl secrets set RELAY_API_KEY=...` (relay side)
#              + update this file + rebuild .dmg + push to users.
NEXUS_RELAY_URL=https://nexus-email-relay.fly.dev
NEXUS_RELAY_API_KEY=ea875UwtabezKIOWLdANV92Ub8OOTHnZAQNt0GYqKvE

# ── Storage backend (#134) ───────────────────────────────────────────
# Greenfield (BNB Chain decentralised storage) sync is DISABLED while
# we migrate to an S3-compatible object-storage backend for durability.
# Local disk + SQL stays as the authoritative store for chat. Set this
# to "0" only to test the legacy Greenfield code path; existing users
# inherit the safer default via start.sh's bundle-merge logic.
NEXUS_GREENFIELD_DISABLED=1

# ── DIRECT SMTP — dev fallback only ──────────────────────────────────
# These are intentionally COMMENTED OUT in the production bundle.
# Direct SMTP would bypass relay's rate-limit + audit + allow-list,
# and shipping the password to medics' machines is the exact mistake
# the relay exists to prevent. Only set locally (in
# $RUNE_HOME/.env, NOT here) for offline-dev iteration.
#NEXUS_SMTP_HOST=smtp.gmail.com
#NEXUS_SMTP_PORT=587
#NEXUS_SMTP_USER=
#NEXUS_SMTP_PASSWORD=
#NEXUS_SMTP_FROM=
#NEXUS_SMTP_ALLOWED_RECIPIENTS=
