# ── Native binary handling ────────────────────────────────────────────
# Flat node_modules layout — esbuild's lookup paths and node-native
# dependency probing both expect top-level layout. Without this, vite/
# rollup native binaries become unreachable.
node-linker=hoisted

# Auto-install peer deps (pnpm v9+ default; explicit for safety)
auto-install-peers=true

# ── postinstall script approval ───────────────────────────────────────
# pnpm 10/11 both fail builds when ANY transitive dep has an unapproved
# postinstall (ERR_PNPM_IGNORED_BUILDS). Different versions read
# different keys for the bypass:
#
#   pnpm 10 :  strict-dep-builds=false  + dangerously-allow-all-builds=true
#              and onlyBuiltDependencies in package.json
#   pnpm 11 :  allowBuilds: { <pkg>: true } in pnpm config store
#              (set via `pnpm approve-builds`)
#
# We put both forms so either version is satisfied. pnpm 11 silently
# ignores the pnpm-10 keys; pnpm 10 silently ignores the pnpm-11 ones.
strict-dep-builds=false
dangerously-allow-all-builds=true
