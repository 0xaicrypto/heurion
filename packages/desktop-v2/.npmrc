# Hoisted node-linker — flat node_modules at the top level, like npm.
# This fixes two things at once:
#   1. node_modules/esbuild/ exists at top level (so cd works)
#   2. esbuild's postinstall is reachable as a first-party script,
#      letting pnpm.onlyBuiltDependencies in package.json actually
#      approve it (instead of silently blocking).
node-linker=hoisted

# Auto-install peer deps (pnpm v9+ default, explicit for safety)
auto-install-peers=true

# Don't fail install on missing build-script approvals — we handle
# esbuild explicitly via package.json pnpm.onlyBuiltDependencies +
# the build-macos.sh ensure_esbuild fallback chain.
strict-dep-builds=false
