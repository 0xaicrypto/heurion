    #      WHERE initials != UPPER(initials)
    # """))


def downgrade() -> None:
    # Data migrations are usually NOT reversible (you can't un-uppercase
    # initials and know which were already capitalised). Document the
    # reversal manually if needed; default = no-op.
    pass
